<Component
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:noesis="clr-namespace:NoesisGUIExtensions"
  xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
  mc:Ignorable="d"
  x:Name="ComponentRoot" d:DesignWidth="1920" d:DesignHeight="1080">

  <Grid x:Name="FadeMask_Vertical">

    <!--Video Upper Fade-->
    <Grid.OpacityMask>
      <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
        <GradientStop Color="#FF000000" Offset="0.5"/>
        <GradientStop Color="#00000000" Offset="0.25"/>
        <GradientStop Color="#00000000" Offset="1"/>
      </LinearGradientBrush>
    </Grid.OpacityMask>
  
    <Grid x:Name="FadeMask_Horizontal">
      <Grid.OpacityMask>
        <LinearGradientBrush StartPoint="0.00329051,0.5" EndPoint="1,0.5">
          <GradientStop Color="#00000000" Offset="0"/>
          <GradientStop Color="#FF000000" Offset="1"/>
        </LinearGradientBrush>
      </Grid.OpacityMask>
      <Grid x:Name="SmokeLayers">
  
        <!--Video Downshift-->
        <Grid.RenderTransform>
          <TransformGroup>
            <ScaleTransform/>
            <SkewTransform/>
            <RotateTransform/>
            <TranslateTransform/>
          </TransformGroup>
        </Grid.RenderTransform>
  
        <!--Video Layer-->
        <MediaElement x:Name="SmokeLayer"
                      Source="/Root;component/Assets/Videos/Video_Smoke_Splash.mp4"
                      LoadedBehavior="Manual"
                      Stretch="UniformToFill"
                      HorizontalAlignment="Center">
  
          <!--Video Loop-->
          <b:Interaction.Triggers>
            <b:EventTrigger EventName="Loaded">
              <noesis:PlayMediaAction/>
            </b:EventTrigger>
            <b:EventTrigger EventName="MediaEnded">
              <noesis:StopMediaAction/>
              <noesis:PlayMediaAction/>
            </b:EventTrigger>
          </b:Interaction.Triggers>
  
          <!--Video Tint-->
          <MediaElement.Effect>
            <noesis:TintEffect Color="{DynamicResource Purple_Light}"/>
          </MediaElement.Effect>
  
        </MediaElement>
  
      </Grid>
    </Grid>
  </Grid>
</Component>