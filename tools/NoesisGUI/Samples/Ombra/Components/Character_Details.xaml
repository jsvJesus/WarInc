    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="Auto"/>
      <ColumnDefinition Width="1*"/>
    </Grid.ColumnDefinitions>

    <Grid x:Name="NavigationArea" HorizontalAlignment="Center">
      <Grid x:Name="ButtonArea" VerticalAlignment="Top">
        <Button x:Name="Button_Escape" Content="escape" Padding="0,0,0,0" VerticalAlignment="Top" Template="{DynamicResource Button_Escape}" Cursor="Hand">
          <b:Interaction.Triggers>
            <b:EventTrigger EventName="Click">
              <b:ChangePropertyAction TargetName="ComponentRoot" PropertyName="IsEnabled" Value="False"/>
            </b:EventTrigger>
          </b:Interaction.Triggers>
        </Button>
      </Grid>
    </Grid>
    <Grid x:Name="ContentArea" Grid.Column="1" Margin="32,0,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="1*"/>
        <ColumnDefinition Width="1*"/>
      </Grid.ColumnDefinitions>
      <Grid x:Name="TitleArea" RenderTransformOrigin="0.5,0.5" Margin="0,0,32,0">
        <Grid.RenderTransform>
          <TransformGroup>
            <ScaleTransform/>
            <SkewTransform/>
            <RotateTransform/>
            <TranslateTransform/>
          </TransformGroup>
        </Grid.RenderTransform>
        <StackPanel x:Name="Title_VerticalStack" RenderTransformOrigin="0.5,0.5" Effect="{DynamicResource TextGlow_Regular}">
          <StackPanel.RenderTransform>
            <TransformGroup>
              <ScaleTransform/>
              <SkewTransform/>
              <RotateTransform/>
              <TranslateTransform/>
            </TransformGroup>
          </StackPanel.RenderTransform>
          <TextBlock x:Name="Text_CharacterName" Text="{Binding Path=Character_Name, StringFormat={}{0}...}" TextWrapping="Wrap" FontFamily="/Root;component/Assets/Fonts/#Libre Bodoni" FontSize="56" HorizontalAlignment="Left" FontStyle="Oblique">
            <TextBlock.LayoutTransform>
              <TransformGroup>
                <ScaleTransform/>
                <SkewTransform/>
                <RotateTransform Angle="-90"/>
                <TranslateTransform/>
              </TransformGroup>
            </TextBlock.LayoutTransform>
            <TextBlock.Foreground>
              <SolidColorBrush Color="{DynamicResource Purple_Light}"/>
            </TextBlock.Foreground>
          </TextBlock>
          <TextBlock x:Name="Text_CharacterNumber" FontFamily="/Root;component/Assets/Fonts/#Libre Bodoni" Text="{Binding Path=Character_Number, StringFormat=(0{0})}" FontStyle="Oblique" FontSize="56" TextWrapping="Wrap" Margin="0,16,0,0">
            <TextBlock.Foreground>
              <SolidColorBrush Color="{DynamicResource Purple_Light}"/>
            </TextBlock.Foreground>
            <TextBlock.LayoutTransform>
              <TransformGroup>
                <ScaleTransform/>
                <SkewTransform/>
                <RotateTransform Angle="-90"/>
                <TranslateTransform/>
              </TransformGroup>
            </TextBlock.LayoutTransform>
          </TextBlock>
        </StackPanel>
      </Grid>
      <Grid x:Name="DescriptionArea" Grid.Column="1" RenderTransformOrigin="0.5,0.5">
        <Grid.RenderTransform>
          <TransformGroup>
            <ScaleTransform/>
            <SkewTransform/>
            <RotateTransform/>
            <TranslateTransform/>
          </TransformGroup>
        </Grid.RenderTransform>
        <TextBlock x:Name="Text_Description" Text="{Binding Path=Character_Description}" TextWrapping="Wrap" FontFamily="/Root;component/Assets/Fonts/#Libre Bodoni" FontSize="32" FontStyle="Oblique" Effect="{DynamicResource TextGlow_Regular}" LineHeight="48">
          <TextBlock.Foreground>
            <SolidColorBrush Color="{DynamicResource Purple_Light}"/>
          </TextBlock.Foreground>
        </TextBlock>
      </Grid>
    </Grid>
  </Grid>
</Component>