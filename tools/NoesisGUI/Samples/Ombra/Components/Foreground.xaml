<Component
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  mc:Ignorable="d"
  x:Name="ComponentRoot" xmlns:noesis="clr-namespace:NoesisGUIExtensions" d:DesignWidth="1920" d:DesignHeight="1080">
  <Grid x:Name="ForegroundGrid" IsHitTestVisible="False">
    <Grid x:Name="Texture" BlendingMode="Screen" Opacity="0.5">
      <Grid.Background>
        <ImageBrush ImageSource="/Root;component/Assets/Bitmaps_Generic_BackgroundsForegrounds/Bitmaps_Generic_BackgroundsForegrounds_Foreground_Texture.png"/>
      </Grid.Background>
    </Grid>
    <Grid x:Name="Noise_Procedural_1" BlendingMode="Multiply" Opacity="0.33">
      <Grid.Background>
        <SolidColorBrush Color="{DynamicResource Purple_Dark}"/>
      </Grid.Background>
      <Grid.Effect>
        <noesis:NoiseEffect Monochromatic="True" Amount="1"/>
      </Grid.Effect>
    </Grid>
    <Grid x:Name="Noise_Procedural_2" BlendingMode="Multiply" Opacity="0.2">
      <Grid.Effect>
        <noesis:NoiseEffect Monochromatic="True"/>
      </Grid.Effect>
      <Grid.Background>
        <SolidColorBrush Color="{DynamicResource Purple_Light}"/>
      </Grid.Background>
    </Grid>
  </Grid>
</Component>