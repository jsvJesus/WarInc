    <ControlTemplate x:Key="MenuButton" TargetType="{x:Type Button}">

      <Grid x:Name="MenuButton_Master" Cursor="Hand">
        <Grid.Background>
          <SolidColorBrush Color="#FFFFFFFF" Opacity="0"/>
        </Grid.Background>

        <VisualStateManager.VisualStateGroups>
          <VisualStateGroup x:Name="CommonStates">
            <VisualStateGroup.Transitions>
              <VisualTransition To="MouseOver">
                <Storyboard>
                  <DoubleAnimationUsingKeyFrames Storyboard.TargetName="MenuButton_Title_Text_Hover" Storyboard.TargetProperty="(UIElement.Opacity)">
                    <EasingDoubleKeyFrame KeyTime="00:00:00" Value="1"/>
                  </DoubleAnimationUsingKeyFrames>
                  <DoubleAnimationUsingKeyFrames Storyboard.TargetName="MenuButton_Title_Text_Normal" Storyboard.TargetProperty="(UIElement.Opacity)">
                    <EasingDoubleKeyFrame KeyTime="00:00:00" Value="0"/>
                  </DoubleAnimationUsingKeyFrames>
                  <DoubleAnimationUsingKeyFrames Storyboard.TargetName="MenuButton_Subtitle_Text_Hover" Storyboard.TargetProperty="(UIElement.Opacity)">
                    <EasingDoubleKeyFrame KeyTime="00:00:00" Value="0"/>
                    <EasingDoubleKeyFrame KeyTime="00:00:00.2000000" Value="1">
                      <EasingDoubleKeyFrame.EasingFunction>
                        <ExponentialEase EasingMode="EaseInOut"/>
                      </EasingDoubleKeyFrame.EasingFunction>
                    </EasingDoubleKeyFrame>
                  </DoubleAnimationUsingKeyFrames>
                  <DoubleAnimationUsingKeyFrames Storyboard.TargetName="MenuButton_Subtitle_Text_Hover" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)">
                    <EasingDoubleKeyFrame KeyTime="00:00:00" Value="-32"/>
                    <EasingDoubleKeyFrame KeyTime="00:00:00.1000000" Value="0"/>
                  </DoubleAnimationUsingKeyFrames>
                  <DoubleAnimationUsingKeyFrames Storyboard.TargetName="MenuButton_Decorative_Backer" Storyboard.TargetProperty="(UIElement.Opacity)">
                    <EasingDoubleKeyFrame KeyTime="00:00:00.2000000" Value="1"/>
                  </DoubleAnimationUsingKeyFrames>
                  <DoubleAnimationUsingKeyFrames Storyboard.TargetName="MenuButton_Decorative_Anchor" Storyboard.TargetProperty="(UIElement.Opacity)">
                    <EasingDoubleKeyFrame KeyTime="00:00:00.2000000" Value="1"/>
                  </DoubleAnimationUsingKeyFrames>
                  <DoubleAnimationUsingKeyFrames Storyboard.TargetName="MenuButton_Decorative_VertLine" Storyboard.TargetProperty="(UIElement.Opacity)">
                    <EasingDoubleKeyFrame KeyTime="00:00:00.2000000" Value="1"/>
                  </DoubleAnimationUsingKeyFrames>
                  <DoubleAnimationUsingKeyFrames Storyboard.TargetName="MenuButton_Decorative_VertLine" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)">
                    <EasingDoubleKeyFrame KeyTime="00:00:00" Value="0"/>
                    <EasingDoubleKeyFrame KeyTime="00:00:00.2000000" Value="1"/>
                  </DoubleAnimationUsingKeyFrames>
                </Storyboard>
              </VisualTransition>
            </VisualStateGroup.Transitions>
            <VisualState x:Name="Normal"/>
            <VisualState x:Name="MouseOver">
              <Storyboard>
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="MenuButton_Title_Text_Hover" Storyboard.TargetProperty="(UIElement.Opacity)">
                  <EasingDoubleKeyFrame KeyTime="00:00:00" Value="1"/>
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="MenuButton_Title_Text_Normal" Storyboard.TargetProperty="(UIElement.Opacity)">
                  <EasingDoubleKeyFrame KeyTime="00:00:00" Value="0"/>
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="MenuButton_Title_Backer" Storyboard.TargetProperty="(UIElement.Opacity)">
                  <EasingDoubleKeyFrame KeyTime="00:00:00" Value="1"/>
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="MenuButton_Subtitle_Backer" Storyboard.TargetProperty="(UIElement.Opacity)">
                  <EasingDoubleKeyFrame KeyTime="00:00:00" Value="1"/>
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="MenuButton_Subtitle_Text_Normal" Storyboard.TargetProperty="(UIElement.Opacity)">
                  <EasingDoubleKeyFrame KeyTime="00:00:00" Value="0"/>
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="MenuButton_Subtitle_Text_Hover" Storyboard.TargetProperty="(UIElement.Opacity)">
                  <EasingDoubleKeyFrame KeyTime="00:00:00" Value="1">
                    <EasingDoubleKeyFrame.EasingFunction>
                      <ExponentialEase EasingMode="EaseInOut"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                  </EasingDoubleKeyFrame>
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="MenuButton_Subtitle_Text_Hover" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)">
                  <EasingDoubleKeyFrame KeyTime="00:00:00" Value="0"/>
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="MenuButton_Decorative_Backer" Storyboard.TargetProperty="(UIElement.Opacity)">
                  <EasingDoubleKeyFrame KeyTime="00:00:00" Value="1"/>
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="MenuButton_Decorative_Anchor" Storyboard.TargetProperty="(UIElement.Opacity)">
                  <EasingDoubleKeyFrame KeyTime="00:00:00" Value="1"/>
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="MenuButton_Decorative_VertLine" Storyboard.TargetProperty="(UIElement.Opacity)">
                  <EasingDoubleKeyFrame KeyTime="00:00:00" Value="1"/>
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="MenuButton_Decorative_VertLine" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)">
                  <EasingDoubleKeyFrame KeyTime="00:00:00" Value="1"/>
                </DoubleAnimationUsingKeyFrames>
                <ColorAnimationUsingKeyFrames Storyboard.TargetName="MenuButton_Title_Text" Storyboard.TargetProperty="(TextElement.Foreground).(SolidColorBrush.Color)">
                  <EasingColorKeyFrame KeyTime="00:00:00" Value="{DynamicResource Green_Light}"/>
                </ColorAnimationUsingKeyFrames>
              </Storyboard>
            </VisualState>
            <VisualState x:Name="Pressed"/>
            <VisualState x:Name="Disabled"/>
          </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
        <StackPanel x:Name="MenuButton_HorzStack" Orientation="Horizontal">
          
          <Grid x:Name="MenuButton_DecorativeBlock" Width="64">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="16"/>
              <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <Grid x:Name="MenuButton_Decorative_Backer" Grid.Column="1" Opacity="0">
              <Grid.Background>
                <SolidColorBrush Color="{DynamicResource Blue_Dark}" Opacity="0.1"/>
              </Grid.Background>
            </Grid>
            <Grid x:Name="MenuButton_Decorative_Anchor" Opacity="0">
              <Grid.Background>
                <SolidColorBrush Color="{DynamicResource Blue_Dark}"/>
              </Grid.Background>
            </Grid>
            <Grid x:Name="MenuButton_Decorative_VertLine" Width="8" HorizontalAlignment="Center" Grid.Column="1" Opacity="0" VerticalAlignment="Center" Height="32">
              <Grid.Background>
                <SolidColorBrush Color="{DynamicResource Blue_Dark}"/>
              </Grid.Background>
              <Grid.RenderTransform>
                <ScaleTransform CenterY="16"/>
              </Grid.RenderTransform>
            </Grid>
          </Grid><StackPanel x:Name="MenuButton_VertStack" Margin="8,0,0,0">
            <Grid x:Name="MenuButton_Title">
              <Grid x:Name="MenuButton_Title_Backer" Opacity="0">
                <Grid.Background>
                  <SolidColorBrush Color="{DynamicResource Blue_Dark}"/>
                </Grid.Background>
              </Grid>
              <TextBlock x:Name="MenuButton_Title_Text" Text="{Binding Path=Content, RelativeSource={RelativeSource TemplatedParent}}" TextWrapping="Wrap" FontFamily="Assets/Fonts/#Octuple max Solid" FontSize="48" Margin="8,4,16,0">
                <TextBlock.Foreground>
                  <SolidColorBrush Color="{DynamicResource Blue_Dark}"/>
                </TextBlock.Foreground>
              </TextBlock>
            </Grid>
            <Grid x:Name="MenuButton_Subtitle" Margin="0,4,0,0">
              <Grid x:Name="MenuButton_Subtitle_Backer" Opacity="0.1">
                <Grid.Background>
                  <SolidColorBrush Color="{DynamicResource Blue_Dark}"/>
                </Grid.Background>
              </Grid>
              <Grid x:Name="MenuButton_Subtitle_ContentVariants" Margin="8,0,8,2">
                
                <TextBlock x:Name="MenuButton_Subtitle_Text_Normal" Text="&gt;&gt;&gt;" TextWrapping="Wrap" FontFamily="Assets/Fonts/#Blaec" VerticalAlignment="Center" Margin="0,2,0,0" FontSize="20">
                  <TextBlock.Foreground>
                    <SolidColorBrush Color="{DynamicResource Blue_Dark}"/>
                  </TextBlock.Foreground>
                </TextBlock><StackPanel x:Name="MenuButton_Subtitle_Text_Hover" Orientation="Horizontal" Opacity="0">
                  <StackPanel.RenderTransform>
                    <TranslateTransform/>
                  </StackPanel.RenderTransform>
                  <TextBlock x:Name="MenuButton_Subtitle_Text_Hover_Action" Text="NAVIGATE" TextWrapping="Wrap" FontFamily="Assets/Fonts/#Gasoek One" VerticalAlignment="Center" FontSize="20">
                    <TextBlock.Foreground>
                      <SolidColorBrush Color="{DynamicResource Grey_Med}"/>
                    </TextBlock.Foreground>
                  </TextBlock>
                  <TextBlock x:Name="MenuButton_Subtitle_Text_Hover_Text_Detail" Text="&gt;&gt;&gt;" TextWrapping="Wrap" FontFamily="Assets/Fonts/#Blaec" VerticalAlignment="Center" Margin="4,2,0,0" FontSize="20">
                    <TextBlock.Foreground>
                      <SolidColorBrush Color="{DynamicResource Grey_Med}"/>
                    </TextBlock.Foreground>
                  </TextBlock>
                </StackPanel>
              </Grid>
            </Grid>
          </StackPanel>
        </StackPanel>
      </Grid>
    </ControlTemplate>

    <ControlTemplate x:Key="BannerButton" TargetType="{x:Type Button}">
      <Grid x:Name="BannerButton_Master" Cursor="Hand">
        <VisualStateManager.VisualStateGroups>
          <VisualStateGroup x:Name="CommonStates">

