<UserControl
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DashMoto"
        mc:Ignorable="d"
        Width="1920" Height="1080" d:DataContext="Data" d:DesignWidth="1920" d:DesignHeight="1080">

    <!--////////////////////////////////////////-->
    <!--TEMPLATES-->
    <!--////////////////////////////////////////-->

    <UserControl.Resources>

        <!--TACHOMETRE TEMPLATE-->
        <!--////////////////////////////////////////-->
        <Style x:Key="ProgressBar_Tachometer" TargetType="{x:Type ProgressBar}">

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="{x:Type ProgressBar}">

                        <!--Construction-->
                        <Grid x:Name="TemplateRoot">

                            <!--Trough-->
                            <Grid x:Name="PART_Track">

                                <Grid Background="Transparent">

                                    <Path Data="M0,0L1080,0"
                                          StrokeThickness="{Binding ActualHeight, ElementName=TemplateRoot}"
                                          Stretch="Fill"
                                          StrokeStartLineCap="Flat" StrokeEndLineCap="Flat"
                                          StrokeDashArray="0.05 0.025"
                                          Margin="-80,0,-80,0">

                                        <Path.Stroke>
                                            <LinearGradientBrush EndPoint="1,0" StartPoint="0,0" Opacity="0.1">
                                                <GradientStop Color="#0166b1" Offset="0"/>
                                                <GradientStop Color="#0166b1" Offset="0.39618286"/>
                                                <GradientStop Color="#ffeb3b" Offset="0.66"/>
                                                <GradientStop Color="Red" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Path.Stroke>

                                    </Path>

                                </Grid>

                            </Grid>

                            <!--Fill-->
                            <Grid x:Name="PART_Indicator" HorizontalAlignment="Left">

                                <!--Bar-->
                                <Grid Background="Transparent"
                                      Width="{Binding ElementName=TemplateRoot, Path=ActualWidth}">

                                    <Path Data="M0,0L1080,0"
                                          StrokeThickness="{Binding ActualHeight, ElementName=TemplateRoot}"
                                          Stretch="Fill"
                                          StrokeStartLineCap="Flat" StrokeEndLineCap="Flat"
                                          StrokeDashArray="0.05 0.025"
                                          Margin="-80,0,-80,0">

                                        <Path.Stroke>
                                            <LinearGradientBrush EndPoint="1,0" StartPoint="0,0" Opacity="1">
                                                <GradientStop Color="#0166b1" Offset="0"/>
                                                <GradientStop Color="#0166b1" Offset="0.4038318"/>
                                                <GradientStop Color="#ffeb3b" Offset="0.66"/>
                                                <GradientStop Color="Red" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Path.Stroke>

                                    </Path>

                                </Grid>

                            </Grid>

                        </Grid>

                        <!--Triggers-->
                        <ControlTemplate.Triggers>

                            <Trigger Property="Orientation" Value="Vertical">
                                <Setter Property="LayoutTransform" TargetName="TemplateRoot">
                                    <Setter.Value>
                                        <RotateTransform Angle="-90"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--RPM READOUT TEMPLATE-->
        <!--////////////////////////////////////////-->

        <!--RepeatButtonTransparent-->
        <Style x:Key="RepeatButtonTransparent" TargetType="{x:Type RepeatButton}">
            <Setter Property="OverridesDefaultStyle" Value="true"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Focusable" Value="false"/>
            <Setter Property="IsTabStop" Value="false"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                        <Rectangle Fill="{TemplateBinding Background}" Height="{TemplateBinding Height}" Width="{TemplateBinding Width}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--RPMSliderThumbVerticalDefault-->
        <ControlTemplate x:Key="RPMSliderThumbVerticalDefault" TargetType="{x:Type Thumb}">

            <Grid HorizontalAlignment="Center" UseLayoutRounding="True" VerticalAlignment="Center">

                <StackPanel x:Name="RPMReadout"
                            Orientation="Vertical">

                    <StackPanel Orientation="Horizontal">

                        <TextBlock Text="{Binding Value,RelativeSource={RelativeSource AncestorType=Slider},StringFormat=F1}"
                                   Foreground="White"
                                   FontSize="80"
                                   FontWeight="Bold" FontStyle="Italic"
                                   HorizontalAlignment="Right">

                            <TextBlock.Effect>
                                <DropShadowEffect Color="#FF6496C8" BlurRadius="64" Direction="0" ShadowDepth="0"/>
                            </TextBlock.Effect>

                        </TextBlock>

                        <TextBlock Text="K"
                                   Foreground="White"
                                   FontSize="80"
                                   FontWeight="Bold" FontStyle="Italic"
                                   HorizontalAlignment="Right">

                            <TextBlock.Effect>
                                <DropShadowEffect Color="#FF6496C8" BlurRadius="64" Direction="0" ShadowDepth="0"/>
                            </TextBlock.Effect>

                        </TextBlock>

                    </StackPanel>

                    <TextBlock Text="RPM"
                               FontStyle="Italic"
                               Foreground="White" FontSize="40"
                               HorizontalAlignment="Right"
                               Margin="0,-16,0,0">

                        <TextBlock.Effect>
                            <DropShadowEffect Color="#FF6496C8" BlurRadius="64" Direction="0" ShadowDepth="0"/>
                        </TextBlock.Effect>

                    </TextBlock>

                </StackPanel>
            </Grid>

        </ControlTemplate>

        <!--RPMSliderVertical-->
        <ControlTemplate x:Key="RPMSliderVertical" TargetType="{x:Type Slider}">

            <Grid HorizontalAlignment="Stretch" Margin="0,-8,0,8">

                <Grid HorizontalAlignment="Right">

                    <Track x:Name="PART_Track">

                        <Track.DecreaseRepeatButton>
                            <RepeatButton Command="{x:Static Slider.DecreaseLarge}" Style="{StaticResource RepeatButtonTransparent}"/>
                        </Track.DecreaseRepeatButton>
                        <Track.IncreaseRepeatButton>
                            <RepeatButton Command="{x:Static Slider.IncreaseLarge}" Style="{StaticResource RepeatButtonTransparent}"/>
                        </Track.IncreaseRepeatButton>

                        <Track.Thumb>
                            <Thumb x:Name="Thumb" FontFamily="Assets/Fonts/#Segoe UI" Focusable="False" OverridesDefaultStyle="True" Template="{StaticResource RPMSliderThumbVerticalDefault}" VerticalAlignment="Center"/>
                        </Track.Thumb>

                    </Track>

                </Grid>

            </Grid>

        </ControlTemplate>

        <!--Slider_RPMReadout-->
        <Style x:Key="Slider_RPMReadout" TargetType="{x:Type Slider}">
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Template" Value="{StaticResource RPMSliderVertical}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!--GEAR TEMPLATE-->
        <!--////////////////////////////////////////-->
        <Style x:Key="RadioButton_Gear" TargetType="{x:Type RadioButton}">

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RadioButton}">

                        <Grid x:Name="templateRoot" SnapsToDevicePixels="True">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CheckedStates">
                                    <VisualStateGroup.Transitions>
                                        <VisualTransition GeneratedDuration="00:00:00.1000000" To="Checked"/>
                                        <VisualTransition From="Checked" GeneratedDuration="00:00:00.2000000"/>
                                    </VisualStateGroup.Transitions>
                                    <VisualState x:Name="Checked">
                                        <Storyboard>
                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="GearContainer" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)">
                                                <EasingDoubleKeyFrame KeyTime="00:00:00" Value="1"/>
                                            </DoubleAnimationUsingKeyFrames>
                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Text_Gear" Storyboard.TargetProperty="(UIElement.Opacity)">
                                                <EasingDoubleKeyFrame KeyTime="00:00:00" Value="1"/>
                                            </DoubleAnimationUsingKeyFrames>
                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Text_Gear" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)">
                                                <EasingDoubleKeyFrame KeyTime="00:00:00" Value="1.3"/>
                                            </DoubleAnimationUsingKeyFrames>
                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Text_Gear" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)">
                                                <EasingDoubleKeyFrame KeyTime="00:00:00" Value="1.3"/>
                                            </DoubleAnimationUsingKeyFrames>
                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Tab" Storyboard.TargetProperty="(UIElement.Opacity)">
                                                <EasingDoubleKeyFrame KeyTime="00:00:00" Value="1"/>
                                            </DoubleAnimationUsingKeyFrames>
                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Tab" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[3].(TranslateTransform.X)">
                                                <EasingDoubleKeyFrame KeyTime="00:00:00" Value="0"/>
                                            </DoubleAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Unchecked"/>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <Grid x:Name="GearContainer" RenderTransformOrigin="0.0,0.5">
                                <Grid.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform ScaleX="0.75"/>
                                        <SkewTransform/>
                                        <RotateTransform/>
                                        <TranslateTransform/>
                                    </TransformGroup>
                                </Grid.RenderTransform>

                                <Grid.Background>
                                    <LinearGradientBrush StartPoint="0.5,0.5" EndPoint="1,0.5" Opacity="0.2">
                                        <GradientStop Color="#33FFFFFF"/>
                                        <GradientStop Color="#0166b1" Offset="1"/>
                                    </LinearGradientBrush>
                                </Grid.Background>
                            </Grid>

                            <TextBlock x:Name="Text_Gear"
                                       Text="{TemplateBinding Content}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontSize="56"
                                       FontFamily="Assets/Fonts/#Segoe UI"
                                       FontWeight="Black" FontStyle="Italic"
                                       Foreground="White"
                                       Opacity="0.25"
                                       Margin="-40,0,0,0"
                                       RenderTransformOrigin="-1,0.5">
                                <TextBlock.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform/>
                                        <SkewTransform/>
                                        <RotateTransform/>
                                        <TranslateTransform/>
                                    </TransformGroup>
                                </TextBlock.RenderTransform>
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="#FF6496C8" BlurRadius="64" Direction="0" ShadowDepth="0"/>
                                </TextBlock.Effect>
                              </TextBlock>
                            <Grid x:Name="Tab"
                                  Background="White"
                                  Opacity="0"
                                  RenderTransformOrigin="1.0,0.5">
                                <Grid.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform ScaleX="0.05"/>
                                        <SkewTransform/>
                                        <RotateTransform/>
                                        <TranslateTransform X="-40"/>
                                    </TransformGroup>
                                </Grid.RenderTransform>
                                  <Grid.Effect>
                                    <DropShadowEffect Color="#FF6496C8" BlurRadius="64" Direction="0" ShadowDepth="0"/>
                                </Grid.Effect>
                              </Grid>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--GEAR NEUTRAL TEMPLATE-->
        <!--////////////////////////////////////////-->
        <Style x:Key="RadioButton_Gear_Neutral" TargetType="{x:Type RadioButton}">

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RadioButton}">
                        <Grid x:Name="templateRoot" SnapsToDevicePixels="True">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CheckedStates">
                                    <VisualStateGroup.Transitions>
                                        <VisualTransition GeneratedDuration="00:00:00.1000000" To="Checked"/>
                                        <VisualTransition From="Checked" GeneratedDuration="00:00:00.2000000"/>
                                    </VisualStateGroup.Transitions>
                                    <VisualState x:Name="Checked">
                                        <Storyboard>
                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="GearContainer" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)">
                                                <EasingDoubleKeyFrame KeyTime="00:00:00" Value="1"/>
                                            </DoubleAnimationUsingKeyFrames>
                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Text_Gear" Storyboard.TargetProperty="(UIElement.Opacity)">
                                                <EasingDoubleKeyFrame KeyTime="00:00:00" Value="1"/>
                                            </DoubleAnimationUsingKeyFrames>
                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Text_Gear" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)">
                                                <EasingDoubleKeyFrame KeyTime="00:00:00" Value="1.3"/>
                                            </DoubleAnimationUsingKeyFrames>
                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Text_Gear" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)">
                                                <EasingDoubleKeyFrame KeyTime="00:00:00" Value="1.3"/>
                                            </DoubleAnimationUsingKeyFrames>
                                            <ColorAnimationUsingKeyFrames Storyboard.TargetName="Text_Gear" Storyboard.TargetProperty="(TextBlock.Foreground).(SolidColorBrush.Color)">
                                                <EasingColorKeyFrame KeyTime="00:00:00" Value="#3cb002"/>
                                            </ColorAnimationUsingKeyFrames>
                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Tab" Storyboard.TargetProperty="(UIElement.Opacity)">
                                                <EasingDoubleKeyFrame KeyTime="00:00:00" Value="1"/>
                                            </DoubleAnimationUsingKeyFrames>
                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Tab" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[3].(TranslateTransform.X)">
                                                <EasingDoubleKeyFrame KeyTime="00:00:00" Value="0"/>
                                            </DoubleAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Unchecked"/>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>

                            <Grid x:Name="GearContainer" RenderTransformOrigin="0.0,0.5">
                                <Grid.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform ScaleX="0.75"/>
                                        <SkewTransform/>
                                        <RotateTransform/>
                                        <TranslateTransform/>
                                    </TransformGroup>
                                </Grid.RenderTransform>

                                <Grid.Background>
                                    <LinearGradientBrush StartPoint="0.5,0.5" EndPoint="1,0.5" Opacity="0.2">
                                        <GradientStop Color="#33FFFFFF"/>
                                        <GradientStop Color="#0166b1" Offset="1"/>
                                    </LinearGradientBrush>
                                </Grid.Background>

                                <Grid>
                                    <Grid.Background>
                                        <LinearGradientBrush StartPoint="0,0.5" EndPoint="0,1" Opacity="0.2">
                                            <GradientStop Color="#333cb002"/>
                                            <GradientStop Color="#3cb002" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Grid.Background>
                                </Grid>
                            </Grid>

                            <TextBlock x:Name="Text_Gear"
                                        Text="{TemplateBinding Content}"
                                        HorizontalAlignment="Center" VerticalAlignment="Center"
                                        FontSize="56"
                                        FontFamily="Assets/Fonts/#Segoe UI"
                                        FontWeight="Black"
                                        Foreground="White"
                                        Opacity="0.25"
                                        Margin="-40,0,0,0"
                                        RenderTransformOrigin="-1,0.5">
                                <TextBlock.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform/>
                                        <SkewTransform/>
                                        <RotateTransform/>
                                        <TranslateTransform/>
                                    </TransformGroup>
                                </TextBlock.RenderTransform>
                            </TextBlock>

                            <Grid x:Name="Tab"
                                    Grid.Column="1"
                                    Background="#3cb002"
                                    Opacity="0"
                                    RenderTransformOrigin="1.0,0.5">
                                  <Grid.RenderTransform>
                                      <TransformGroup>
                                          <ScaleTransform ScaleX="0.05"/>
                                          <SkewTransform/>
                                          <RotateTransform/>
                                          <TranslateTransform X="-40"/>
                                      </TransformGroup>
                                  </Grid.RenderTransform>
                            </Grid>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--FUEL GAUGE TEMPLATE-->
        <!--////////////////////////////////////////-->

        <!--Progress Bar Fuel-->
        <Style x:Key="ProgressBar_Fuel" TargetType="{x:Type ProgressBar}">

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ProgressBar}">

                        <!--Construction-->

                        <Grid x:Name="TemplateRoot">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0">
                                <Viewbox Margin="12">
                                    <Grid>
                                        <Path Fill="#ffffffff"
                                              Data="F1 M 261.325,177.303 C 261.325,186.372 253.973,193.724 244.904,193.724 L 80.693,193.724 C 71.624,193.724 64.272,186.372 64.272,177.303 L 64.272,63.266 C 64.272,54.197 71.624,46.845 80.693,46.845 L 244.904,46.845 C 253.973,46.845 261.325,54.197 261.325,63.266 L 261.325,177.303 Z M 437.559,361.732 L 424.980,94.434 C 424.422,82.647 419.435,71.650 410.936,63.471 L 351.672,6.434 C 343.830,-1.113 331.355,-0.868 323.808,6.966 C 316.261,14.808 316.502,27.284 324.340,34.831 L 355.188,64.518 C 355.184,64.884 355.169,65.247 355.187,65.617 L 357.426,110.371 C 358.010,122.029 363.786,132.616 373.276,139.415 L 388.145,150.069 L 398.196,363.643 C 398.950,378.705 391.769,384.423 385.390,384.740 C 377.211,385.292 371.480,377.540 370.874,365.423 L 363.247,198.785 C 362.695,186.658 357.224,175.022 348.234,166.850 C 339.244,158.685 327.082,154.358 315.023,154.961 L 309.622,155.230 L 309.622,32.842 C 309.622,14.704 294.918,0.000 276.780,0.000 L 48.818,0.000 C 30.680,0.000 15.975,14.704 15.975,32.842 L 15.975,459.936 L 6.569,459.936 C 2.941,459.936 0.000,462.877 0.000,466.505 L 0.000,500.000 L 325.597,500.000 L 325.597,466.505 C 325.597,462.877 322.657,459.936 319.029,459.936 L 309.622,459.936 L 309.622,194.688 L 316.992,194.320 C 318.740,194.288 320.453,194.856 321.733,196.020 C 323.016,197.187 323.798,198.846 323.875,200.581 L 331.508,367.309 C 333.397,405.074 359.325,424.170 384.816,424.167 C 385.663,424.167 386.513,424.145 387.359,424.103 C 413.790,422.781 439.519,400.915 437.559,361.732 Z">
                                            <Path.Effect>
                                                <DropShadowEffect Color="#FF6496C8" BlurRadius="64" Direction="0" ShadowDepth="0"/>
                                            </Path.Effect>
                                        </Path>
                                    </Grid>
                                </Viewbox>
                            </Grid>

                            <!--Fillable Bar-->
                            <Grid Grid.Column="1">

                                <Grid x:Name="PART_Track">
                                    <Border CornerRadius="0,32,32,0" Background="Black" Opacity="0.6"/>
                                    <Border CornerRadius="0,32,32,0" Background="#0166b1" Opacity="0.2"/>
                                </Grid>

                                <Grid x:Name="PART_Indicator" ClipToBounds="true" HorizontalAlignment="Left">

                                    <Grid x:Name="Indicator" Margin="8">

                                        <Border CornerRadius="0,24,24,0">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0.5,0.5" EndPoint="1,0.5" Opacity="0.2">
                                                    <GradientStop Color="#33FFFFFF"/>
                                                    <GradientStop Color="#0166b1" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>

                                        <Border CornerRadius="0,24,24,0">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0.5" EndPoint="0,1" Opacity="0.4">
                                                    <GradientStop Color="#333cb002"/>
                                                    <GradientStop Color="#3cb002" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>

                                    </Grid>

                                    <Border Padding="8,0,8,0">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,0,8">
    
                                            <TextBlock x:Name="Text_Range_Approximation"
                                                       Text="~"
                                                       FontSize="40"
                                                       FontFamily="Assets/Fonts/#Segoe UI"
                                                       FontWeight="Black" FontStyle="Italic"
                                                       VerticalAlignment="Center"
                                                       Foreground="White">
    
                                                <TextBlock.Effect>
                                                    <DropShadowEffect Color="#FF6496C8" BlurRadius="64" Direction="0" ShadowDepth="0"/>
                                                </TextBlock.Effect>
    
                                            </TextBlock>
    
                                            <TextBlock x:Name="Text_Range_Value"
                                                       Text="{Binding Value,RelativeSource={RelativeSource AncestorType=ProgressBar},StringFormat=F0}"
                                                       FontSize="40"
                                                       FontFamily="Assets/Fonts/#Segoe UI"
                                                       FontWeight="Bold" FontStyle="Italic"
                                                       VerticalAlignment="Center"
                                                       Foreground="White"
                                                       Margin="0,0,16,0">
    
                                                <TextBlock.Effect>
                                                    <DropShadowEffect Color="#FF6496C8" BlurRadius="64" Direction="0" ShadowDepth="0"/>
                                                </TextBlock.Effect>
    
                                            </TextBlock>
    
                                            <TextBlock x:Name="Text_Range_Unit"
                                                       Text="km"
                                                       FontSize="40"
                                                       FontFamily="Assets/Fonts/#Segoe UI"
                                                       FontWeight="Bold" FontStyle="Italic"
                                                       VerticalAlignment="Center"
                                                       Foreground="White"
                                                       Margin="0,0,16,0">
    
                                                <TextBlock.Effect>
                                                    <DropShadowEffect Color="#FF6496C8" BlurRadius="64" Direction="0" ShadowDepth="0"/>
                                                </TextBlock.Effect>
    
                                            </TextBlock>
    
                                        </StackPanel>
                                    </Border>
                                </Grid>

                            </Grid>
                        </Grid>

                        <ControlTemplate.Triggers>
                        </ControlTemplate.Triggers>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <!--////////////////////////////////////////-->
        <!--STORYBOARDS-->
        <!--////////////////////////////////////////-->
        
        <Storyboard x:Key="MapMotion" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Map" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)">
                <EasingDoubleKeyFrame KeyTime="00:00:00" Value="1"/>
                <EasingDoubleKeyFrame KeyTime="00:00:20" Value="1.5"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Map" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)">
                <EasingDoubleKeyFrame KeyTime="00:00:00" Value="1"/>
                <EasingDoubleKeyFrame KeyTime="00:00:20" Value="1.5"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Map" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[3].(TranslateTransform.X)">
                <EasingDoubleKeyFrame KeyTime="00:00:00" Value="0"/>
                <EasingDoubleKeyFrame KeyTime="00:00:20" Value="-250"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Map" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[2].(RotateTransform.Angle)">
                <EasingDoubleKeyFrame KeyTime="00:00:00" Value="0"/>
                <EasingDoubleKeyFrame KeyTime="00:00:20" Value="-10"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Map" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[3].(TranslateTransform.Y)">
                <EasingDoubleKeyFrame KeyTime="00:00:00" Value="0"/>
                <EasingDoubleKeyFrame KeyTime="00:00:20" Value="140"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>



        <Storyboard x:Key="MapRoute" RepeatBehavior="Forever">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="TurnArrow" Storyboard.TargetProperty="(UIElement.Opacity)">
                <EasingDoubleKeyFrame KeyTime="00:00:00" Value="1"/>
                <EasingDoubleKeyFrame KeyTime="00:00:03" Value="1"/>
                <EasingDoubleKeyFrame KeyTime="00:00:04.3000001" Value="0">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <CubicEase EasingMode="EaseIn"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="00:00:05" Value="1">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <CubicEase EasingMode="EaseOut"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
    </UserControl.Resources>

    <!--////////////////////////////////////////-->
    <!--CONSTRUCTION-->
    <!--////////////////////////////////////////-->

    <!--MASTER-->
    <Grid x:Name="Screen_Master">

        <!--BACKGROUND-->
        <Grid x:Name="Background" Background="#FF071924" ClipToBounds="True">
            <Grid x:Name="Map" RenderTransformOrigin="0.5,0.5">
                <Grid.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleX="1.079"/>
                        <SkewTransform/>
                        <RotateTransform/>
                        <TranslateTransform X="-236.529"/>
                    </TransformGroup>
                </Grid.RenderTransform>
                <Grid.Background>
                    <ImageBrush ImageSource="Assets/Bitmaps/Dash_Background.png" Stretch="UniformToFill"/>
                </Grid.Background>
            </Grid>
        </Grid>

        <!--INTERFACE-->
        <Grid x:Name="InterfaceGrid">

            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <!--GEARSTACK-->
            <Grid x:Name="GearColumnGrid" Grid.Column="0" Grid.ColumnSpan="2"
                  Grid.Row="0" Grid.RowSpan="14">

                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <!--6-->
                <RadioButton Style="{DynamicResource RadioButton_Gear}" Content="6" Grid.Row="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IsChecked="{Binding Gear6}"/>
                <!--5-->
                <RadioButton Style="{DynamicResource RadioButton_Gear}" Content="5" Grid.Row="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IsChecked="{Binding Gear5}"/>
                <!--4-->
                <RadioButton Style="{DynamicResource RadioButton_Gear}" Content="4" Grid.Row="2" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IsChecked="{Binding Gear4}"/>
                <!--3-->
                <RadioButton Style="{DynamicResource RadioButton_Gear}" Content="3" Grid.Row="3" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IsChecked="{Binding Gear3}"/>
                <!--2-->
                <RadioButton Style="{DynamicResource RadioButton_Gear}" Content="2" Grid.Row="4" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IsChecked="{Binding Gear2}"/>
                <!--Neutral-->
                <RadioButton Style="{DynamicResource RadioButton_Gear_Neutral}" Content="N" Grid.Row="5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IsChecked="{Binding GearN}"/>
                <!--1-->
                <RadioButton Style="{DynamicResource RadioButton_Gear}" Content="1" Grid.Row="6" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IsChecked="{Binding Gear1}"/>

            </Grid>

            <!--HEADER-->
            <Grid x:Name="HeaderGrid" Grid.Column="7" Grid.ColumnSpan="10"
                  Grid.Row="0" Grid.RowSpan="1"
                  VerticalAlignment="Top"
                  Margin="0,4,0,0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="5*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="5*"/>
                </Grid.ColumnDefinitions>

                <!--Logo-->
                <Grid x:Name="LogoGrid" Grid.Column="1">
                    <Viewbox x:Name="LogoViewbox" Margin="8">
                        <Grid x:Name="LogoArea">
                            <Path Fill="#ffffffff" Data="M460.13,0L590.53,34.94 660.49,295.44 437.84,517.83 307.44,482.89 284.12,396.05 414.52,430.99 573.55,272.15 526.91,98.48 396.51,63.54 460.13,0z M495.11,130.25L530.09,260.5 466.48,324.04 431.49,193.79 214.16,135.56 86.94,262.63 121.92,392.88 34.98,369.59 0,239.34 190.84,48.72 495.11,130.25z M312.75,202.27L225.82,178.97 130.4,274.28 212.02,578.19 472.82,648.08 568.24,552.77 544.92,465.94 449.5,561.24 275.64,514.66 217.34,297.58 312.75,202.27z">
                                <Path.Effect>
                                    <DropShadowEffect Color="#FF6496C8" BlurRadius="64" Direction="0" ShadowDepth="0"/>
                                </Path.Effect>
                            </Path>
                        </Grid>
                    </Viewbox>
                </Grid>

                <!--Clock-->
                <TextBlock Text="{Binding Path=Time}"
                           FontSize="64"
                           Grid.Column="0"
                           HorizontalAlignment="Right" VerticalAlignment="Center"
                           FontFamily="Assets/Fonts/#Segoe UI"
                           Foreground="White"
                           Margin="0,0,24,8"/>

                <!--Temp-->
                <StackPanel x:Name="TemperatureHorizontalStack" Grid.Column="2"
                            HorizontalAlignment="Left" VerticalAlignment="Center"
                            Orientation="Horizontal"
                            Margin="24,0,0,8">

                    <TextBlock Text="{Binding Path=Temperature, StringFormat=F0}"
                               FontSize="64"                               
                               FontFamily="Assets/Fonts/#Segoe UI"
                               Foreground="White"
                               HorizontalAlignment="Right" VerticalAlignment="Center">

                        <TextBlock.Effect>
                            <DropShadowEffect Color="#FF6496C8" BlurRadius="64" Direction="0" ShadowDepth="0"/>
                        </TextBlock.Effect>

                    </TextBlock>

                    <TextBlock Text="°C"
                               FontSize="64"                               
                               FontFamily="Assets/Fonts/#Segoe UI"
                               Foreground="White"
                               HorizontalAlignment="Right" VerticalAlignment="Center">

                        <TextBlock.Effect>
                            <DropShadowEffect Color="#FF6496C8" BlurRadius="64" Direction="0" ShadowDepth="0"/>
                        </TextBlock.Effect>

                    </TextBlock>

                </StackPanel>

            </Grid>

            <!--SPEDOMETER-->
            <Grid x:Name="SpeedometerGrid" Grid.Column="5" Grid.ColumnSpan="14"
                  Grid.Row="1" Grid.RowSpan="6">

                <StackPanel x:Name="SpeedometerVerticalStack" VerticalAlignment="Center" >

                    <TextBlock Text="{Binding Path=Speed, StringFormat=F0}"
                               HorizontalAlignment="Center"
                               FontSize="400"
                               FontFamily="Assets/Fonts/#Segoe UI"
                               FontWeight="Black" FontStyle="Italic"
                               Foreground="White"
                               Margin="0,-80,0,0">

                        <TextBlock.Effect>
                            <DropShadowEffect Color="#FF6496C8" BlurRadius="64" Direction="0" ShadowDepth="0"/>
                        </TextBlock.Effect>

                    </TextBlock>

                    <TextBlock Text="km/h"
                               HorizontalAlignment="Center"
                               FontSize="56"
                               FontFamily="Assets/Fonts/#Segoe UI"
                               FontWeight="Black" FontStyle="Italic"
                               Foreground="White"
                               Margin="0,-64,0,0">

                        <TextBlock.Effect>
                            <DropShadowEffect Color="#FF6496C8" BlurRadius="64" Direction="0" ShadowDepth="0"/>
                        </TextBlock.Effect>

                    </TextBlock>

                </StackPanel>

            </Grid>

            <!--GPS-->
            <Grid x:Name="GPSGrid" Grid.Column="3" Grid.ColumnSpan="18"
                  Grid.Row="7" Grid.RowSpan="4">

                <StackPanel x:Name="GPSVerticalStack" Orientation="Vertical" VerticalAlignment="Center">

                    <!--Direction Indicator-->
                    <Grid x:Name="TurnIndicator" Width="80" Height="80">
                        <Viewbox>
                            <Grid>
                                <Path x:Name="TurnArrow" Fill="#ffffffff"
                                      Data="F1 M 272.552,0.000 M 272.552,0.000 L 272.552,69.330 L 224.189,69.330 C 100.373,69.330 0.000,169.703 0.000,293.519 L 0.000,475.224 L 130.272,475.224 L 130.272,293.519 C 130.272,241.649 172.320,199.601 224.189,199.601 L 272.552,199.601 L 272.552,268.929 L 500.000,134.465 L 272.552,0.000 Z">
                                    <Path.Effect>
                                        <DropShadowEffect Color="#FF6496C8" BlurRadius="64" Direction="0" ShadowDepth="0"/>
                                    </Path.Effect>
                                </Path>
                            </Grid>
                        </Viewbox>

                    </Grid>

                    <!--Waypoint Distance-->
                    <Grid x:Name="DistanceIndicator">

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                            <TextBlock Text="1.52"
                                   HorizontalAlignment="Center"
                                   FontSize="80"
                                   FontFamily="Assets/Fonts/#Segoe UI"
                                   FontWeight="Black" FontStyle="Italic"
                                   Foreground="White">

                                <TextBlock.Effect>
                                    <DropShadowEffect Color="#FF6496C8" BlurRadius="64" Direction="0" ShadowDepth="0"/>
                                </TextBlock.Effect>

                            </TextBlock>

                            <TextBlock Text="km"
                                   HorizontalAlignment="Center"
                                   FontSize="80"
                                   FontFamily="Assets/Fonts/#Segoe UI"
                                   FontWeight="Black" FontStyle="Italic"
                                   Foreground="White" Margin="16,0,0,0">

                                <TextBlock.Effect>
                                    <DropShadowEffect Color="#FF6496C8" BlurRadius="64" Direction="0" ShadowDepth="0"/>
                                </TextBlock.Effect>

                            </TextBlock>

                        </StackPanel>

                    </Grid>

                    <!--Waypoint Name-->
                    <Grid x:Name="StreetIndicator">

                        <TextBlock Text="Passo dello Stelvio"
                                   HorizontalAlignment="Center"
                                   FontSize="56"
                                   FontFamily="Assets/Fonts/#Segoe UI"
                                   FontWeight="Bold" FontStyle="Italic"
                                   Foreground="White">

                            <TextBlock.Effect>
                                <DropShadowEffect Color="#FF6496C8" BlurRadius="64" Direction="0" ShadowDepth="0"/>
                            </TextBlock.Effect>

                        </TextBlock>
                    </Grid>

                </StackPanel>

            </Grid>

            <!--FUELGAUGE-->
            <Grid x:Name="FuelGrid" Grid.Column="7" Grid.ColumnSpan="10"
                  Grid.Row="12" Grid.RowSpan="1"
                  Margin="0,0,0,24">

                <ProgressBar x:Name="ProgressBar_FuelGauge" Style="{DynamicResource ProgressBar_Fuel}"
                             Minimum="0"
                             Maximum="{Binding Path=Fuel_Max}"
                             Value="{Binding Path=Fuel}"
                             SmallChange="1"/>

            </Grid>

            <!--TACHOMETER-->

            <!--RPM Gauge-->
            <ProgressBar x:Name="ProgressBar_Tachometer"
                         Style="{DynamicResource ProgressBar_Tachometer}"
                         Orientation="Vertical"
                         Minimum="0"
                         Maximum="{Binding Path=RPM_Max}"
                         Value="{Binding Path=RPM}"
                         Grid.Column="22" Grid.ColumnSpan="2"
                         Grid.Row="0" Grid.RowSpan="12">

                <ProgressBar.OpacityMask>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1" >

                        <LinearGradientBrush.RelativeTransform>
                            <TransformGroup>
                                <ScaleTransform CenterY="0.5" CenterX="0.5"/>
                                <SkewTransform CenterX="0.7" CenterY="0.5"/>
                                <RotateTransform Angle="66" CenterX="0.75" CenterY="0.5"/>
                                <TranslateTransform/>
                            </TransformGroup>
                        </LinearGradientBrush.RelativeTransform>

                        <GradientStop Color="White" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>

                    </LinearGradientBrush>
                </ProgressBar.OpacityMask>

            </ProgressBar>

            <!--RPM Readout-->
            <Slider x:Name="Slider_Tachometer" Style="{DynamicResource Slider_RPMReadout}" 
                    Orientation="Vertical"
                    Minimum="{Binding ElementName=ProgressBar_Tachometer, Path=Minimum}"
                    Maximum="{Binding ElementName=ProgressBar_Tachometer, Path=Maximum}"
                    Value="{Binding ElementName=ProgressBar_Tachometer, Path=Value}"
                    Grid.Column="18" Grid.ColumnSpan="4"
                    Grid.Row="0" Grid.RowSpan="12"/>


        </Grid>


    </Grid>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard x:Name="MapMotion_Begin" Storyboard="{StaticResource MapMotion}"/>
            <BeginStoryboard x:Name="MapRoute_Begin" Storyboard="{StaticResource MapRoute}"/>
        </EventTrigger>
    </UserControl.Triggers>

</UserControl>
