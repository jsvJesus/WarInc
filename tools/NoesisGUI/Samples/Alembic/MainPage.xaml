<Page
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  mc:Ignorable="d"
  d:DesignWidth="1920"
  d:DesignHeight="1080" xmlns:system="clr-namespace:System;assembly=mscorlib" xmlns:noesis="clr-namespace:NoesisGUIExtensions" xmlns:b="http://schemas.microsoft.com/xaml/behaviors" xmlns:editor="clr-namespace:Editor" d:DataContext="AlembicDataSet">
  <Page.Resources>
    <Style x:Key="Style.ScrollBar.PageButton" TargetType="RepeatButton">
      <Setter Value="False" Property="IsTabStop"/>
      <Setter Value="False" Property="Focusable"/>
      <Setter Value="Press" Property="ClickMode"/>
      <Setter Value="250" Property="Delay"/>
      <Setter Value="100" Property="Interval"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="RepeatButton">
            <Border Background="#00FFFFFF"/>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style x:Key="Style.ScrollBar.Thumb" TargetType="Thumb">
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Thumb">
            <Border x:Name="Thumb" CornerRadius="20,20,20,20">
              <Border.Background>
                <SolidColorBrush Color="{DynamicResource FlaxYellow}"/>
              </Border.Background>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Value="True" Property="IsMouseOver">
                <Setter TargetName="Thumb" Property="Background">
                  <Setter.Value>
                    <SolidColorBrush Color="{DynamicResource CrayolaBrown}"/>
                  </Setter.Value>
                </Setter>
              </Trigger>
              <Trigger Value="True" Property="IsDragging">
                <Setter TargetName="Thumb" Property="Background">
                  <Setter.Value>
                    <SolidColorBrush Color="{DynamicResource CrayolaBrown}"/>
                  </Setter.Value>
                </Setter>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <ControlTemplate x:Key="Template.ScrollBar.Vertical" TargetType="ScrollBar">
      <Track x:Name="PART_Track">
        <Track.IncreaseRepeatButton>
          <RepeatButton Command="ScrollBar.PageRightCommand" Style="{StaticResource Style.ScrollBar.PageButton}"/>
        </Track.IncreaseRepeatButton>
        <Track.DecreaseRepeatButton>
          <RepeatButton Command="ScrollBar.PageLeftCommand" Style="{StaticResource Style.ScrollBar.PageButton}"/>
        </Track.DecreaseRepeatButton>
        <Track.Thumb>
          <Thumb x:Name="Thumb" Height="6" Width="NaN" Style="{StaticResource Style.ScrollBar.Thumb}"/>
        </Track.Thumb>
      </Track>
      <ControlTemplate.Triggers>
        <Trigger Value="Vertical" Property="Orientation">
          <Setter TargetName="PART_Track" Value="True" Property="IsDirectionReversed"/>
          <Setter TargetName="Thumb" Value="6" Property="Width"/>
          <Setter TargetName="Thumb" Value="NaN" Property="Height"/>
        </Trigger>
      </ControlTemplate.Triggers>
    </ControlTemplate>
    <ControlTemplate x:Key="Template.ScrollViewer" TargetType="ScrollViewer">
      <Border BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <ScrollContentPresenter ScrollViewer.CanContentScroll="{TemplateBinding CanContentScroll}" Margin="0" CanHorizontallyScroll="False" CanVerticallyScroll="False" HorizontalAlignment="Center" Width="736" VerticalAlignment="Center" Height="423"/>
          <ScrollBar x:Name="PART_VerticalScrollBar" Orientation="Vertical" ViewportSize="{TemplateBinding ViewportHeight}" Maximum="{TemplateBinding ScrollableHeight}" Value="{Binding Path=VerticalOffset, RelativeSource={RelativeSource TemplatedParent}, Mode=OneWay}" Margin="0" Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}" Grid.Column="1" Grid.Row="0" HorizontalAlignment="Center" Width="17" VerticalAlignment="Center" Height="419" Template="{DynamicResource Template.ScrollBar.Vertical}"/>
        </Grid>
      </Border>
    </ControlTemplate>
    <ControlTemplate x:Key="Template.ListBox" TargetType="ListBox">
      <ScrollViewer BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" BorderBrush="{TemplateBinding BorderBrush}" Focusable="False" Template="{DynamicResource Template.ScrollViewer}">
        <ItemsPresenter/>
      </ScrollViewer>
    </ControlTemplate>
    <ItemsPanelTemplate x:Key="Template.ListBox.ItemsPanel">
      <VirtualizingStackPanel Margin="0,5,0,0" Height="414">
        <VirtualizingStackPanel.Background>
          <ImageBrush ImageSource="Assets/GridBackground.png" TileMode="Tile" Viewport="0,0,1,0.143" Opacity="0.363"/>
        </VirtualizingStackPanel.Background>
      </VirtualizingStackPanel>
    </ItemsPanelTemplate>
    <ControlTemplate x:Key="Template.ListBoxItem.Reset" TargetType="ListBoxItem">
      <ContentPresenter/>
    </ControlTemplate>
    <Style x:Key="Style.ListBoxItem.Filtered" TargetType="{x:Type ListBoxItem}" BasedOn="{StaticResource {x:Type ListBoxItem}}">
      <Setter Property="noesis:StyleInteraction.Triggers">
        <Setter.Value>
          <noesis:StyleTriggerCollection>
            <b:DataTrigger Value="{Binding Path=Tag, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}" Binding="{Binding Path=Type}" Comparison="NotEqual">
              <b:ChangePropertyAction PropertyName="Visibility" Value="Collapsed"/>
            </b:DataTrigger>
          </noesis:StyleTriggerCollection>
        </Setter.Value>
      </Setter>
      <Setter Property="Template" Value="{DynamicResource Template.ListBoxItem.Reset}"/>
      <Setter Property="Height" Value="60"/>
    </Style>
    <Style x:Key="Style.ListBoxItem.All" TargetType="{x:Type ListBoxItem}" BasedOn="{StaticResource {x:Type ListBoxItem}}">
      <Setter Property="Template" Value="{DynamicResource Template.ListBoxItem.Reset}"/>
      <Setter Property="Height" Value="60"/>
    </Style>
    <ControlTemplate x:Key="Template.TabControl" TargetType="TabControl">
      <DockPanel>
        <TabPanel Background="#00FFFFFF" IsItemsHost="True" Panel.ZIndex="1" DockPanel.Dock="Top" KeyboardNavigation.TabIndex="1" Height="92" HorizontalAlignment="Center"/>
        <Border>
          <ContentPresenter x:Name="PART_SelectedContentHost" ContentSource="SelectedContent" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
        </Border>
      </DockPanel>
    </ControlTemplate>
    <ControlTemplate x:Key="Template.TabItem" TargetType="TabItem">
      <Grid x:Name="Grid0" Width="185" Height="40">
        <b:Interaction.Triggers>
          <b:EventTrigger EventName="MouseDown">
            <b:PlaySoundAction Source="Assets/MetalClick.mp3"/>
          </b:EventTrigger>
        </b:Interaction.Triggers>
        <Border x:Name="BorderUnselected" BorderThickness="1,0,0.5,0" VerticalAlignment="Center" Height="40" Margin="0,0,-0.5,0">
          <Border.BorderBrush>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
              <GradientStop Offset="0" Color="#00B2B0AF"/>
              <GradientStop Offset="1" Color="#00B2B0AF"/>
              <GradientStop Color="{DynamicResource Color.005}" Offset="0.16412546"/>
              <GradientStop Color="{DynamicResource Color.005}" Offset="0.82421494"/>
            </LinearGradientBrush>
          </Border.BorderBrush>
        </Border>
        <Grid x:Name="GridSelect" Visibility="Hidden">
          <Border Width="19" HorizontalAlignment="Left" Opacity="0.494">
            <Border.Background>
              <RadialGradientBrush GradientOrigin="0,0.5" Center="0,0.5" RadiusX="1">
                <RadialGradientBrush.RelativeTransform>
                  <TransformGroup>
                    <ScaleTransform CenterY="0.5" CenterX="0"/>
                    <SkewTransform CenterY="0.5" CenterX="0"/>
                    <RotateTransform CenterY="0.5"/>
                    <TranslateTransform/>
                  </TransformGroup>
                </RadialGradientBrush.RelativeTransform>
                <GradientStop Offset="0" Color="#FFFFFFFF"/>
                <GradientStop Offset="1" Color="#002B2B2B"/>
              </RadialGradientBrush>
            </Border.Background>
          </Border>
          <Border Width="19" HorizontalAlignment="Right" Opacity="0.494">
            <Border.Background>
              <RadialGradientBrush RadiusX="1" GradientOrigin="1,0.5" Center="1,0.5">
                <RadialGradientBrush.RelativeTransform>
                  <TransformGroup>
                    <ScaleTransform CenterY="0.5" CenterX="0"/>
                    <SkewTransform CenterY="0.5" CenterX="0"/>
                    <RotateTransform CenterY="0.5" CenterX="1"/>
                    <TranslateTransform/>
                  </TransformGroup>
                </RadialGradientBrush.RelativeTransform>
                <GradientStop Offset="0" Color="#FFFFFFFF"/>
                <GradientStop Color="#002B2B2B" Offset="1"/>
              </RadialGradientBrush>
            </Border.Background>
          </Border>
          <Border x:Name="BorderSelected" BorderThickness="1,1,1,1">
            <Border.Background>
              <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Offset="0.39636287" Color="#9B2B2B2B"/>
                <GradientStop Offset="0.5852212" Color="#9B2B2B2B"/>
                <GradientStop Color="#00343434" Offset="1"/>
                <GradientStop Color="#00343434" Offset="0.013452368"/>
              </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
              <BlurEffect Radius="1"/>
            </Border.Effect>
          </Border>
        </Grid>
        <ContentPresenter x:Name="ContentPresenter0" ContentSource="Header" Opacity="0.756" VerticalAlignment="Center"/>
      </Grid>
      <ControlTemplate.Triggers>
        <Trigger Value="True" Property="IsSelected">
          <Setter Value="2" Property="Panel.ZIndex"/>
          <Setter TargetName="GridSelect" Property="Visibility" Value="Visible"/>
          <Setter TargetName="ContentPresenter0" Property="Opacity" Value="1"/>
          <Setter TargetName="BorderUnselected" Property="Opacity" Value="0.578"/>
        </Trigger>
      </ControlTemplate.Triggers>
    </ControlTemplate>
    <DataTemplate x:Key="DataTemplate.TabItem.Header">
      <Grid>
        <TextBlock x:Name="TextBlock0" Text="{Binding}" FontFamily="Assets/Fonts/#Aquifer" FontSize="24" TextAlignment="Center">
          <TextBlock.Foreground>
            <SolidColorBrush Color="#FFFFFFFF"/>
          </TextBlock.Foreground>
        </TextBlock>
      </Grid>
    </DataTemplate>
    <DataTemplate x:Key="DataTemplate.CraftItem">
      <Grid x:Name="RootGrid" Height="60">
        <b:Interaction.Triggers>
          <b:DataTrigger Value="True" Binding="{Binding Path=Enabled}">
            <b:GoToStateAction StateName="Enabled"/>
          </b:DataTrigger>
          <b:DataTrigger Value="False" Binding="{Binding Path=Enabled}">
            <b:GoToStateAction StateName="Disabled"/>
          </b:DataTrigger>
          <b:EventTrigger EventName="MouseEnter">
            <b:GoToStateAction StateName="MouseOver"/>
            <b:ChangePropertyAction Value="True" PropertyName="IsSelected" TargetObject="{Binding RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}}"/>
          </b:EventTrigger>
          <b:EventTrigger EventName="MouseLeave">
            <b:GoToStateAction StateName="Normal"/>
          </b:EventTrigger>
          <b:EventTrigger>
            <b:GoToStateAction StateName="Nocraft"/>
          </b:EventTrigger>
          <b:EventTrigger EventName="MouseDown">
            <b:Interaction.Behaviors>
              <b:ConditionBehavior>
                <b:ConditionalExpression ForwardChaining="And">
                  <b:ComparisonCondition RightOperand="True" LeftOperand="{Binding Path=Enabled}"/>
                 </b:ConditionalExpression>
              </b:ConditionBehavior>
            </b:Interaction.Behaviors>
            <b:GoToStateAction StateName="Craft"/>
            <b:PlaySoundAction Source="Assets/MetalClick.mp3"/>
          </b:EventTrigger>
          <b:TimerTrigger EventName="MouseDown" TotalTicks="1">
            <b:Interaction.Behaviors>
              <b:ConditionBehavior>
                <b:ConditionalExpression ForwardChaining="And">
                  <b:ComparisonCondition RightOperand="True" LeftOperand="{Binding Path=Enabled}"/>
               </b:ConditionalExpression>
              </b:ConditionBehavior>
            </b:Interaction.Behaviors>
            <b:GoToStateAction StateName="Nocraft"/>
            <b:ControlStoryboardAction Storyboard="{DynamicResource Anim.Toast}"/>
          </b:TimerTrigger>
        </b:Interaction.Triggers>
        <Grid.RenderTransform>
          <TransformGroup>
            <ScaleTransform/>
            <SkewTransform/>
            <RotateTransform/>
            <TranslateTransform/>
          </TransformGroup>
        </Grid.RenderTransform>
        <VisualStateManager.VisualStateGroups>
          <VisualStateGroup x:Name="CommonStates">
            <VisualStateGroup.Transitions>
              <VisualTransition GeneratedDuration="00:00:00.2000000"/>
            </VisualStateGroup.Transitions>
            <VisualState x:Name="Normal">
              <Storyboard/>
            </VisualState>
            <VisualState x:Name="MouseOver">
              <Storyboard>
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="SelectBorder" Storyboard.TargetProperty="(UIElement.Opacity)">
                  <EasingDoubleKeyFrame KeyTime="00:00:00" Value="1"/>
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ItemName" Storyboard.TargetProperty="(UIElement.Opacity)">
                  <EasingDoubleKeyFrame KeyTime="00:00:00" Value="1"/>
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ItemQty" Storyboard.TargetProperty="(UIElement.Opacity)">
                  <EasingDoubleKeyFrame KeyTime="00:00:00" Value="1"/>
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ItemNameExt" Storyboard.TargetProperty="(UIElement.Opacity)">
                  <EasingDoubleKeyFrame KeyTime="00:00:00" Value="1"/>
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="TransformGrid" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[3].(TranslateTransform.X)">
                  <EasingDoubleKeyFrame KeyTime="00:00:00"/>
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="TransformGrid" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[3].(TranslateTransform.Y)">
                  <EasingDoubleKeyFrame KeyTime="00:00:00" Value="-7"/>
                </DoubleAnimationUsingKeyFrames>
              </Storyboard>
            </VisualState>
          </VisualStateGroup>
          <VisualStateGroup x:Name="EnabledStates">
            <VisualState x:Name="Enabled">
              <Storyboard>
                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="DisabledBorder" Storyboard.TargetProperty="(UIElement.Visibility)">
                  <DiscreteObjectKeyFrame KeyTime="00:00:00" Value="{x:Static Visibility.Hidden}"/>
                </ObjectAnimationUsingKeyFrames>
                <ColorAnimationUsingKeyFrames Storyboard.TargetName="ItemName" Storyboard.TargetProperty="(TextElement.Foreground).(SolidColorBrush.Color)">
                  <EasingColorKeyFrame KeyTime="00:00:00" Value="{DynamicResource Color.005}"/>
                </ColorAnimationUsingKeyFrames>
                <ColorAnimationUsingKeyFrames Storyboard.TargetName="ItemNameExt" Storyboard.TargetProperty="(TextElement.Foreground).(SolidColorBrush.Color)">
                  <EasingColorKeyFrame KeyTime="00:00:00" Value="{DynamicResource Color.005}"/>
                </ColorAnimationUsingKeyFrames>
                <ColorAnimationUsingKeyFrames Storyboard.TargetName="ItemQty" Storyboard.TargetProperty="(TextElement.Foreground).(SolidColorBrush.Color)">
                  <EasingColorKeyFrame KeyTime="00:00:00" Value="{DynamicResource Color.006}"/>
                </ColorAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ItemName" Storyboard.TargetProperty="(UIElement.Opacity)">
                  <EasingDoubleKeyFrame KeyTime="00:00:00" Value="1"/>
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ItemNameExt" Storyboard.TargetProperty="(UIElement.Opacity)">
                  <EasingDoubleKeyFrame KeyTime="00:00:00" Value="1"/>
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ItemQty" Storyboard.TargetProperty="(UIElement.Opacity)">
                  <EasingDoubleKeyFrame KeyTime="00:00:00" Value="0.8"/>
                </DoubleAnimationUsingKeyFrames>
                <ColorAnimationUsingKeyFrames Storyboard.TargetName="MQty1" Storyboard.TargetProperty="(TextElement.Foreground).(SolidColorBrush.Color)">
                  <EasingColorKeyFrame KeyTime="00:00:00" Value="{DynamicResource Color.006}"/>
                </ColorAnimationUsingKeyFrames>
                <ColorAnimationUsingKeyFrames Storyboard.TargetName="MQty2" Storyboard.TargetProperty="(TextElement.Foreground).(SolidColorBrush.Color)">
                  <EasingColorKeyFrame KeyTime="00:00:00" Value="{DynamicResource Color.006}"/>
                </ColorAnimationUsingKeyFrames>
                <ColorAnimationUsingKeyFrames Storyboard.TargetName="MQty3" Storyboard.TargetProperty="(TextElement.Foreground).(SolidColorBrush.Color)">
                  <EasingColorKeyFrame KeyTime="00:00:00" Value="{DynamicResource Color.006}"/>
                </ColorAnimationUsingKeyFrames>
              </Storyboard>
            </VisualState>
            <VisualState x:Name="Disabled">
              <Storyboard>
                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="DisabledBorder" Storyboard.TargetProperty="(UIElement.Visibility)">
                  <DiscreteObjectKeyFrame KeyTime="00:00:00" Value="{x:Static Visibility.Visible}"/>
                </ObjectAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Icon" Storyboard.TargetProperty="(UIElement.Opacity)">
                  <LinearDoubleKeyFrame KeyTime="00:00:00" Value="0.607"/>
                </DoubleAnimationUsingKeyFrames>
              </Storyboard>
            </VisualState>
          </VisualStateGroup>
          <VisualStateGroup x:Name="CraftStates">
            <VisualStateGroup.Transitions>
              <VisualTransition GeneratedDuration="00:00:00"/>
            </VisualStateGroup.Transitions>
            <VisualState x:Name="Nocraft">
              <Storyboard>
                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="FinalRectangle" Storyboard.TargetProperty="(UIElement.Visibility)">
                  <DiscreteObjectKeyFrame KeyTime="00:00:00" Value="{x:Static Visibility.Hidden}"/>
                </ObjectAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="FinalRectangle" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)">
                  <EasingDoubleKeyFrame KeyTime="00:00:00" Value="0"/>
                </DoubleAnimationUsingKeyFrames>
                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ProgressRectangle" Storyboard.TargetProperty="(UIElement.Visibility)">
                  <DiscreteObjectKeyFrame KeyTime="00:00:00" Value="{x:Static Visibility.Hidden}"/>
                </ObjectAnimationUsingKeyFrames>
              </Storyboard>
            </VisualState>
            <VisualState x:Name="Craft">
              <Storyboard>
                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="FinalRectangle" Storyboard.TargetProperty="(UIElement.Visibility)">
                  <DiscreteObjectKeyFrame KeyTime="00:00:00" Value="{x:Static Visibility.Visible}"/>
                </ObjectAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="FinalRectangle" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)">
                  <EasingDoubleKeyFrame KeyTime="00:00:00" Value="0"/>
                  <SplineDoubleKeyFrame Value="1" KeyTime="00:00:00.8000000" KeySpline="0.7,0,0.6,1"/>
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="SelectBorder" Storyboard.TargetProperty="(UIElement.Opacity)">
                  <EasingDoubleKeyFrame KeyTime="00:00:00" Value="1"/>
                </DoubleAnimationUsingKeyFrames>
                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ProgressRectangle" Storyboard.TargetProperty="(UIElement.Visibility)">
                  <DiscreteObjectKeyFrame KeyTime="00:00:00" Value="{x:Static Visibility.Visible}"/>
                </ObjectAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ProgressRectangle" Storyboard.TargetProperty="(UIElement.Opacity)">
                  <EasingDoubleKeyFrame KeyTime="00:00:00" Value="0"/>
                  <EasingDoubleKeyFrame KeyTime="00:00:00.7500000" Value="0"/>
                  <EasingDoubleKeyFrame KeyTime="00:00:00.8000000" Value="0.313"/>
                  <EasingDoubleKeyFrame KeyTime="00:00:00.8500000" Value="0.275"/>
                  <EasingDoubleKeyFrame KeyTime="00:00:00.9500000" Value="0"/>
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ProgressRectangle" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)">
                  <EasingDoubleKeyFrame KeyTime="00:00:00" Value="1"/>
                  <EasingDoubleKeyFrame KeyTime="00:00:00.7500000" Value="0.9"/>
                  <EasingDoubleKeyFrame KeyTime="00:00:00.9500000" Value="1.1">
                    <EasingDoubleKeyFrame.EasingFunction>
                      <QuarticEase EasingMode="EaseOut"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                  </EasingDoubleKeyFrame>
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ProgressRectangle" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)">
                  <EasingDoubleKeyFrame KeyTime="00:00:00" Value="1"/>
                  <EasingDoubleKeyFrame KeyTime="00:00:00.7500000" Value="0.9"/>
                  <EasingDoubleKeyFrame KeyTime="00:00:00.9500000" Value="1.1">
                    <EasingDoubleKeyFrame.EasingFunction>
                      <QuarticEase EasingMode="EaseOut"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                  </EasingDoubleKeyFrame>
                </DoubleAnimationUsingKeyFrames>
              </Storyboard>
            </VisualState>
          </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
        <Border x:Name="DisabledBorder" IsEnabled="{Binding Path=Enabled}" Margin="10,0,0,0" Background="#542C2C2C" Opacity="0.309"/>
        <Grid x:Name="TransformGrid" Margin="5,0,0,0" >
          <Grid.RenderTransform>
            <TransformGroup>
              <ScaleTransform/>
              <SkewTransform/>
              <RotateTransform/>
              <TranslateTransform X="7"/>
            </TransformGroup>
          </Grid.RenderTransform>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="75*"/>
            <ColumnDefinition Width="347*"/>
            <ColumnDefinition Width="330*"/>
          </Grid.ColumnDefinitions>
          <Border x:Name="SelectBorder" Grid.ColumnSpan="3" BorderThickness="0,1,0,1" Opacity="0">
            <Border.BorderBrush>
              <LinearGradientBrush EndPoint="1,0">
                <GradientStop Offset="1" Color="#008A8A8A"/>
                <GradientStop Color="#008A8A8A"/>
                <GradientStop Color="{DynamicResource Color.006}" Offset="0.92200005"/>
                <GradientStop Color="#F99A9393" Offset="0.537"/>
                <GradientStop Color="{DynamicResource Color.006}" Offset="0.075"/>
                <GradientStop Color="{DynamicResource Color.006}" Offset="0.33990997"/>
                <GradientStop Color="{DynamicResource Color.006}" Offset="0.7094168"/>
              </LinearGradientBrush>
            </Border.BorderBrush>
            <Border.RenderTransform>
              <TransformGroup>
                <ScaleTransform/>
                <SkewTransform/>
                <RotateTransform/>
                <TranslateTransform/>
              </TransformGroup>
            </Border.RenderTransform>
            <MediaElement Source="Assets/Smoke.mp4" SpeedRatio="1" Position="00:00:00" Stretch="UniformToFill" StretchDirection="DownOnly" VerticalAlignment="Center" BlendingMode="Screen">
              <MediaElement.OpacityMask>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                  <GradientStop Color="#44000000" Offset="0.42100003"/>
                  <GradientStop Color="#FF000000" Offset="0.157"/>
                  <GradientStop Color="#FF000000" Offset="0.85200006"/>
                  <GradientStop Color="#44000000" Offset="0.57600003"/>
                </LinearGradientBrush>
              </MediaElement.OpacityMask>
            </MediaElement>
          </Border>
          <Border x:Name="Icon" Height="45" HorizontalAlignment="Right" Width="45" Margin="0,0,8,0">
            <Border.Background>
              <ImageBrush ImageSource="{Binding Path=Icon}" Stretch="Uniform"/>
            </Border.Background>
          </Border>
          <StackPanel x:Name="ItemNameStack" Orientation="Horizontal" HorizontalAlignment="Left" Grid.Column="1">
            <TextBlock x:Name="ItemName" Text="{Binding Path=Name}" Grid.Column="1" HorizontalAlignment="Left" VerticalAlignment="Center" FontSize="26" FontFamily="Assets/Fonts/#Essays1743" Opacity="0.8">
              <TextBlock.Foreground>
                <SolidColorBrush Color="{DynamicResource Color.002}"/>
              </TextBlock.Foreground>
            </TextBlock>
            <TextBlock x:Name="ItemNameExt" Text="{Binding Path=Extension}" TextWrapping="Wrap" VerticalAlignment="Center" Grid.Column="1" HorizontalAlignment="Left" FontSize="26" FontFamily="Assets/Fonts/#Essays1743" Margin="5,0,0,10" Opacity="0.8" FontStyle="Italic">
              <TextBlock.Foreground>
                <SolidColorBrush Color="{DynamicResource Color.002}"/>
              </TextBlock.Foreground>
            </TextBlock>
          </StackPanel>
          <StackPanel x:Name="Materials" Grid.Column="2" Orientation="Horizontal" Margin="7,0,0,0">
            <StackPanel x:Name="Materials1" Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Left">
              <Border Width="38" Height="35" Grid.Column="2">
                <Border.Background>
                  <ImageBrush ImageSource="{Binding Path=Ingredient1.IngredientIcon}" Stretch="Uniform"/>
                </Border.Background>
              </Border>
              <TextBlock x:Name="MQty1" Text="{Binding Path=Ingredient1.IngredientQty, StringFormat=F0}" TextWrapping="Wrap" Grid.Column="2" VerticalAlignment="Center" FontFamily="Assets/Fonts/#Essays1743" FontSize="25" TextAlignment="Center" Style="{DynamicResource}" FontWeight="DemiBold" Margin="6,0,0,0" HorizontalAlignment="Center">
                <TextBlock.Foreground>
                  <SolidColorBrush Color="{DynamicResource OldRed}"/>
                </TextBlock.Foreground>
              </TextBlock>
            </StackPanel>
            <Grid Margin="20,0,11,0">
              <Path Data="M0,0 0,8.10256M-4.0001,4.00005 3.99975,4.00005" StrokeThickness="1.2" Stretch="Fill" Margin="0,6.1,0.822,0" Height="9.099993" HorizontalAlignment="Center" VerticalAlignment="Center" Width="8.999847" Stroke="{DynamicResource CrossGradient}" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
            </Grid>
            <StackPanel x:Name="Materials2" Orientation="Horizontal" HorizontalAlignment="Left">
              <Border Width="38" Height="35" Grid.Column="2">
                <Border.Background>
                  <ImageBrush ImageSource="{Binding Path=Ingredient2.IngredientIcon}" Stretch="Uniform"/>
