      <BooleanAnimationUsingKeyFrames Storyboard.TargetName="Technician" Storyboard.TargetProperty="(UIElement.IsEnabled)">
        <DiscreteBooleanKeyFrame KeyTime="0:0:0" Value="False"/>
        <DiscreteBooleanKeyFrame KeyTime="0:0:0.5000000" Value="True"/>
