<Component
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
  xmlns:noesis="clr-namespace:NoesisGUIExtensions"
  xmlns:local="clr-namespace:NoesisStudioInternals"
  mc:Ignorable="d" d:DataContext="System.01" d:DesignWidth="1280" d:DesignHeight="720">
  <Component.Resources>
    <ControlTemplate x:Key="ContentControl.ControlTemplate.UpdateAnimation" TargetType="ContentControl">
      <Grid x:Name="Grid0" RenderTransformOrigin="0.5,0.5">
        <b:Interaction.Triggers>
          <b:DataTrigger Binding="{Binding Path=IsEnabled, RelativeSource={RelativeSource TemplatedParent}}" Value="True">
            <b:GoToStateAction StateName="Visible"/>
          </b:DataTrigger>
          <b:DataTrigger Binding="{Binding Path=IsEnabled, RelativeSource={RelativeSource TemplatedParent}}" Value="False">
            <b:GoToStateAction StateName="Hidden"/>
          </b:DataTrigger>
        </b:Interaction.Triggers>
        <Grid.RenderTransform>
          <TransformGroup>
            <ScaleTransform/>
            <SkewTransform/>
            <RotateTransform/>
            <TranslateTransform/>
          </TransformGroup>
        </Grid.RenderTransform>
        <Grid.OpacityMask>
          <LinearGradientBrush StartPoint="0,1">
            <GradientStop Color="#FF000000" Offset="0"/>
            <GradientStop Color="#FFFFFFFF" Offset="1"/>
            <GradientStop Color="#FF333333" Offset="0.20228153"/>
            <GradientStop Color="#FF626262" Offset="0.4"/>
            <GradientStop Color="#FF8D8D8D" Offset="0.6"/>
            <GradientStop Color="#FFC2C2C2" Offset="0.8"/>
          </LinearGradientBrush>
        </Grid.OpacityMask>
        <VisualStateManager.VisualStateGroups>
          <VisualStateGroup x:Name="States">
            <VisualStateGroup.Transitions>
              <VisualTransition From="Hidden" GeneratedDuration="0" To="Visible">
                <Storyboard>
                  <ColorAnimationUsingKeyFrames Storyboard.TargetName="Grid0" Storyboard.TargetProperty="(UIElement.OpacityMask).(GradientBrush.GradientStops)[0].(GradientStop.Color)">
                    <EasingColorKeyFrame KeyTime="0:0:0" Value="#00000000"/>
                    <EasingColorKeyFrame KeyTime="0:0:0.1000000" Value="#FF000000"/>
                  </ColorAnimationUsingKeyFrames>
                  <ColorAnimationUsingKeyFrames Storyboard.TargetName="Grid0" Storyboard.TargetProperty="(UIElement.OpacityMask).(GradientBrush.GradientStops)[2].(GradientStop.Color)">
                    <EasingColorKeyFrame KeyTime="0:0:0" Value="#00333333"/>
                    <EasingColorKeyFrame KeyTime="0:0:0.1500000" Value="#FF333333"/>
                  </ColorAnimationUsingKeyFrames>
                  <ColorAnimationUsingKeyFrames Storyboard.TargetName="Grid0" Storyboard.TargetProperty="(UIElement.OpacityMask).(GradientBrush.GradientStops)[3].(GradientStop.Color)">
                    <EasingColorKeyFrame KeyTime="0:0:0" Value="#00626262"/>
                    <EasingColorKeyFrame KeyTime="0:0:0.1000000" Value="#00626262"/>
                    <EasingColorKeyFrame KeyTime="0:0:0.2000000" Value="#FF626262"/>
                  </ColorAnimationUsingKeyFrames>
                  <ColorAnimationUsingKeyFrames Storyboard.TargetName="Grid0" Storyboard.TargetProperty="(UIElement.OpacityMask).(GradientBrush.GradientStops)[4].(GradientStop.Color)">
                    <EasingColorKeyFrame KeyTime="0:0:0" Value="#008D8D8D"/>
                    <EasingColorKeyFrame KeyTime="0:0:0.1500000" Value="#008D8D8D"/>
                    <EasingColorKeyFrame KeyTime="0:0:0.2500000" Value="#FF8D8D8D"/>
                  </ColorAnimationUsingKeyFrames>
                  <ColorAnimationUsingKeyFrames Storyboard.TargetName="Grid0" Storyboard.TargetProperty="(UIElement.OpacityMask).(GradientBrush.GradientStops)[5].(GradientStop.Color)">
                    <EasingColorKeyFrame KeyTime="0:0:0" Value="#00C2C2C2"/>
                    <EasingColorKeyFrame KeyTime="0:0:0.2000000" Value="#00C2C2C2"/>
                    <EasingColorKeyFrame KeyTime="0:0:0.3000000" Value="#FFC2C2C2"/>
                  </ColorAnimationUsingKeyFrames>
                  <ColorAnimationUsingKeyFrames Storyboard.TargetName="Grid0" Storyboard.TargetProperty="(UIElement.OpacityMask).(GradientBrush.GradientStops)[1].(GradientStop.Color)">
                    <EasingColorKeyFrame KeyTime="0:0:0" Value="#00FFFFFF"/>
                    <EasingColorKeyFrame KeyTime="0:0:0.2500000" Value="#00FFFFFF"/>
                    <EasingColorKeyFrame KeyTime="0:0:0.3499999" Value="#FFFFFFFF"/>
                  </ColorAnimationUsingKeyFrames>
                  <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Grid0" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[3].(TranslateTransform.Y)">
                    <EasingDoubleKeyFrame KeyTime="0:0:0" Value="-5"/>
                    <EasingDoubleKeyFrame KeyTime="0:0:0.2000000" Value="0">
                      <EasingDoubleKeyFrame.EasingFunction>
                        <CubicEase EasingMode="EaseIn"/>
                      </EasingDoubleKeyFrame.EasingFunction>
                    </EasingDoubleKeyFrame>
                  </DoubleAnimationUsingKeyFrames>
                  <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter0" Storyboard.TargetProperty="(UIElement.Opacity)">
                    <EasingDoubleKeyFrame KeyTime="0:0:0" Value="0"/>
                    <EasingDoubleKeyFrame KeyTime="0:0:0.1000000" Value="1">
                      <EasingDoubleKeyFrame.EasingFunction>
                        <CubicEase EasingMode="EaseIn"/>
                      </EasingDoubleKeyFrame.EasingFunction>
                    </EasingDoubleKeyFrame>
                  </DoubleAnimationUsingKeyFrames>
                </Storyboard>
              </VisualTransition>
            </VisualStateGroup.Transitions>
            <VisualState x:Name="Visible"/>
            <VisualState x:Name="Hidden">
              <Storyboard>
                <ColorAnimationUsingKeyFrames Storyboard.TargetName="Grid0" Storyboard.TargetProperty="(UIElement.OpacityMask).(GradientBrush.GradientStops)[0].(GradientStop.Color)">
                  <EasingColorKeyFrame KeyTime="0:0:0" Value="#00000000"/>
                </ColorAnimationUsingKeyFrames>
                <ColorAnimationUsingKeyFrames Storyboard.TargetName="Grid0" Storyboard.TargetProperty="(UIElement.OpacityMask).(GradientBrush.GradientStops)[2].(GradientStop.Color)">
                  <EasingColorKeyFrame KeyTime="0:0:0" Value="#00333333"/>
                </ColorAnimationUsingKeyFrames>
                <ColorAnimationUsingKeyFrames Storyboard.TargetName="Grid0" Storyboard.TargetProperty="(UIElement.OpacityMask).(GradientBrush.GradientStops)[3].(GradientStop.Color)">
                  <EasingColorKeyFrame KeyTime="0:0:0" Value="#00626262"/>
                </ColorAnimationUsingKeyFrames>
                <ColorAnimationUsingKeyFrames Storyboard.TargetName="Grid0" Storyboard.TargetProperty="(UIElement.OpacityMask).(GradientBrush.GradientStops)[4].(GradientStop.Color)">
                  <EasingColorKeyFrame KeyTime="0:0:0" Value="#008D8D8D"/>
                </ColorAnimationUsingKeyFrames>
                <ColorAnimationUsingKeyFrames Storyboard.TargetName="Grid0" Storyboard.TargetProperty="(UIElement.OpacityMask).(GradientBrush.GradientStops)[5].(GradientStop.Color)">
                  <EasingColorKeyFrame KeyTime="0:0:0" Value="#00C2C2C2"/>
                </ColorAnimationUsingKeyFrames>
                <ColorAnimationUsingKeyFrames Storyboard.TargetName="Grid0" Storyboard.TargetProperty="(UIElement.OpacityMask).(GradientBrush.GradientStops)[1].(GradientStop.Color)">
                  <EasingColorKeyFrame KeyTime="0:0:0" Value="#00FFFFFF"/>
                </ColorAnimationUsingKeyFrames>
              </Storyboard>
            </VisualState>
          </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
        <ContentPresenter x:Name="ContentPresenter0" ContentSource="Content"/>
      </Grid>
    </ControlTemplate>
    <Storyboard x:Key="Storyboard0">
