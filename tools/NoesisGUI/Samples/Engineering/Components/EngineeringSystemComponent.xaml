        <DiscreteBooleanKeyFrame KeyTime="0:0:0.5000000" Value="True"/>
      </BooleanAnimationUsingKeyFrames>
      <BooleanAnimationUsingKeyFrames Storyboard.TargetName="TechnicianOptions" Storyboard.TargetProperty="(UIElement.IsEnabled)">
        <DiscreteBooleanKeyFrame KeyTime="0:0:0" Value="False"/>
        <DiscreteBooleanKeyFrame KeyTime="0:0:0.6000000" Value="True"/>
      </BooleanAnimationUsingKeyFrames>
      <BooleanAnimationUsingKeyFrames Storyboard.TargetName="Modifiers" Storyboard.TargetProperty="(UIElement.IsEnabled)">
        <DiscreteBooleanKeyFrame KeyTime="0:0:0" Value="False"/>
        <DiscreteBooleanKeyFrame KeyTime="0:0:0.5000000" Value="True"/>
      </BooleanAnimationUsingKeyFrames>
      <BooleanAnimationUsingKeyFrames Storyboard.TargetName="PerformanceOutputValue" Storyboard.TargetProperty="(UIElement.IsEnabled)">
        <DiscreteBooleanKeyFrame KeyTime="0:0:0" Value="False"/>
        <DiscreteBooleanKeyFrame KeyTime="0:0:0.6000000" Value="True"/>
      </BooleanAnimationUsingKeyFrames>
      <BooleanAnimationUsingKeyFrames Storyboard.TargetName="SystemIcon" Storyboard.TargetProperty="(UIElement.IsEnabled)">
        <DiscreteBooleanKeyFrame KeyTime="0:0:0" Value="False"/>
        <DiscreteBooleanKeyFrame KeyTime="0:0:0.1000000" Value="True"/>
      </BooleanAnimationUsingKeyFrames>
      <BooleanAnimationUsingKeyFrames Storyboard.TargetName="Performance" Storyboard.TargetProperty="(UIElement.IsEnabled)">
        <DiscreteBooleanKeyFrame KeyTime="0:0:0" Value="False"/>
        <DiscreteBooleanKeyFrame KeyTime="0:0:0.2000000" Value="True"/>
      </BooleanAnimationUsingKeyFrames>
    </Storyboard>
  </Component.Resources>
