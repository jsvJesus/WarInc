  <DataTemplate x:Key="SystemViewModel.DataTemplate.Wheel">
    <Canvas Width="128" Height="640" RenderTransformOrigin="0.5,0.5">
      <Canvas.RenderTransform>
        <TransformGroup>
          <ScaleTransform/>
          <SkewTransform/>
          <RotateTransform Angle="{Binding WheelRotation}"/>
          <TranslateTransform/>
        </TransformGroup>
      </Canvas.RenderTransform>
      <Canvas.Style>
        <Style TargetType="{x:Type Canvas}">
          <Style.Triggers>
            <DataTrigger Binding="{Binding IsVisible}" Value="False">
              <DataTrigger.Setters>
                <Setter Property="Visibility" Value="Hidden"/>
              </DataTrigger.Setters>
            </DataTrigger>
          </Style.Triggers>
        </Style>
      </Canvas.Style>
  
      <!-- Armor Section -->
      <Path Fill="{StaticResource Brush.PanelLines}" Data="{StaticResource Geometry.ArmorSection}"/>
  
      <!-- Equipment Slot -->
      <ContentControl Background="Transparent" Style="{StaticResource ContentControl.Style.ButtonStandard}" Canvas.Left="8" Canvas.Top="28">
        <Canvas Width="112" Height="54">
          <!-- Top orientation -->
          <Path Style="{StaticResource Path.Style.SystemButton}">            
            <b:Interaction.Triggers>
              <b:DataTrigger Binding="{Binding Path=IsSelected, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ListBoxItem}}}" Value="True">
                <b:ChangePropertyAction PropertyName="Stroke" Value="{StaticResource Brush.Text}"/>
              </b:DataTrigger>
              <b:DataTrigger Binding="{Binding Path=IsSelected, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ListBoxItem}}}" Value="False">
                <b:ChangePropertyAction PropertyName="Stroke" Value="{StaticResource Brush.InteractableBorder}"/>
              </b:DataTrigger>
            </b:Interaction.Triggers>
          </Path>
          <Path Style="{StaticResource Path.Style.SystemButtonDecor}"/>
  
          <Grid Canvas.Top="10" Canvas.Left="18" Width="76">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="32"/>
              <ColumnDefinition/>
              <ColumnDefinition Width="32"/>
            </Grid.ColumnDefinitions>

            <Grid Width="32" Height="32" RenderTransformOrigin="0.5,0.5">
              <Grid.RenderTransform>
                <TransformGroup>
                  <ScaleTransform/>
                  <SkewTransform/>                  
                  <RotateTransform>
                    <RotateTransform.Angle>
                      <Binding Path="WheelRotation">
                        <Binding.Converter>
                          <noesis:MathConverter Expression="{}{0} * -1"/>
                        </Binding.Converter>
                      </Binding>
                    </RotateTransform.Angle>
                  </RotateTransform>
                  <TranslateTransform/>
                </TransformGroup>
              </Grid.RenderTransform>
              <Grid.Style>
                <Style TargetType="{x:Type Canvas}">
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsOrientatedTop}" Value="True">
                      <DataTrigger.Setters>
                        <Setter Property="Grid.Column" Value="0"/>
                      </DataTrigger.Setters>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsOrientatedTop}" Value="False">
                      <DataTrigger.Setters>
                        <Setter Property="Grid.Column" Value="2"/>
                      </DataTrigger.Setters>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Grid.Style>

              <Viewbox Margin="2">
                <ContentControl ContentTemplateSelector="{StaticResource TemplateSelector.DynamicKey.Icon}" Content="{Binding}"/>
              </Viewbox>
            </Grid>

            <Grid Width="32" Height="32" RenderTransformOrigin="0.5,0.5">
              <Grid.RenderTransform>
                <TransformGroup>
                  <ScaleTransform/>
                  <SkewTransform/>                  
                  <RotateTransform>
                    <RotateTransform.Angle>
                      <Binding Path="WheelRotation">
                        <Binding.Converter>
                          <noesis:MathConverter Expression="{}{0} * -1"/>
                        </Binding.Converter>
                      </Binding>
                    </RotateTransform.Angle>
                  </RotateTransform>
                  <TranslateTransform/>
                </TransformGroup>
              </Grid.RenderTransform>
              <Grid.Style>
                <Style TargetType="{x:Type Grid}">
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsOrientatedTop}" Value="True">
                      <DataTrigger.Setters>
                        <Setter Property="Grid.Column" Value="2"/>
                      </DataTrigger.Setters>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsOrientatedTop}" Value="False">
                      <DataTrigger.Setters>
                        <Setter Property="Grid.Column" Value="0"/>
                      </DataTrigger.Setters>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Grid.Style>
    
              <!-- Geometry.TechnicianSlotBackground -->
              <Path Fill="{StaticResource Brush.TechnicianSlotBackground}" Data="{StaticResource Geometry.TechnicianSlotBackground}"/>
              <!-- Geometry.TechnicianSlotIcon -->
              <Path Fill="#40000000" Data="{StaticResource Geometry.TechnicianSlotIcon}"/>
              <!-- Technician portrait -->
              <Viewbox>
                <ContentControl ContentTemplateSelector="{StaticResource TemplateSelector.DynamicKey.TechnicianPortrait}" Content="{Binding Technician.PortraitKey}"/>
              </Viewbox>
            </Grid>
          </Grid>          
        </Canvas>
      </ContentControl>
  
      <!-- Bars -->
      <!-- Top orientation -->
      <Canvas Width="128" RenderTransformOrigin="0.5,0.5">
        <Canvas.RenderTransform>
          <TransformGroup>
            <ScaleTransform ScaleX="1"/>
          </TransformGroup>
        </Canvas.RenderTransform>
        <Path x:Name="IntegrityBar" Data="{StaticResource Geometry.IntegrityBar}">
          <Path.MinWidth>
            <MultiBinding>
              <MultiBinding.Converter>
                <noesis:MathConverter Expression="{}{0}/{1}"/>
              </MultiBinding.Converter>
              <Binding Path="IntegrityBar.CurrentValue"/>
              <Binding Path="IntegrityBar.MaxValue"/>
            </MultiBinding>
          </Path.MinWidth>
          <Path.Fill>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
              <GradientStop Color="{StaticResource Color.Integrity}" Offset="{Binding MinWidth, RelativeSource={RelativeSource AncestorType=Path}}"/>
              <GradientStop Color="{StaticResource Color.BarBackground}" Offset="{Binding MinWidth, RelativeSource={RelativeSource AncestorType=Path}}"/>
            </LinearGradientBrush>
          </Path.Fill>
        </Path>
        <Path x:Name="InstabilityBar" Data="{StaticResource Geometry.InstabilityBar}">
          <Path.MinWidth>
            <MultiBinding>
              <MultiBinding.Converter>
                <noesis:MathConverter Expression="{}{0}/{1}"/>
              </MultiBinding.Converter>
              <Binding Path="InstabilityBar.CurrentValue"/>
              <Binding Path="InstabilityBar.MaxValue"/>
            </MultiBinding>
          </Path.MinWidth>
          <Path.Fill>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
              <GradientStop Color="{StaticResource Color.Instability}" Offset="{Binding MinWidth, RelativeSource={RelativeSource AncestorType=Path}}"/>
              <GradientStop Color="{StaticResource Color.BarBackground}" Offset="{Binding MinWidth, RelativeSource={RelativeSource AncestorType=Path}}"/>
            </LinearGradientBrush>
          </Path.Fill>
        </Path>
        <Path x:Name="HeatBar" Data="{StaticResource Geometry.HeatBar}">
          <Path.MinWidth>
            <MultiBinding>
              <MultiBinding.Converter>
                <noesis:MathConverter Expression="{}{0}/{1}"/>
              </MultiBinding.Converter>
              <Binding Path="HeatBar.CurrentValue"/>
              <Binding Path="HeatBar.MaxValue"/>
            </MultiBinding>
          </Path.MinWidth>
          <Path.Fill>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
              <GradientStop Color="{StaticResource Color.Heat}" Offset="{Binding MinWidth, RelativeSource={RelativeSource AncestorType=Path}}"/>
              <GradientStop Color="{StaticResource Color.BarBackground}" Offset="{Binding MinWidth, RelativeSource={RelativeSource AncestorType=Path}}"/>
            </LinearGradientBrush>
          </Path.Fill>
        </Path>
        <Path x:Name="PowerBar" Data="{StaticResource Geometry.PowerBar}">
          <Path.MinWidth>
            <MultiBinding>
              <MultiBinding.Converter>
                <noesis:MathConverter Expression="{}{0}/{1}"/>
              </MultiBinding.Converter>
              <Binding Path="PowerBar.CurrentValue"/>
              <Binding Path="PowerBar.MaxValue"/>
            </MultiBinding>
          </Path.MinWidth>
          <Path.Fill>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
              <GradientStop Color="{StaticResource Color.Power}" Offset="{Binding MinWidth, RelativeSource={RelativeSource AncestorType=Path}}"/>
              <GradientStop Color="{StaticResource Color.BarBackground}" Offset="{Binding MinWidth, RelativeSource={RelativeSource AncestorType=Path}}"/>
            </LinearGradientBrush>
          </Path.Fill>
        </Path>
      </Canvas>
  
      <Path Fill="{StaticResource Brush.PanelLines}" Data="{StaticResource Geometry.Chrevons}"/>
      
      <Canvas Width="30" Height="30" Canvas.Left="48" Canvas.Top="89">
        <Path x:Name="PowerLineCircle" StrokeThickness="1" Style="{StaticResource Path.Style.SystemNodeRing}" Fill="{StaticResource Brush.Background}" Data="M 30.5 15.5 Q 30.5 21.75 26.1 26.1 21.7 30.5 15.5 30.5 9.3 30.5 4.9 26.1 0.5 21.75 0.5 15.5 0.5 9.3 4.9 4.9 9.3 0.5 15.5 0.5 21.7 0.5 26.1 4.9 30.5 9.3 30.5 15.5 Z"/>
  
        <Canvas Background="Transparent" Width="22" Height="22" Canvas.Left="4" Canvas.Top="4">
          <Canvas Width="22" Height="22">
            <Canvas Canvas.Left="11" Canvas.Top="11"/>
            <Path Style="{StaticResource Path.Style.Interactable}" Data="M 22.5 11.5 Q 22.5 16 19.25 19.25 16.05 22.5 11.5 22.5 6.95 22.5 3.7 19.25 0.5 16 0.5 11.5 0.5 6.9 3.7 3.7 6.95 0.5 11.5 0.5 16.05 0.5 19.25 3.7 22.5 6.9 22.5 11.5 Z"/>
            <Canvas Width="22" Height="22" RenderTransformOrigin="0.5,0.5">
              <Canvas.RenderTransform>
                <TransformGroup>
                  <ScaleTransform/>
                  <SkewTransform/>                  
                  <RotateTransform>
                    <RotateTransform.Angle>
                      <Binding Path="WheelRotation">
                        <Binding.Converter>
                          <noesis:MathConverter Expression="{}{0} * -1"/>
                        </Binding.Converter>
                      </Binding>
                    </RotateTransform.Angle>
                  </RotateTransform>
                  <TranslateTransform/>
                </TransformGroup>
              </Canvas.RenderTransform>
              <TextBlock Style="{DynamicResource TextBlock.Style.Header2}" TextAlignment="Center" Width="22" Canvas.Top="4" Text="{Binding PowerBar.CurrentValue}">
                <TextBlock.Foreground>
                  <SolidColorBrush Color="{DynamicResource Color.AddPowerConnection}"/>
                </TextBlock.Foreground>
              </TextBlock>
            </Canvas>
          </Canvas>
        </Canvas>
      </Canvas>
    </Canvas>
  </DataTemplate>

