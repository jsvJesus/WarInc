  <ControlTemplate x:Key="Button.ControlTemplate.Rectangle" TargetType="Button">
    <Grid x:Name="ButtonRoot" RenderTransformOrigin="0.5,0.5">
      <VisualStateManager.VisualStateGroups>
        <VisualStateGroup x:Name="CommonStates">
          <VisualStateGroup.Transitions>
            <VisualTransition GeneratedDuration="0:0:0.1500000" To="MouseOver"/>
            <VisualTransition GeneratedDuration="0:0:0.0500000" To="Pressed"/>
          </VisualStateGroup.Transitions>
          <VisualState x:Name="Normal"/>
          <VisualState x:Name="MouseOver">
            <Storyboard>
              <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ButtonRoot" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)">
                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="1.01"/>
              </DoubleAnimationUsingKeyFrames>
              <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ButtonRoot" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)">
                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="1.01"/>
              </DoubleAnimationUsingKeyFrames>
            </Storyboard>
          </VisualState>
          <VisualState x:Name="Pressed">
            <Storyboard>
              <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ButtonRoot" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)">
                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="0.99"/>
              </DoubleAnimationUsingKeyFrames>
              <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ButtonRoot" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)">
                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="0.99"/>
              </DoubleAnimationUsingKeyFrames>
            </Storyboard>
          </VisualState>
          <VisualState x:Name="Disabled"/>
        </VisualStateGroup>
      </VisualStateManager.VisualStateGroups>
      <Grid.RenderTransform>
        <TransformGroup>
          <ScaleTransform/>
          <SkewTransform/>
          <RotateTransform/>
          <TranslateTransform/>
        </TransformGroup>
      </Grid.RenderTransform>  
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition/>
          <ColumnDefinition Width="9"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="9"/>
          <RowDefinition/>
        </Grid.RowDefinitions>
        <Border BorderThickness="0" Grid.RowSpan="2" Background="{TemplateBinding Background}" BorderBrush="{x:Null}"/>
        <Border x:Name="TopLeftBorder" BorderThickness="1,1,0,0" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"/>
        <Border x:Name="BottomBorder" BorderThickness="1,0,1,1" Grid.Row="1" Grid.ColumnSpan="2" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"/>
        <Grid Grid.Column="1">
          <Path x:Name="CornerEdge" Data="M -0.5 0.5 L 1.5 0.5 L 9.5 8.5 L 9.5 10.5 L -0.5 10.5 Z" HorizontalAlignment="Right" VerticalAlignment="Top" Fill="{TemplateBinding Background}" Stroke="{TemplateBinding BorderBrush}"/>
          <Path x:Name="CornerDecor" Data="M 0.5 0.5 L 5.5 5.5 L 5.5 0.5 L 0.5 0.5 Z" Fill="Transparent" Stroke="{StaticResource Brush.InteractableDecor}" HorizontalAlignment="Right" VerticalAlignment="Top" Width="6" Height="6" Grid.Column="1"/>
        </Grid>
      </Grid>    
      <ContentPresenter ContentSource="Content"/>
    </Grid>
  </ControlTemplate> 

  <Style x:Key="Button.Style.Rectangle" TargetType="{x:Type Button}" BasedOn="{StaticResource Button.Style.Standard}">
    <Setter Property="Background" Value="{StaticResource Brush.InteractableBackground}"/>
    <Setter Property="BorderBrush" Value="{StaticResource Brush.InteractableBorder}"/>
    <Setter Property="Template" Value="{StaticResource Button.ControlTemplate.Rectangle}"/>
    <Style.Triggers>
      <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self},Path=IsMouseOver}" Value="True">
        <Setter Property="Background" Value="{StaticResource Brush.InteractableBackground:Hover}"/>
      </DataTrigger>
    </Style.Triggers>
  </Style>

  <Style x:Key="Button.Style.Dark" TargetType="{x:Type Button}" BasedOn="{StaticResource Button.Style.Rectangle}">
    <Setter Property="Background" Value="{StaticResource Brush.PanelBackground}"/>
    <Setter Property="Content" Value="{Binding}"/>
  </Style>

  <Style x:Key="Button.Style.Message" TargetType="{x:Type Button}" BasedOn="{StaticResource Button.Style.Dark}">
    <Style.Triggers>
      <DataTrigger Binding="{Binding Subject, FallbackValue={x:Null}}" Value="{x:Null}">
        <Setter Property="Visibility" Value="Collapsed"/>
      </DataTrigger>
    </Style.Triggers>
  </Style>

  <DataTemplate DataType="{x:Type studio:UnassignedStatusViewModel}">
    <Grid>
      <TextBlock Text="UNASSIGNED" Style="{StaticResource TextBlock.Style.TechnicianButtonStatus}"/>
    </Grid>
  </DataTemplate>

  <DataTemplate DataType="{x:Type studio:AssignedStatusViewModel}">
    <StackPanel Orientation="Horizontal">
      <Viewbox Height="{Binding Path=ActualHeight, ElementName=SystemName}">
        <Canvas Width="128" Height="128">
          <ContentControl ContentTemplateSelector="{StaticResource TemplateSelector.DynamicKey.Icon}" Content="{Binding System}"/>
        </Canvas>
      </Viewbox>
      <TextBlock x:Name="SystemName" Style="{StaticResource TextBlock.Style.TechnicianButtonStatus}" Margin="4,0,0,0">
        <TextBlock.Text>
          <Binding Path="System.Name">
            <Binding.Converter>
              <noesis:CaseConverter Format="UpperCase"/>
            </Binding.Converter>
          </Binding>
        </TextBlock.Text>
      </TextBlock>
    </StackPanel>
  </DataTemplate>

  <DataTemplate DataType="{x:Type studio:InjuredStatusViewModel}">
    <Grid>
      <TextBlock Text="{Binding InjuryTimeRemaining, StringFormat='{}INJURED [{0}]'}" Style="{StaticResource TextBlock.Style.TechnicianButtonStatus}"/>
    </Grid>
  </DataTemplate>

  <Style x:Key="Button.Style.PowerPreset" TargetType="{x:Type Button}" BasedOn="{StaticResource Button.Style.Standard}">    
    <Setter Property="Command" Value="{Binding SelectPowerPresetCommand}"/>
    <Setter Property="CommandParameter" Value="{Binding Path=Number}"/>
  </Style>

  <Style x:Key="Button.Style.Technician" TargetType="{x:Type Button}" BasedOn="{StaticResource Button.Style.Standard}">    
    <Setter Property="Command" Value="{Binding SelectTechnicianCommand}"/>
  </Style>

  <Style x:Key="Path.Style.TechnicianButton" TargetType="{x:Type Path}" BasedOn="{StaticResource Path.Style.Interactable}">    
    <Style.Triggers>
      <DataTrigger Binding="{Binding, FallbackValue={x:Null}}" Value="{x:Null}">
        <Setter Property="Fill" Value="{StaticResource Brush.PanelBackground}"/>
        <Setter Property="Stroke" Value="{StaticResource Brush.PanelBackground}"/>
      </DataTrigger>
    </Style.Triggers>
  </Style>

  <Style x:Key="Path.Style.TechnicianButtonDecor" TargetType="{x:Type Path}" BasedOn="{StaticResource Path.Style.InteractableDecor}">   
    <Style.Triggers>
      <DataTrigger Binding="{Binding, FallbackValue={x:Null}}" Value="{x:Null}">
        <Setter Property="Stroke" Value="{StaticResource Brush.PanelBackground}"/>
      </DataTrigger>
    </Style.Triggers>
  </Style>

  <Style x:Key="ContentControl.Style.TechnicianButton" TargetType="{x:Type ContentControl}">     
    <Setter Property="ContentTemplate" Value="{StaticResource TechnicianViewModel.DataTemplate.TechnicianButton}"/>
    <Setter Property="Content" Value="{Binding}"/>    
    <Style.Triggers>
      <DataTrigger Binding="{Binding, FallbackValue={x:Null}}" Value="{x:Null}">
        <Setter Property="Visibility" Value="Collapsed"/>
      </DataTrigger>
    </Style.Triggers>
  </Style>

  <DataTemplate DataType="{x:Type studio:SystemModifierSingleViewModel}">
    <Grid>      
      <TextBlock Style="{StaticResource TextBlock.Style.Header4}">
        <TextBlock.Text>
          <Binding Path="Description">
            <Binding.Converter>
              <noesis:CaseConverter Format="UpperCase"/>
            </Binding.Converter>
          </Binding>
        </TextBlock.Text>
      </TextBlock>
      <TextBlock Text="{Binding Value}" Style="{StaticResource TextBlock.Style.SystemModifer.Positive}"/>
    </Grid>
  </DataTemplate>

  <DataTemplate DataType="{x:Type studio:SystemModifierParentViewModel}">
    <StackPanel> 
      <TextBlock Style="{StaticResource TextBlock.Style.Header4}">
        <TextBlock.Text>
          <Binding Path="Description">
            <Binding.Converter>
              <noesis:CaseConverter Format="UpperCase"/>
            </Binding.Converter>
          </Binding>
        </TextBlock.Text>
      </TextBlock>
      <ItemsControl ItemsSource="{Binding Children}" Margin="5,0,0,0">
        <ItemsControl.ItemContainerStyle>
          <Style>
            <Setter Property="Control.Margin" Value="0,3,0,0"/>
          </Style>
        </ItemsControl.ItemContainerStyle>
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Grid>       
              <TextBlock Style="{StaticResource TextBlock.Style.Header4}">
                <TextBlock.Text>
                  <Binding Path="Description" StringFormat="{}- {0}">
                    <Binding.Converter>
                      <noesis:CaseConverter Format="UpperCase"/>
                    </Binding.Converter>
                  </Binding>
                </TextBlock.Text>
              </TextBlock>
              <TextBlock Text="{Binding Value}" Style="{StaticResource TextBlock.Style.SystemModifer.Positive}"/>
            </Grid>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </StackPanel>
  </DataTemplate>

  <DataTemplate x:Key="BarViewModel.DataTemplate.Integrity">
