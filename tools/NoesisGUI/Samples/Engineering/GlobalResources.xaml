        <MultiBinding>
          <MultiBinding.Converter>
            <noesis:MathConverter Expression="{}{0}/{1}"/>
          </MultiBinding.Converter>
          <Binding Path="CurrentValue"/>
          <Binding Path="MaxValue"/>
        </MultiBinding>
      </Border.MinWidth>
      <Border.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
          <GradientStop Color="{StaticResource Color.Integrity}" Offset="{Binding MinWidth, RelativeSource={RelativeSource AncestorType=Border}}"/>
          <GradientStop Color="{StaticResource Color.BarBackground}" Offset="{Binding MinWidth, RelativeSource={RelativeSource AncestorType=Border}}"/>
