  <Style x:Key="TextBlock.Style.Standard" TargetType="{x:Type TextBlock}">
    <Setter Property="FontFamily" Value="Fonts/#Aldrich"/>
    <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
    <Setter Property="FontSize" Value="10"/>
  </Style>

  <Style x:Key="Button.Style.Standard" TargetType="{x:Type Button}">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderBrush" Value="{x:Null}"/>
    <Setter Property="FontFamily" Value="Fonts/#Aldrich"/>
    <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
    <Setter Property="FontSize" Value="9"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type Button}">
          <ContentPresenter x:Name="LayoutRoot" RenderTransformOrigin="0.5 0.5" HorizontalAlignment="Left" VerticalAlignment="Top">
            <ContentPresenter.RenderTransform>
              <ScaleTransform/>
            </ContentPresenter.RenderTransform>
            <VisualStateManager.VisualStateGroups>
              <VisualStateGroup x:Name="CommonStates">
                <VisualState x:Name="Normal">
                  <Storyboard Duration="0:0:0.15">
                    <DoubleAnimation Storyboard.TargetName="LayoutRoot" Storyboard.TargetProperty="(ContentPresenter.RenderTransform).(ScaleTransform.ScaleX)"
                         To="1" Duration="0:0:0.15"/>
                    <DoubleAnimation Storyboard.TargetName="LayoutRoot" Storyboard.TargetProperty="(ContentPresenter.RenderTransform).(ScaleTransform.ScaleY)"
                         To="1" Duration="0:0:0.15"/>
                    <DoubleAnimation Storyboard.TargetName="LayoutRoot" Storyboard.TargetProperty="(ContentPresenter.Opacity)"
                         To="1" Duration="0:0:0.15"/>
                  </Storyboard>
                </VisualState>
                <VisualState x:Name="MouseOver">
                  <Storyboard Duration="0:0:0.15">
                    <DoubleAnimation Storyboard.TargetName="LayoutRoot" Storyboard.TargetProperty="(ContentPresenter.RenderTransform).(ScaleTransform.ScaleX)"
                         To="1.05" Duration="0:0:0.15"/>
                    <DoubleAnimation Storyboard.TargetName="LayoutRoot" Storyboard.TargetProperty="(ContentPresenter.RenderTransform).(ScaleTransform.ScaleY)"
                         To="1.05" Duration="0:0:0.15"/>
                    <DoubleAnimation Storyboard.TargetName="LayoutRoot" Storyboard.TargetProperty="(ContentPresenter.Opacity)"
                         To="1" Duration="0:0:0.15"/>
                  </Storyboard>
                </VisualState>
                <VisualState x:Name="Pressed">
                  <Storyboard Duration="0:0:0.15">
                    <DoubleAnimation Storyboard.TargetName="LayoutRoot" Storyboard.TargetProperty="(ContentPresenter.RenderTransform).(ScaleTransform.ScaleX)"
                         To="0.95" Duration="0:0:0.15"/>
                    <DoubleAnimation Storyboard.TargetName="LayoutRoot" Storyboard.TargetProperty="(ContentPresenter.RenderTransform).(ScaleTransform.ScaleY)"
                         To="0.95" Duration="0:0:0.15"/>
                    <DoubleAnimation Storyboard.TargetName="LayoutRoot" Storyboard.TargetProperty="(ContentPresenter.Opacity)"
                         To="1" Duration="0:0:0.15"/>
                  </Storyboard>
                </VisualState>
                <VisualState x:Name="Disabled">
                  <Storyboard Duration="0:0:0.15">
                    <DoubleAnimation Storyboard.TargetName="LayoutRoot" Storyboard.TargetProperty="(ContentPresenter.RenderTransform).(ScaleTransform.ScaleX)"
                         To="1" Duration="0:0:0.15"/>
                    <DoubleAnimation Storyboard.TargetName="LayoutRoot" Storyboard.TargetProperty="(ContentPresenter.RenderTransform).(ScaleTransform.ScaleY)"
                         To="1" Duration="0:0:0.15"/>
                    <DoubleAnimation Storyboard.TargetName="LayoutRoot" Storyboard.TargetProperty="(ContentPresenter.Opacity)"
                         To="0.5" Duration="0:0:0.15"/>
                  </Storyboard>
                </VisualState>
              </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>
          </ContentPresenter>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="ContentControl.Style.ButtonStandard" TargetType="{x:Type ContentControl}">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="FontFamily" Value="Fonts/#Aldrich"/>
    <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
    <Setter Property="FontSize" Value="9"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type ContentControl}">
          <Grid x:Name="LayoutRoot" Background="Transparent" RenderTransformOrigin="0.5,0.5">            
            <b:Interaction.Triggers>
              <b:EventTrigger EventName="MouseEnter" >
                  <b:GoToStateAction StateName="MouseOver"/>
              </b:EventTrigger>
              <b:EventTrigger EventName="MouseDown" >
                  <b:GoToStateAction StateName="Pressed"/>
              </b:EventTrigger>
              <b:EventTrigger EventName="MouseUp" >
                  <b:GoToStateAction StateName="Normal"/>
              </b:EventTrigger>
              <b:EventTrigger EventName="MouseLeave" >
                  <b:GoToStateAction StateName="Normal"/>
              </b:EventTrigger>
            </b:Interaction.Triggers>
            <Grid.RenderTransform>
              <ScaleTransform/>
            </Grid.RenderTransform>
            <VisualStateManager.VisualStateGroups>
              <VisualStateGroup x:Name="CommonStates">
                <VisualState x:Name="Normal">
                  <Storyboard Duration="0:0:0.05">
                    <DoubleAnimation Storyboard.TargetName="LayoutRoot" Storyboard.TargetProperty="(Grid.RenderTransform).(ScaleTransform.ScaleX)"
                         To="1" Duration="0:0:0.05"/>
                    <DoubleAnimation Storyboard.TargetName="LayoutRoot" Storyboard.TargetProperty="(Grid.RenderTransform).(ScaleTransform.ScaleY)"
                         To="1" Duration="0:0:0.05"/>
                    <DoubleAnimation Storyboard.TargetName="LayoutRoot" Storyboard.TargetProperty="(Grid.Opacity)"
                         To="1" Duration="0:0:0.05"/>
                  </Storyboard>
                </VisualState>
                <VisualState x:Name="MouseOver">
                  <Storyboard Duration="0:0:0.15">
                    <DoubleAnimation Storyboard.TargetName="LayoutRoot" Storyboard.TargetProperty="(Grid.RenderTransform).(ScaleTransform.ScaleX)"
                         To="1.05" Duration="0:0:0.15"/>
                    <DoubleAnimation Storyboard.TargetName="LayoutRoot" Storyboard.TargetProperty="(Grid.RenderTransform).(ScaleTransform.ScaleY)"
                         To="1.05" Duration="0:0:0.15"/>
                    <DoubleAnimation Storyboard.TargetName="LayoutRoot" Storyboard.TargetProperty="(Grid.Opacity)"
                         To="1" Duration="0:0:0.15"/>
                  </Storyboard>
                </VisualState>
                <VisualState x:Name="Pressed">
                  <Storyboard Duration="0:0:0.1">
                    <DoubleAnimation Storyboard.TargetName="LayoutRoot" Storyboard.TargetProperty="(Grid.RenderTransform).(ScaleTransform.ScaleX)"
                         To="0.95" Duration="0:0:0.1"/>
                    <DoubleAnimation Storyboard.TargetName="LayoutRoot" Storyboard.TargetProperty="(Grid.RenderTransform).(ScaleTransform.ScaleY)"
                         To="0.95" Duration="0:0:0.1"/>
                    <DoubleAnimation Storyboard.TargetName="LayoutRoot" Storyboard.TargetProperty="(Grid.Opacity)"
                         To="1" Duration="0:0:0.1"/>
                  </Storyboard>
                </VisualState>
                <VisualState x:Name="Disabled">
                  <Storyboard Duration="0:0:0.15">
                    <DoubleAnimation Storyboard.TargetName="LayoutRoot" Storyboard.TargetProperty="(Grid.RenderTransform).(ScaleTransform.ScaleX)"
                         To="1" Duration="0:0:0.15"/>
                    <DoubleAnimation Storyboard.TargetName="LayoutRoot" Storyboard.TargetProperty="(Grid.RenderTransform).(ScaleTransform.ScaleY)"
                         To="1" Duration="0:0:0.15"/>
                    <DoubleAnimation Storyboard.TargetName="LayoutRoot" Storyboard.TargetProperty="(Grid.Opacity)"
                         To="0.5" Duration="0:0:0.15"/>
                  </Storyboard>
                </VisualState>
              </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>
            <ContentPresenter/>
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

