    <Grid x:Name="Vignette" Background="#FFFFFFFF" BlendingMode="Multiply" IsHitTestVisible="False">
      <Grid.Effect>
        <noesis:VignetteEffect Strength="16"/>
      </Grid.Effect>
    </Grid>
    <Grid x:Name="SpeechOverlay_Grid" HorizontalAlignment="Right" VerticalAlignment="Top">
      <Grid.RowDefinitions>
        <RowDefinition Height="32"/>
        <RowDefinition Height="1*"/>
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="1*"/>
        <ColumnDefinition Width="32"/>
        <ColumnDefinition Width="144"/>
        <ColumnDefinition Width="32"/>
      </Grid.ColumnDefinitions>
      <Grid x:Name="Mayor_Portrait_Grid" VerticalAlignment="Center" Grid.Column="1" Grid.Row="1" HorizontalAlignment="Center" Grid.ColumnSpan="3">
        <Grid.Effect>
          <DropShadowEffect Color="{DynamicResource Color_OverlayShadow}" BlurRadius="0" ShadowDepth="4" Direction="-90"/>
        </Grid.Effect>
        <Grid x:Name="Mayor_Portrait_Visual_Grid" Width="144" Height="{Binding Path=ActualWidth, ElementName=Mayor_Portrait_Visual_Grid}">
          <Border x:Name="Portrait_Backer" CornerRadius="48,48,48,48">
            <Border.Background>
              <SolidColorBrush Color="{DynamicResource Info_Color_Foreground}"/>
            </Border.Background>
          </Border>
          <Border x:Name="Portrait_Image" CornerRadius="48,48,48,48" BorderThickness="8,8,8,8">
            <Border.Background>
              <ImageBrush ImageSource="{Binding Path=Town[0].MayorPortrait}" Stretch="UniformToFill">
                <ImageBrush.Transform>
                  <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform/>
                    <TranslateTransform Y="-8"/>
                  </TransformGroup>
                </ImageBrush.Transform>
              </ImageBrush>
            </Border.Background>
          </Border>
          <Border x:Name="Portrait_InnerOutline" CornerRadius="48,48,48,48" BorderThickness="4,4,4,4">
            <Border.BorderBrush>
              <SolidColorBrush Color="{DynamicResource Info_Color_Foreground}"/>
            </Border.BorderBrush>
          </Border>
        </Grid>
        <StackPanel x:Name="Mayor_Labels_VerticalStack" HorizontalAlignment="Center" VerticalAlignment="Bottom">
          <StackPanel.RenderTransform>
            <TransformGroup>
              <ScaleTransform/>
              <SkewTransform/>
              <RotateTransform/>
              <TranslateTransform Y="2"/>
            </TransformGroup>
          </StackPanel.RenderTransform>
