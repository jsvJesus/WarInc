    </LinearGradientBrush>
    <LinearGradientBrush x:Key="SliderBackgroundBrush" EndPoint="0.5,1" StartPoint="0.5,0">
      <GradientStop Offset="0" Color="#0C000000"/>
      <GradientStop Offset="0.5" Color="#4C000000"/>
      <GradientStop Offset="1" Color="#0C000000"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="SliderBorderBrush" EndPoint="0.5,1" StartPoint="0.5,0">
      <GradientStop Color="#FF1A7FB2"/>
      <GradientStop Color="#FF24648F" Offset="0.5"/>
      <GradientStop Color="#FF1A7FB2" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="ControlShadowBrush" EndPoint="0.5,1" StartPoint="0.5,0">
      <GradientStop Color="#11000000" Offset="0"/>
      <GradientStop Color="#33000000" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="LabelBackgroundBrush" EndPoint="0.5,1" StartPoint="0.5,0">
      <GradientStop Color="White" Offset="0"/>
      <GradientStop Color="#FFCBCBCB" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="IndentBorder" EndPoint="0.5,1" StartPoint="0.5,0">
      <GradientStop Color="#FF17436A" Offset="0"/>
      <GradientStop Color="#FF164269" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="IndentBackground" EndPoint="0.5,1" StartPoint="0.5,0">
      <GradientStop Offset="0" Color="#FF2E6E9B"/>
      <GradientStop Offset="0.95" Color="#FF143B5E"/>
      <GradientStop Offset="0.89" Color="#FF1C4E78"/>
    </LinearGradientBrush>
    <SolidColorBrush x:Key="TextForegroundBrush" Color="#FF482E19"/>
    <Style x:Key="Style.ItemContainer" TargetType="ComboBoxItem">
      <Setter Property="Template" Value="{DynamicResource ComboBoxItemTemplate}"/>
    </Style>
  </Page.Resources>

  <b:Interaction.Triggers>
    <b:EventTrigger>
      <b:ControlStoryboardAction Storyboard="{DynamicResource Intro}"/>
    </b:EventTrigger>
  </b:Interaction.Triggers>

  <Grid>
    <Grid x:Name="LayoutRoot" Focusable="True" Background="{DynamicResource NoesisLogoBg}" FlowDirection="{Binding Path=Selected.FlowDirection}">
      <Grid.RowDefinitions>
        <RowDefinition Height="9*"/>
        <RowDefinition Height="80*"/>
        <RowDefinition Height="9*"/>
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="5*"/>
        <ColumnDefinition Width="90*"/>
        <ColumnDefinition Width="5*"/>
      </Grid.ColumnDefinitions>
      <Viewbox Grid.Row="1" Grid.Column="1" PPAAMode="Disabled">
        <Grid x:Name="Dialog" Width="290" Height="380" RenderTransformOrigin="0.5,0.25">
          <Grid.RenderTransform>
            <TransformGroup>
              <ScaleTransform/>
              <SkewTransform/>
              <RotateTransform/>
              <TranslateTransform/>
            </TransformGroup>
          </Grid.RenderTransform>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="8"/>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="8"/>
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="4"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="8"/>
          </Grid.RowDefinitions>
          <Border Grid.Column="1">
            <Border.Background>
              <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Color="#00000000" Offset="0"/>
                <GradientStop Color="#3F000000" Offset="1"/>
              </LinearGradientBrush>
            </Border.Background>
          </Border>
          <Border Grid.Column="1" Grid.Row="2">
            <Border.Background>
              <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Color="#00000000" Offset="1"/>
                <GradientStop Color="#3F000000"/>
              </LinearGradientBrush>
            </Border.Background>
          </Border>
          <Border Grid.Row="1">
            <Border.Background>
              <LinearGradientBrush EndPoint="1,0" StartPoint="0,0">
                <GradientStop Color="#00000000"/>
                <GradientStop Color="#3F000000" Offset="1"/>
              </LinearGradientBrush>
            </Border.Background>
          </Border>
          <Border Grid.Column="2" Grid.Row="1">
            <Border.Background>
              <LinearGradientBrush EndPoint="1,0" StartPoint="0,0">
                <GradientStop Color="#00000000" Offset="1"/>
                <GradientStop Color="#3F000000"/>
              </LinearGradientBrush>
            </Border.Background>
          </Border>
          <Border>
            <Border.Background>
              <RadialGradientBrush GradientOrigin="1,1" Center="1,1" RadiusX="1" RadiusY="1">
                <GradientStop Color="#00000000" Offset="1"/>
                <GradientStop Color="#3F000000"/>
              </RadialGradientBrush>
            </Border.Background>
          </Border>
          <Border Grid.Column="2">
            <Border.Background>
              <RadialGradientBrush GradientOrigin="0,1" Center="0,1" RadiusX="1" RadiusY="1">
                <GradientStop Color="#00000000" Offset="1"/>
                <GradientStop Color="#3F000000"/>
              </RadialGradientBrush>
            </Border.Background>
          </Border>
          <Border Grid.Row="2">
            <Border.Background>
              <RadialGradientBrush GradientOrigin="1,0" Center="1,0" RadiusX="1" RadiusY="1">
                <GradientStop Color="#00000000" Offset="1"/>
                <GradientStop Color="#3F000000"/>
              </RadialGradientBrush>
            </Border.Background>
          </Border>
          <Border Grid.Column="2" Grid.Row="2">
            <Border.Background>
              <RadialGradientBrush GradientOrigin="0,0" Center="0,0" RadiusX="1" RadiusY="1">
                <GradientStop Color="#00000000" Offset="1"/>
                <GradientStop Color="#3F000000"/>
              </RadialGradientBrush>
            </Border.Background>
          </Border>
          <Border Grid.Column="1" Grid.Row="1" BorderThickness="1" Opacity="0.5">
            <Border.BorderBrush>
              <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Color="#FF1B638F" Offset="0"/>
                <GradientStop Color="#FF12435F" Offset="1"/>
              </LinearGradientBrush>
            </Border.BorderBrush>
            <Border.Background>
              <RadialGradientBrush GradientOrigin="0.5,0.1" Center="0.5,0.1" RadiusY="0.9" RadiusX="0.9">
                <GradientStop Color="#FF2C76B4" Offset="0"/>
                <GradientStop Color="#FF154064" Offset="0.65"/>
                <GradientStop Color="#FF123757" Offset="1"/>
              </RadialGradientBrush>
            </Border.Background>
          </Border>
          <Grid Grid.Column="1" Grid.Row="1" PPAAMode="Default">
            <Grid.RowDefinitions>
              <RowDefinition Height="15"/>
              <RowDefinition Height="*"/>
              <RowDefinition Height="10"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="20"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="20"/>
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="1" Grid.Row="1">
              <Grid.RowDefinitions>
                <RowDefinition Height="36*"/>
                <RowDefinition Height="20*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="175*"/>
              </Grid.RowDefinitions>
              <Viewbox x:Name="Logo" Stretch="Uniform" Margin="0,0,10,0">
                <StackPanel Orientation="Horizontal" FlowDirection="LeftToRight">
                  <Path Stretch="Uniform" Fill="{DynamicResource NoesisLogoBlueBg}" Data="{DynamicResource NoesisLogoGeometry}"/>
                  <Path Stretch="Uniform" Data="{DynamicResource NoesisTextGeometry}" VerticalAlignment="Center" Margin="40,0,0,0" Fill="#FFFFFFFF"/>
                  <Path Stretch="Uniform" Fill="{DynamicResource NoesisLogoBlueBg}" Data="{DynamicResource NoesisGuiTextGeometry}" Margin="40,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
              </Viewbox>
              <Border Grid.Row="2" BorderThickness="1" Margin="0,0,0,16" PPAAMode="Disabled" BorderBrush="{DynamicResource IndentBorder}" Background="{noesis:Loc ResourceKey=Flag}">
                <Border Padding="2">
                  <Border.Background>
                    <LinearGradientBrush EndPoint="1,1" StartPoint="0,0">
                      <GradientStop Color="#00304C62" Offset="0"/>
                      <GradientStop Color="#7E022A49" Offset="0.6"/>
                      <GradientStop Color="#FF154565" Offset="1"/>
                    </LinearGradientBrush>
                  </Border.Background>
                  <Label HorizontalAlignment="Center" Foreground="White" FontSize="11" MinHeight="14" Margin="0,2" Content="{noesis:Loc ResourceKey=TitleLabel}"/>
                </Border>
              </Border>
              <Grid Grid.Row="3">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="60"/>
                  <ColumnDefinition Width="40"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0" Grid.ColumnSpan="2" Foreground="#FF72BCE6" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,2" Content="{noesis:Loc ResourceKey=SelectLabel}"/>
                <ComboBox x:Name="LanguageSelector" Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" Margin="0,3,8,3" ItemTemplate="{DynamicResource LanguageItemTemplate}" ItemsSource="{Binding Path=Languages}" SelectedIndex="0" SelectedItem="{Binding Path=Selected, Mode=TwoWay}" ItemContainerStyle="{DynamicResource Style.ItemContainer}" Padding="0,8,0,8"/>
                <Label Grid.Row="1" FontSize="10" Foreground="#FF72BCE6" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,4" Content="{noesis:Loc ResourceKey=SoundLabel}"/>
                <Slider Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="1" Margin="0,3,8,3" Style="{DynamicResource SliderStyle}" Value="{Binding Path=SoundLevel}" Foreground="#FF65FF00"/>
                <Label Grid.Row="2" FontSize="10" Foreground="#FF72BCE6" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,3" Content="{noesis:Loc ResourceKey=MusicLabel}"/>
                <Slider x:Name="MusicLevel" Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="2" Value="{Binding Path=MusicLevel}" Margin="0,2,8,2" Style="{DynamicResource SliderStyle}" Foreground="#FF98FF00"/>
              </Grid>
              <Label Grid.Row="4" FontSize="10" Margin="4,10,4,0" MinHeight="16" Content="{noesis:Loc ResourceKey=DescLabel}"/>
            </Grid>
          </Grid>
        </Grid>
      </Viewbox>
    </Grid>
    <StackPanel x:Name="Infoverlay_HorizontalStack" Margin="32,32,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Orientation="Horizontal">
      <Component Source="Resources/MiniShowcases/Info_Info_Component.xaml" Height="{Binding Path=ActualHeight, ElementName=TabItem_Off}" Width="{Binding Path=ActualHeight, RelativeSource={RelativeSource Self}}" VerticalAlignment="Top" HorizontalAlignment="Left"/>
      <TabControl x:Name="Infoverlay_TabControl" Background="{x:Null}" Padding="0,0,0,0">
        <TabControl.MaxWidth>
          <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType={x:Type Page}}">
            <Binding.Converter>
              <noesis:MathConverter Expression="{}{0}/3"/>
            </Binding.Converter>
          </Binding>
        </TabControl.MaxWidth>
        <TabItem x:Name="TabItem_Off" Cursor="Hand" IsSelected="True" Template="{DynamicResource TabItem_Info_Template}" Header="{DynamicResource Info_Off_Geometry}">
          <Grid Background="#FFE5E5E5"/>
        </TabItem>
        <TabItem x:Name="TabItem_On" Cursor="Hand" Template="{DynamicResource TabItem_Info_Template}" Header="{DynamicResource Info_On_Geometry}">
          <Grid VerticalAlignment="Top" HorizontalAlignment="Left">
            <Component Source="Resources/MiniShowcases/Info_Overlay_ContentArea_Component.xaml" Text_Title_Str="Localization" Text_Description_Str="Noesis offers a complete localization featureset which allows for flexible, and powerful functionality to cater to worldwide audiences.
&#x0A;
&#x0A;Through the Noesis &apos;Loc&apos; Markup Extension, translations of content can be easily managed from a centralised Data source, which can then be bound to various pieces of content through Bindings, allowing the entire content of interfaces to be instantly changed from one localization to another.
&#x0A;
&#x0A;To render these languages, Noesis comes out of-the-box with incredible font support capable of rendering scripts from around the globe, including support for both left-to-right, and right-to-left writing systems.
&#x0A;
&#x0A;Furthermore, using the powerful &apos;FlowDirection&apos; Property, not only text, but entire layouts can be changed on-the-fly from &apos;LeftToRight&apos; to &apos;RightToLeft&apos;to provide the highest fidelity localization experience to users.
&#x0A;
&#x0A;As localization often extends beyond just language, entire collections of Resources can also be easily swapped on a per-locale basis through easy-to-manage Resource Dictionaries. This allows for each localization to benefit from not only different typography and translations, but completely different audiovisual presentation packages for each locale to best serve unique cultural sensitivities."/>
          </Grid>
        </TabItem>
      </TabControl>
    </StackPanel>
  </Grid>
</Page>
