    <ItemsPanelTemplate x:Key="IconDataArray_ListBox_ItemsPanel_Template">
      <StackPanel Orientation="Horizontal"/>
    </ItemsPanelTemplate>

    <DataTemplate x:Key="IconDataArray_ListBox_Item_Template">
      <Grid>
        <Component Source="Resources/IconLibrary/Component_Label_Badge_Rank_Number.xaml" Margin="0,0,0,160" Rank_Number_Int="{Binding Path=Badge_Rank_Number}"/>
        <Component Source="Resources/IconLibrary/Component_Label_Badge_Name.xaml" Margin="0,96,0,0" Rank_Name_Str="{Binding Path=Badge}"/>
        <ContentControl HorizontalAlignment="Center" VerticalAlignment="Center" Content="{Binding}">
          <b:Interaction.Triggers>
            <b:DataTrigger x:Name="IfIconDataRank=Mors_ThenSetSkullIcon" Binding="{Binding Path=Badge}" Value="Mors">
              <b:ChangePropertyAction PropertyName="ContentTemplate" Value="{DynamicResource DataTemplate_Icon_Skull}"/>
            </b:DataTrigger>
            <b:DataTrigger x:Name="IfIconDataNamel=Ave_ThenSetBirdIcon" Binding="{Binding Path=Badge}" Value="Ave">
              <b:ChangePropertyAction PropertyName="ContentTemplate" Value="{DynamicResource DataTemplate_Icon_Bird}"/>
            </b:DataTrigger>
            <b:DataTrigger x:Name="IfIconDataName=Flor_ThenSetFlowerIcon" Binding="{Binding Path=Badge}" Value="Flor">
              <b:ChangePropertyAction PropertyName="ContentTemplate" Value="{DynamicResource DataTemplate_Icon_Flower}"/>
            </b:DataTrigger>
          </b:Interaction.Triggers>
        </ContentControl>
      </Grid>
    </DataTemplate>

    <Style x:Key="IconDataArray_ListBox_ItemContainer_Style" TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
      <Setter Property="Template" Value="{DynamicResource IconDataArray_ListBox_ItemContainer_Template}"/>
    </Style>
    <ControlTemplate x:Key="IconDataArray_ListBox_ItemContainer_Template" TargetType="ListBoxItem">

      <ControlTemplate.Triggers>
        <Trigger Value="True" Property="IsSelected">
          <Setter TargetName="ItemBorder" Property="Background" Value="#FF4682B4"/>
        </Trigger>
        <Trigger Value="True" Property="IsMouseOver">
          <Setter TargetName="ItemBorder" Property="Background" Value="#FF778899"/>
        </Trigger>
      </ControlTemplate.Triggers>
      <Grid>
        <Component Source="Resources/IconLibrary/Component_Medallion_Rings.xaml" HorizontalAlignment="Center" VerticalAlignment="Center">
          <Component.LayoutTransform>
            <TransformGroup>
              <ScaleTransform ScaleX="0.85" ScaleY="0.85"/>
              <SkewTransform/>
              <RotateTransform Angle="90"/>
              <TranslateTransform/>
            </TransformGroup>
          </Component.LayoutTransform>
        </Component>
        <Component Source="Resources/IconLibrary/Component_Medallion_Rings.xaml" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        <ContentPresenter/>
      </Grid>
    </ControlTemplate>

    <Style x:Key="Style.ItemContainer" TargetType="ListBoxItem">
      <Setter Property="Template" Value="{DynamicResource IconDataArray_ListBox_ItemContainer_Template}"/>
    </Style>
  </Page.Resources>

  <Grid>
    <StackPanel x:Name="IconRows_VerticalStack" HorizontalAlignment="Center" VerticalAlignment="Center">
      <StackPanel x:Name="Components_HorizontalStack" Height="256" HorizontalAlignment="Center" Orientation="Horizontal">
        <TextBlock x:Name="Components_Description_TextBlock" TextWrapping="Wrap" HorizontalAlignment="Right" VerticalAlignment="Center" FontFamily="Resources/IconLibrary/#Book Antiqua" FontSize="24" FontWeight="Bold" TextAlignment="Right" Margin="0,0,32,0" noesis:RichText.Text="Iconography as[br/]Components:" Width="{Binding Path=ActualWidth, ElementName=ContentTemplates_Description_TextBlock}" FontStyle="Italic" d:IsLocked="True"/>
        <Grid x:Name="Components_Badge_0">
          <Component Source="Resources/IconLibrary/Component_Medallion.xaml" Rank_Number_Int="1" Rank_Name_Str="Mors" d:IsLocked="True"/>
          <Component Source="Resources/IconLibrary/Component_Badge_Skull.xaml" Width="96" Margin="0,0,4,20" Badge_Color_Custom_0_Brush="#FFA7A7A7" Badge_Color_Custom_1_Brush="#FF3D3D3D" Badge_Color_Custom_2_Brush="#FF845C00"/>
        </Grid>
        <Grid x:Name="Components_Badge_1">
          <Component Source="Resources/IconLibrary/Component_Medallion.xaml" Rank_Number_Int="2" Rank_Name_Str="Ave" d:IsLocked="True"/>
          <Component Source="Resources/IconLibrary/Component_Badge_Bird.xaml" Width="120" Margin="0,0,16,40" Badge_Color_Custom_0_Brush="#FF1F7300" Badge_Color_Custom_1_Brush="#FF64A200" Badge_Color_Custom_2_Brush="#FFB1AD09" Badge_Color_Custom_3_Brush="#FF007B7B"/>
        </Grid>
        <Grid x:Name="Components_Badge_2">
          <Component Source="Resources/IconLibrary/Component_Medallion.xaml" Rank_Number_Int="3" Rank_Name_Str="Flor" d:IsLocked="True"/>
          <Component Source="Resources/IconLibrary/Component_Badge_Flower.xaml" Width="128" Margin="0,0,0,18" Badge_Color_Custom_0_Brush="#FF930969" Badge_Color_Custom_1_Brush="#FF930000" Badge_Color_Custom_2_Brush="#FF00929A" Badge_Color_Custom_3_Brush="#FFFF5050"/>
        </Grid>
      </StackPanel>
      <StackPanel x:Name="ContentTemplates_HorizontalStack" Height="256" HorizontalAlignment="Center" Orientation="Horizontal">
        <TextBlock x:Name="ContentTemplates_Description_TextBlock" FontSize="24" FontFamily="Resources/IconLibrary/#Book Antiqua" FontStyle="Italic" TextAlignment="Right" TextWrapping="Wrap" FontWeight="Bold" Margin="0,0,32,0" HorizontalAlignment="Right" VerticalAlignment="Center" noesis:RichText.Text="Iconography as[br/]swappable[br/]Content Templates:" d:IsLocked="True"/>
        <Grid x:Name="ContentTemplates_Badge_0">
          <Component Source="Resources/IconLibrary/Component_Medallion.xaml" Rank_Number_Int="1" Rank_Name_Str="Mors" d:IsLocked="True"/>
          <ContentControl ContentTemplate="{DynamicResource DataTemplate_Icon_Skull}" HorizontalAlignment="Center" VerticalAlignment="Center" Content="{Binding Path=Icons[0]}"/>
        </Grid>
        <Grid x:Name="ContentTemplates_Badge_1">
          <Component Source="Resources/IconLibrary/Component_Medallion.xaml" Rank_Number_Int="2" Rank_Name_Str="Ave" d:IsLocked="True"/>
          <ContentControl ContentTemplate="{DynamicResource DataTemplate_Icon_Bird}" HorizontalAlignment="Center" VerticalAlignment="Center" Content="{Binding Path=Icons[1]}"/>
        </Grid>
        <Grid x:Name="ContentTemplates_Badge_2">
          <Component Source="Resources/IconLibrary/Component_Medallion.xaml" Rank_Number_Int="3" Rank_Name_Str="Flor" d:IsLocked="True"/>
          <ContentControl ContentTemplate="{DynamicResource DataTemplate_Icon_Flower}" HorizontalAlignment="Center" VerticalAlignment="Center" Content="{Binding Path=Icons[2]}"/>
        </Grid>
      </StackPanel>
      <StackPanel x:Name="DataArray_HorizontalStack" Height="256" HorizontalAlignment="Center" Orientation="Horizontal">
        <TextBlock x:Name="DataArray_Description_TextBlock" FontSize="24" FontFamily="Resources/IconLibrary/#Book Antiqua" FontStyle="Italic" TextAlignment="Right" TextWrapping="Wrap" FontWeight="Bold" Margin="0,0,32,0" HorizontalAlignment="Right" VerticalAlignment="Center" noesis:RichText.Text="Iconography as[br/]a Data-Driven[br/]Array:" Width="{Binding Path=ActualWidth, ElementName=ContentTemplates_Description_TextBlock}" Text="Iconography as&#x0A;a Data-Driven&#x0A;Array:"/>
        <ListBox ItemsPanel="{DynamicResource IconDataArray_ListBox_ItemsPanel_Template}" ItemContainerStyle="{DynamicResource Style.ItemContainer}" ItemTemplate="{DynamicResource IconDataArray_ListBox_Item_Template}" ItemsSource="{Binding Path=Icons}"/>
      </StackPanel>
    </StackPanel>
    <StackPanel xmlns:noesis="clr-namespace:NoesisGUIExtensions"
      x:Name="Infoverlay_HorizontalStack" Margin="32,32,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Orientation="Horizontal">
      <Component Source="Resources/MiniShowcases/Info_Info_Component.xaml" Height="{Binding Path=ActualHeight, ElementName=TabItem_Off}" Width="{Binding Path=ActualHeight, RelativeSource={RelativeSource Self}}" VerticalAlignment="Top" HorizontalAlignment="Left" d:IsLocked="True"/>
      <TabControl x:Name="Infoverlay_TabControl" Background="{x:Null}" Padding="0,0,0,0">
        <TabControl.MaxWidth>
          <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType={x:Type Page}}">
            <Binding.Converter>
              <noesis:MathConverter Expression="{}{0}/3"/>
            </Binding.Converter>
          </Binding>
        </TabControl.MaxWidth>
        <TabItem x:Name="TabItem_Off" Cursor="Hand" IsSelected="True" Template="{DynamicResource TabItem_Info_Template}" Header="{DynamicResource Info_Off_Geometry}">
          <Grid Background="#FFE5E5E5" d:IsHidden="True"/>
        </TabItem>
        <TabItem x:Name="TabItem_On" Cursor="Hand" Template="{DynamicResource TabItem_Info_Template}" Header="{DynamicResource Info_On_Geometry}">
          <Grid VerticalAlignment="Top" HorizontalAlignment="Left" d:IsLocked="True">
            <Component Source="Resources/MiniShowcases/Info_Overlay_ContentArea_Component.xaml" Text_Description_Str="There are many ways within Noesis Studio to create centralized, easily-maintainable icon libraries. Each method has its own benefits depending on individual needs and preferences:
&#x0A;
&#x0A;Creating each icon as an individual Component typically offers the easiest method for those seeking an experience most similar to creating components in external graphics editors. Components are stored as individual XAML files that can be arranged with incredible flexibility within the Assets Panel [Ctrl+1], and simply dragged-and-dropped into a Page when desired.
&#x0A;
&#x0A;Components also benefit from powerful &apos;Dynamic Properties&apos; functionality, which allows changes to be made within the Component, from the outside. This can be seen in the first row of this sample, where the colours for each individual icon can be edited from the Page-level without editing the core Component itself. This enables easy creation of instances without having to edit the base Component.
&#x0A;
&#x0A;DataTemplates, on the other hand, will be the best-suited solution within the creation of a Data-Driven interface.
&#x0A;
&#x0A;DataTemplates are stored as Resources, and can be viewed and managed within the Resources Panel [Ctrl+5]. In this example, in the second and third row, each badge&apos;s colouring, rank number, and visual are all Data-Driven, as can be seen by navigating to the Data Panel [Ctrl+6], and inspecting the &apos;IconLibrary_[..]&apos; items.
&#x0A;
&#x0A;DataTemplates present a couple advantages in that they can both be used in a standalone manner as can be seen in the second row (in a way not dissimilar to how Components are presented in the first row). However, the real superpower of Datatemplates is that they can also be automatically laid out as part of a Data-Driven array powered by a Collection Element as can be seen in the third row. In this example, the entire presentation of the icons is controlled by a ListBox Element which controls the icons and their positions relative to eachother.
&#x0A;
&#x0A;Another major strength of DataTemplates, is that since they are Templates, they can easily be hot-swapped from the context menu. Their Templated nature also means that they can be changed from the Properties panel, making them accessible to being swapped through Interactions, such as through an Event or a Trigger.
&#x0A;
&#x0A;It is also useful to note, that in many cases, mixing-and-matching between both approaches can also be beneficial. In this sample for example, the third row&apos;s ItemContainer Template contains a set of Components to facilitate asset-sharing between many of the examples pictured." Text_Title_Str="Icon Library"/>
          </Grid>
        </TabItem>
      </TabControl>
    </StackPanel>
  </Grid>
</Page>
