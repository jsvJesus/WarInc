    <Grid x:Name="Vignette" Background="#FFFFFFFF" BlendingMode="Multiply" Opacity="0.099999994" d:IsLocked="True">
      <Grid.Effect>
        <noesis:VignetteEffect Size="1" Strength="32"/>
      </Grid.Effect>

    </Grid>
    <StackPanel x:Name="Infoverlay_HorizontalStack" Margin="32,32,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Orientation="Horizontal">
      <Component Source="Resources/MiniShowcases/Info_Info_Component.xaml" Height="{Binding Path=ActualHeight, ElementName=TabItem_Off}" Width="{Binding Path=ActualHeight, RelativeSource={RelativeSource Self}}" VerticalAlignment="Top" HorizontalAlignment="Left" d:IsLocked="True"/>
      <TabControl x:Name="Infoverlay_TabControl" Background="{x:Null}" Padding="0,0,0,0">
        <TabControl.MaxWidth>
          <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType={x:Type Page}}">
            <Binding.Converter>
              <noesis:MathConverter Expression="{}{0}/3"/>
            </Binding.Converter>
          </Binding>
        </TabControl.MaxWidth>
        <TabItem x:Name="TabItem_Off" Cursor="Hand" IsSelected="True" Template="{DynamicResource TabItem_Info_Template}" Header="{DynamicResource Info_Off_Geometry}">
          <Grid Background="#FFE5E5E5" d:IsHidden="True"/>
        </TabItem>
        <TabItem x:Name="TabItem_On" Cursor="Hand" Template="{DynamicResource TabItem_Info_Template}" Header="{DynamicResource Info_On_Geometry}">
          <Grid VerticalAlignment="Top" HorizontalAlignment="Left" d:IsLocked="True">
            <Component Source="Resources/MiniShowcases/Info_Overlay_ContentArea_Component.xaml" Text_Description_Str="Noesis offers the ability to easily transform Elements in 3D space for an added layer of visual expression. &#x0A; &#x0A;3D Transforms can be accessed by selecting an Element, navigating to its &apos;Transform&apos; Property sub-category, and opening the expander to reveal the &apos;3D Transform&apos; sub-section, from where a range of 3D Properties can be manipulated. &#x0A; &#x0A;Just like many Element Properties, the individual Properties that make up a 3D Transformation can also be animated directly in Noesis Studio to create rich, immersive interfaces. An example can be viewed by navigating to the Animation Panel [Ctrl+4], navigating to the &apos;Storyboard&apos; tab, and selecting &apos;Animation_Intro&apos;. " Text_Title_Str="3D Transformations"/>
          </Grid>
        </TabItem>
      </TabControl>
    </StackPanel>
  </Grid>
  <Page.Triggers>
    <EventTrigger RoutedEvent="Loaded">
      <BeginStoryboard x:Name="Animation_Intro_Begin" Storyboard="{StaticResource Animation_Intro}"/>
    </EventTrigger>
  </Page.Triggers>

</Page>
