<Page
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
  xmlns:noesis="clr-namespace:NoesisGUIExtensions"
  mc:Ignorable="d"
  d:DesignWidth="1920"
  d:DesignHeight="1080"
  Background="#FF4D5052">
  <b:Interaction.Triggers>
    <b:DataTrigger x:Name="IfPopUpOpen_BlurAndDarkenBackground" Value="True" Binding="{Binding Path=IsOpen, ElementName=Popup}">
      <b:GoToStateAction x:Name="Effects_On" TargetName="Master_Grid" StateName="BackgroundEffects_On"/>
    </b:DataTrigger>
    <b:DataTrigger x:Name="IfPopUpClosed_NoBackgroundEffects" Value="False" Binding="{Binding Path=IsOpen, ElementName=Popup}">
      <b:GoToStateAction x:Name="Effects_Off" TargetName="Master_Grid" StateName="BackgroundEffects_Off" UseTransitions="False"/>
    </b:DataTrigger>
  </b:Interaction.Triggers>
  <Page.Resources>
    <ResourceDictionary>
      <ControlTemplate x:Key="OpenCloseButton_ToggleButton" TargetType="ToggleButton">
        <Grid x:Name="Grid_Master" RenderTransformOrigin="0.5,0.5">
          <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="CommonStates">
              <VisualState x:Name="Normal"/>
              <VisualState x:Name="MouseOver">
                <Storyboard>
                  <ColorAnimationUsingKeyFrames Storyboard.TargetName="Frame_Border" Storyboard.TargetProperty="(Panel.Background).(GradientBrush.GradientStops)[1].(GradientStop.Color)">
                    <EasingColorKeyFrame Value="#FF534985" KeyTime="0:0:0.10">
                      <EasingColorKeyFrame.EasingFunction>
                        <CubicEase EasingMode="EaseIn"/>
                      </EasingColorKeyFrame.EasingFunction>
                    </EasingColorKeyFrame>
                  </ColorAnimationUsingKeyFrames>
                  <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Frame_Shadow_Border" Storyboard.TargetProperty="(UIElement.Opacity)">
                    <LinearDoubleKeyFrame KeyTime="0:0:0.10" Value="0.5"/>
                  </DoubleAnimationUsingKeyFrames>
                  <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Grid_Master" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)">
                    <LinearDoubleKeyFrame KeyTime="00:00:00.1000000" Value="1.02"/>
                  </DoubleAnimationUsingKeyFrames>
                  <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Grid_Master" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)">
                    <LinearDoubleKeyFrame KeyTime="00:00:00.1000000" Value="1.02"/>
                  </DoubleAnimationUsingKeyFrames>
                </Storyboard>
              </VisualState>
              <VisualState x:Name="Pressed"/>
              <VisualState x:Name="Disabled"/>
            </VisualStateGroup>
          </VisualStateManager.VisualStateGroups>
          <Grid.RenderTransform>
            <TransformGroup>
              <ScaleTransform/>
              <SkewTransform/>
              <RotateTransform/>
              <TranslateTransform/>
            </TransformGroup>
          </Grid.RenderTransform>
          <Border x:Name="Frame_Shadow_Border" Padding="16,16,16,16" Background="#FF000000" Opacity="0.25" Effect="{DynamicResource FrameDropShadow}" CornerRadius="26,26,26,26"/>
          <Border x:Name="Frame_Border" CornerRadius="24,24,24,24" Padding="16,16,16,16" BorderThickness="4,4,4,4">
            <Border.Background>
              <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                <GradientStop Offset="0" Color="#FF433B6B"/>
                <GradientStop Offset="1" Color="#FF433B6B"/>
              </LinearGradientBrush>
            </Border.Background>
            <Border.BorderBrush>
              <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                <GradientStop Color="#FF433B6B" Offset="1"/>
                <GradientStop Color="#FF534985" Offset="0"/>
              </LinearGradientBrush>
            </Border.BorderBrush>
            <TextBlock x:Name="Text_TextBlock" TextWrapping="Wrap" Text="{Binding Path=Content, RelativeSource={RelativeSource TemplatedParent}}" Margin="8,8,8,8" TextAlignment="Center" Effect="{DynamicResource ButtonTextDropShadow}" FontFamily="Resources/Popup/#Arial Rounded MT" FontSize="{Binding Path=FontSize, RelativeSource={RelativeSource TemplatedParent}}" Padding="{Binding Path=Padding, RelativeSource={RelativeSource TemplatedParent}}"/>
          </Border>
        </Grid>
        <ControlTemplate.Triggers>
          <Trigger Property="IsChecked" Value="True">
            <Setter TargetName="BackgroundBorder" Property="Background" Value="#FF4682B4"/>
          </Trigger>
          <Trigger Property="IsMouseOver" Value="True">
            <Setter TargetName="BackgroundBorder" Property="Background" Value="#FF778899"/>
          </Trigger>
          <Trigger Property="IsPressed" Value="True">
            <Setter TargetName="BackgroundBorder" Property="Background" Value="#FF708090"/>
          </Trigger>
        </ControlTemplate.Triggers>
      </ControlTemplate>
      <DropShadowEffect x:Key="FrameDropShadow" Color="#FF321B41" Direction="-90" BlurRadius="0" ShadowDepth="8"/>
      <DropShadowEffect x:Key="ButtonTextDropShadow" Color="#FF321B41" Direction="-90" BlurRadius="0" Opacity="0.66" ShadowDepth="6"/>
    </ResourceDictionary>
  </Page.Resources>
  <Grid x:Name="Master_Grid">
    <VisualStateManager.VisualStateGroups>
      <VisualStateGroup x:Name="BackgroundBlurStates">
        <VisualStateGroup.Transitions>
          <VisualTransition GeneratedDuration="00:00:00.2000000"/>
          <VisualTransition GeneratedDuration="00:00:01" To="BackgroundEffects_On">
            <Storyboard>
              <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Background_Darkener_Border" Storyboard.TargetProperty="(UIElement.Opacity)">
                <LinearDoubleKeyFrame KeyTime="0:0:0.075"/>
                <LinearDoubleKeyFrame KeyTime="0:0:0.150" Value="0.25"/>
              </DoubleAnimationUsingKeyFrames>
              <DoubleAnimationUsingKeyFrames Storyboard.TargetName="BackgroundImages_Grid" Storyboard.TargetProperty="(UIElement.Effect).(BlurEffect.Radius)">
                <LinearDoubleKeyFrame KeyTime="0:0:0.075"/>
                <LinearDoubleKeyFrame KeyTime="0:0:0.150" Value="32"/>
              </DoubleAnimationUsingKeyFrames>
              <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Popup_Grid" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)">
                <EasingDoubleKeyFrame Value="0.9" KeyTime="0:0:0">
                  <EasingDoubleKeyFrame.EasingFunction>
                    <SineEase EasingMode="EaseIn"/>
                  </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="0:0:0.075" Value="1.1">
                  <EasingDoubleKeyFrame.EasingFunction>
                    <SineEase EasingMode="EaseIn"/>
                  </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame Value="1" KeyTime="0:0:0.150">
                  <EasingDoubleKeyFrame.EasingFunction>
                    <SineEase EasingMode="EaseIn"/>
                  </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
              </DoubleAnimationUsingKeyFrames>
              <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Popup_Grid" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)">
                <EasingDoubleKeyFrame Value="0.9" KeyTime="0:0:0">
                  <EasingDoubleKeyFrame.EasingFunction>
                    <SineEase EasingMode="EaseIn"/>
                  </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="0:0:0.075" Value="1.1">
                  <EasingDoubleKeyFrame.EasingFunction>
                    <SineEase EasingMode="EaseIn"/>
                  </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame Value="1" KeyTime="0:0:0.150">
                  <EasingDoubleKeyFrame.EasingFunction>
                    <SineEase EasingMode="EaseIn"/>
                  </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
              </DoubleAnimationUsingKeyFrames>
            </Storyboard>
          </VisualTransition>
        </VisualStateGroup.Transitions>
        <VisualState x:Name="BackgroundEffects_Off">
          <Storyboard>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="BackgroundImages_Grid" Storyboard.TargetProperty="(UIElement.Effect).(BlurEffect.Radius)">
              <LinearDoubleKeyFrame KeyTime="00:00:00" Value="0"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Background_Darkener_Border" Storyboard.TargetProperty="(UIElement.Opacity)">
              <LinearDoubleKeyFrame KeyTime="00:00:00" Value="0"/>
            </DoubleAnimationUsingKeyFrames>
          </Storyboard>
        </VisualState>
        <VisualState x:Name="BackgroundEffects_On">
          <Storyboard>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="BackgroundImages_Grid" Storyboard.TargetProperty="(UIElement.Effect).(BlurEffect.Radius)">
              <EasingDoubleKeyFrame Value="32" KeyTime="0:0:0">
                <EasingDoubleKeyFrame.EasingFunction>
                  <CubicEase EasingMode="EaseIn"/>
                </EasingDoubleKeyFrame.EasingFunction>
              </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Background_Darkener_Border" Storyboard.TargetProperty="(UIElement.Opacity)">
              <EasingDoubleKeyFrame Value="0.25" KeyTime="0:0:0">
                <EasingDoubleKeyFrame.EasingFunction>
                  <CubicEase EasingMode="EaseIn"/>
                </EasingDoubleKeyFrame.EasingFunction>
              </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
          </Storyboard>
        </VisualState>
      </VisualStateGroup>
    </VisualStateManager.VisualStateGroups>
    <Grid x:Name="Background_Grid" Margin="0,0.096">
      <Border x:Name="BackgroundFill_Border" Background="#FF2F2852"/>
      <Grid x:Name="BackgroundImages_Grid">
        <Grid.Effect>
          <BlurEffect Radius="0"/>
        </Grid.Effect>
        <Image x:Name="Background_Top_Image" RenderTransformOrigin="0.5,0.5" Source="Resources/Popup/AquaticPlants.png">
          <Image.RenderTransform>
            <TransformGroup>
              <ScaleTransform ScaleY="{Binding Path=ScaleX, RelativeSource={RelativeSource Self}}" ScaleX="0.5"/>
              <SkewTransform/>
              <RotateTransform/>
              <TranslateTransform Y="-200"/>
            </TransformGroup>
          </Image.RenderTransform>
        </Image>
        <Image x:Name="Background_Bottom_Image" RenderTransformOrigin="0.5,0.5" Source="Resources/Popup/AquaticPlants.png">
          <Image.RenderTransform>
            <TransformGroup>
              <ScaleTransform ScaleY="{Binding Path=ScaleX, RelativeSource={RelativeSource Self}}" ScaleX="-0.5"/>
              <SkewTransform/>
              <RotateTransform/>
              <TranslateTransform Y="200"/>
            </TransformGroup>
          </Image.RenderTransform>
        </Image>
      </Grid>
      <Border x:Name="Background_Darkener_Border" Background="#FF000000" Opacity="0"/>
      <Image x:Name="BackgroundWaves_Image" RenderTransformOrigin="0.5,0.5" Stretch="UniformToFill" BlendingMode="Multiply" IsHitTestVisible="False" Source="Resources/Popup/WavePattern.png"/>
    </Grid>
    <ToggleButton x:Name="OpenButton_Toggle" Cursor="Hand" Template="{DynamicResource OpenCloseButton_ToggleButton}" IsChecked="{Binding Path=IsOpen, ElementName=Popup, Mode=TwoWay}" HorizontalAlignment="Center" VerticalAlignment="Center" Content="🗃️ OPEN POPUP" FontSize="96" Padding="0,0,8,0"/>
    <Popup x:Name="Popup" Placement="Center" AllowsTransparency="True" HasDropShadow="True" PlacementTarget="{Binding ElementName=OpenButton_Checkbox}" PopupAnimation="Slide">
      <Grid x:Name="Popup_Grid" Width="1024" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
        <Grid.RenderTransform>
          <TransformGroup>
            <ScaleTransform/>
            <SkewTransform/>
            <RotateTransform/>
            <TranslateTransform/>
          </TransformGroup>
        </Grid.RenderTransform>
        <Grid x:Name="Popup_Frame_Grid">
          <Border x:Name="Popup_FrameShadow_Border" Effect="{DynamicResource FrameDropShadow}" BorderThickness="4,4,4,4" BorderBrush="#FF000000" Background="#FF000000" Opacity="0.25" CornerRadius="26,26,26,26">
            <Border.Visibility>
              <Binding Path="HasDropShadow" RelativeSource="{RelativeSource AncestorType=TypeClass}">
                <Binding.Converter>
                  <BooleanToVisibilityConverter/>
                </Binding.Converter>
              </Binding>
            </Border.Visibility>
          </Border>
          <Border x:Name="Popup_Frame_Border" CornerRadius="16,16,16,16" BorderThickness="4,4,4,4">
            <Border.Background>
              <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                <GradientStop Offset="0" Color="#FF433B6B"/>
                <GradientStop Offset="1" Color="#FF282340"/>
              </LinearGradientBrush>
            </Border.Background>
            <Border.BorderBrush>
              <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                <GradientStop Color="#FF433B6B" Offset="1"/>
                <GradientStop Color="#FF534985" Offset="0"/>
              </LinearGradientBrush>
            </Border.BorderBrush>
          </Border>
        </Grid>
        <StackPanel x:Name="PopupContent_StackPanel" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="32,32,32,32">
          <TextBlock x:Name="Popup_Title_TextBlock" TextAlignment="Center" Margin="0,0,0,32" Effect="{DynamicResource ButtonTextDropShadow}" FontSize="96" TextWrapping="Wrap" Text="POPUP" FontFamily="Resources/Popup/#Arial Rounded MT"/>
          <TextBlock x:Name="Popup_Description_TextBlock" TextAlignment="Center" Margin="0,0,0,32" FontSize="64" TextWrapping="Wrap" Text="Discover the Popup Element! 🪧" Effect="{DynamicResource ButtonTextDropShadow}" FontFamily="Resources/Popup/#Arial Rounded MT"/>
          <ToggleButton x:Name="Popup_CloseButton_Toggle" Cursor="Hand" Template="{DynamicResource OpenCloseButton_ToggleButton}" Content="CLOSE" Margin="0,16,0,16" IsChecked="{Binding Path=IsOpen, ElementName=Popup, Mode=TwoWay}" FontSize="64" Padding="0,0,0,0"/>
        </StackPanel>
      </Grid>
    </Popup>
    <StackPanel x:Name="Infoverlay_HorizontalStack" Margin="32,32,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Orientation="Horizontal">
      <Component Source="Resources/MiniShowcases/Info_Info_Component.xaml" Height="{Binding Path=ActualHeight, ElementName=TabItem_Off}" Width="{Binding Path=ActualHeight, RelativeSource={RelativeSource Self}}" VerticalAlignment="Top" HorizontalAlignment="Left" d:IsLocked="True"/>
      <TabControl x:Name="Infoverlay_TabControl" Background="{x:Null}" Padding="0,0,0,0">
        <TabControl.MaxWidth>
          <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType={x:Type Page}}">
            <Binding.Converter>
              <noesis:MathConverter Expression="{}{0}/3"/>
            </Binding.Converter>
          </Binding>
        </TabControl.MaxWidth>
        <TabItem x:Name="TabItem_Off" Cursor="Hand" IsSelected="True" Template="{DynamicResource TabItem_Info_Template}" Header="{DynamicResource Info_Off_Geometry}">
          <Grid Background="#FFE5E5E5" d:IsHidden="True"/>
        </TabItem>
        <TabItem x:Name="TabItem_On" Cursor="Hand" Template="{DynamicResource TabItem_Info_Template}" Header="{DynamicResource Info_On_Geometry}">
          <Grid VerticalAlignment="Top" HorizontalAlignment="Left">
            <Component Source="Resources/MiniShowcases/Info_Overlay_ContentArea_Component.xaml" Text_Title_Str="Popups" Text_Description_Str="Noesis offers a ready-made Popup Element that contains all of the functionality required to create efficient, easy-to-invoke overlays. &#x0A; &#x0A;Any collection of sub-Elements can be placed within a Popup Element, from where they inherit the functional features of the Popup in which they&apos;re placed. This includes instant revealing and concealment of the Element and all of its children via the Popup&apos;s &apos;Open&apos; Property. &#x0A; &#x0A;In this sample, an &apos;open&apos; and a &apos;close&apos; button, are bound to the Popup&apos;s &apos;Open&apos; Property. &#x0A; &#x0A;When the &apos;open&apos; button is pressed, the Popup&apos;s &apos;Open&apos; Property is set to &apos;True&apos;, revealing the Popup. Conversely, when the &apos;close&apos; button is pressed, the Popup&apos;s &apos;Open&apos; Property is set to &apos;False&apos;, and thus, conceals the Popup and its contents. &#x0A; &#x0A;The Popup Element also includes a slew of Properties that serve to define its presentation, and positioning. &#x0A; &#x0A;Using the &apos;Placement Target&apos; Property, the Popup is able to render in a position relative to any Element on the Page, or, relative to the position of the mouse cursor at the moment the Popup is opened. &#x0A; &#x0A;In this example, using the &apos;Center&apos; value for the &apos;Placement&apos; Property, the Popup is set to be centered to its &apos;Placement Target&apos; (in this case, the button used to open it). &#x0A; &#x0A;This Popup also showcases a usage of the &apos;Slide&apos; transition animation, one of the Popup&apos;s animation presets which when selected, play every time to Popup&apos;s &apos;Open&apos; Property is set to &apos;True&apos; and the Popup is revealed." d:IsLocked="True"/>
          </Grid>
        </TabItem>
      </TabControl>
    </StackPanel>
  </Grid>
</Page>
