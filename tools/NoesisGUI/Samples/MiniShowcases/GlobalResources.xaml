  <ControlTemplate TargetType="TabItem" x:Key="TabItem_Info_Template">
    <Border x:Name="TabBorder" BorderBrush="#00FFFFFF">
      <Border.Background>
        <SolidColorBrush Color="{DynamicResource Info_Color_Background_Highlight}"/>
      </Border.Background>
      <Grid>
        <Border BorderThickness="0,2,0,2">
          <Border.BorderBrush>
            <SolidColorBrush Color="{DynamicResource Info_Color_Background}"/>
          </Border.BorderBrush>
        </Border>
        <Grid x:Name="Highlight" VerticalAlignment="Top" Height="2" Visibility="Hidden" Margin="0,-2,0,0">
          <Grid.Background>
            <SolidColorBrush Color="{DynamicResource Info_Color_Accent}"/>
          </Grid.Background>
        </Grid>
        <TextBlock x:Name="Label_TextBlock" TextWrapping="Wrap" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="8,8,8,8" Visibility="Hidden" Text="XXX" FontFamily="Resources/MiniShowcases/#PT Root UI"/>
        <Path x:Name="Icon" Data="{Binding Path=Header, RelativeSource={RelativeSource TemplatedParent}}" Stretch="Uniform" Width="{Binding Path=ActualHeight, ElementName=Label_TextBlock}" VerticalAlignment="Center" HorizontalAlignment="Center">
          <Path.Fill>
            <SolidColorBrush Color="{DynamicResource Info_Color_Foreground}"/>
          </Path.Fill>
        </Path>
      </Grid>
    </Border>
    <ControlTemplate.Triggers>
      <Trigger Property="IsMouseOver" Value="True">
        <Setter Property="Panel.ZIndex" Value="1"/>
        <Setter TargetName="TabBorder" Property="Background">
          <Setter.Value>
            <SolidColorBrush Color="{DynamicResource Info_Color_Background}"/>
          </Setter.Value>
        </Setter>
      </Trigger>
      <Trigger Property="IsSelected" Value="True">
        <Setter Property="Panel.ZIndex" Value="2"/>
        <Setter TargetName="Highlight" Property="Visibility" Value="Visible"/>
        <Setter TargetName="TabBorder" Property="Background">
          <Setter.Value>
            <SolidColorBrush Color="{DynamicResource Info_Color_Background}"/>
          </Setter.Value>
        </Setter>
      </Trigger>
    </ControlTemplate.Triggers>
  </ControlTemplate>

