
sampler ScreenTex	: register (s0);
sampler G_Aux 		: register (s1);

float4 BW  = { 0.3f, 0.59f, 0.11f, 1.0f};


float4 main ( float2 Tex : TEXCOORD0  ) : COLOR
{
	float3 d = tex2D(ScreenTex, Tex).rgb;
	float selfIllum = saturate(tex2D(G_Aux, Tex).a*2-1);

	return float4(d*selfIllum*2, 1);
}

