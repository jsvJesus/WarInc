<UserControl
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Width="1920"
    Height="1080"
    Background="#FF000000"
    d:DesignWidth="1920"
    d:DesignHeight="1080">

    <UserControl.Resources>

        <Storyboard x:Key="BackgroundLoop">
            <DoubleAnimationUsingKeyFrames
                Storyboard.TargetName="BackgroundMap"
                Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                RepeatBehavior="Forever"
                AutoReverse="True">
                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="1.06"/>
                <EasingDoubleKeyFrame KeyTime="0:0:18" Value="1.14">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <SineEase EasingMode="EaseInOut"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>

            <DoubleAnimationUsingKeyFrames
                Storyboard.TargetName="BackgroundMap"
                Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                RepeatBehavior="Forever"
                AutoReverse="True">
                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="1.06"/>
                <EasingDoubleKeyFrame KeyTime="0:0:18" Value="1.14">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <SineEase EasingMode="EaseInOut"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>

            <DoubleAnimationUsingKeyFrames
                Storyboard.TargetName="BackgroundMap"
                Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[3].(TranslateTransform.X)"
                RepeatBehavior="Forever"
                AutoReverse="True">
                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="-18"/>
                <EasingDoubleKeyFrame KeyTime="0:0:22" Value="18">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <SineEase EasingMode="EaseInOut"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>

            <DoubleAnimationUsingKeyFrames
                Storyboard.TargetName="BackgroundMap"
                Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[3].(TranslateTransform.Y)"
                RepeatBehavior="Forever"
                AutoReverse="True">
                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="-10"/>
                <EasingDoubleKeyFrame KeyTime="0:0:26" Value="14">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <SineEase EasingMode="EaseInOut"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>

        <Storyboard x:Key="Intro">
            <DoubleAnimationUsingKeyFrames
                Storyboard.TargetName="Dialog"
                Storyboard.TargetProperty="Opacity">
                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="0"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.35" Value="1">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <CubicEase EasingMode="EaseOut"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>

            <DoubleAnimationUsingKeyFrames
                Storyboard.TargetName="Dialog"
                Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)">
                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="0.94"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.35" Value="1">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <BackEase EasingMode="EaseOut" Amplitude="0.25"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>

            <DoubleAnimationUsingKeyFrames
                Storyboard.TargetName="Dialog"
                Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)">
                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="0.94"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.35" Value="1">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <BackEase EasingMode="EaseOut" Amplitude="0.25"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>

        <SolidColorBrush x:Key="TextMain" Color="#FFF2F5F8"/>
        <SolidColorBrush x:Key="TextMuted" Color="#FF8E9AA8"/>
        <SolidColorBrush x:Key="AccentRed" Color="#FFE0352D"/>
        <SolidColorBrush x:Key="AccentOrange" Color="#FFFF8A2A"/>

        <LinearGradientBrush x:Key="PanelBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#EE111820" Offset="0"/>
            <GradientStop Color="#DD070A0E" Offset="0.58"/>
            <GradientStop Color="#F0000000" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="ButtonBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FF2A333D" Offset="0"/>
            <GradientStop Color="#FF111820" Offset="0.45"/>
            <GradientStop Color="#FF06080B" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="ButtonHoverBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FF3C4652" Offset="0"/>
            <GradientStop Color="#FF281618" Offset="0.5"/>
            <GradientStop Color="#FF090607" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="PlayButtonBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFE64A34" Offset="0"/>
            <GradientStop Color="#FF8F1B16" Offset="0.55"/>
            <GradientStop Color="#FF260707" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="PlayButtonHoverBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFFF7750" Offset="0"/>
            <GradientStop Color="#FFC72C22" Offset="0.55"/>
            <GradientStop Color="#FF3B0908" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Width" Value="360"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="Margin" Value="0,7,0,7"/>
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="FontFamily" Value="Verdana"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Background" Value="{StaticResource ButtonBrush}"/>
            <Setter Property="BorderBrush" Value="#FF45505C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4">

                            <Grid>
                                <Border
                                    Height="16"
                                    VerticalAlignment="Top"
                                    CornerRadius="4"
                                    Opacity="0.35">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#FFFFFFFF" Offset="0"/>
                                            <GradientStop Color="#00FFFFFF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>

                                <Rectangle
                                    Height="1"
                                    VerticalAlignment="Top"
                                    Fill="#88FFFFFF"
                                    Margin="1,1,1,0"/>

                                <ContentPresenter
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource ButtonHoverBrush}"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#FFFF3B2F"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FF080A0D"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#FFFFFFFF"/>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PlayButton" TargetType="Button" BasedOn="{StaticResource MenuButton}">
            <Setter Property="Width" Value="360"/>
            <Setter Property="Height" Value="58"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Background" Value="{StaticResource PlayButtonBrush}"/>
            <Setter Property="BorderBrush" Value="#FFFF8A2A"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="5">

                            <Grid>
                                <Border
                                    Height="20"
                                    VerticalAlignment="Top"
                                    CornerRadius="5"
                                    Opacity="0.38">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#FFFFFFFF" Offset="0"/>
                                            <GradientStop Color="#00FFFFFF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>

                                <Rectangle
                                    Height="1"
                                    VerticalAlignment="Top"
                                    Fill="#AAFFFFFF"
                                    Margin="1,1,1,0"/>

                                <ContentPresenter
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource PlayButtonHoverBrush}"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#FFFFFFFF"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FF3B0908"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#FFFFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ExitButton" TargetType="Button" BasedOn="{StaticResource MenuButton}">
            <Setter Property="Foreground" Value="#FFC9D0D8"/>
            <Setter Property="BorderBrush" Value="#FF333A44"/>
            <Setter Property="Background" Value="#CC05070A"/>
        </Style>

    </UserControl.Resources>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
            <BeginStoryboard Storyboard="{StaticResource BackgroundLoop}"/>
        </EventTrigger>

        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
            <BeginStoryboard Storyboard="{StaticResource Intro}"/>
        </EventTrigger>
    </UserControl.Triggers>

    <Grid Background="#FF000000">

        <Grid ClipToBounds="True">
            <Grid
                x:Name="BackgroundMap"
                RenderTransformOrigin="0.5,0.5">

                <Grid.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleX="1.08" ScaleY="1.08"/>
                        <SkewTransform/>
                        <RotateTransform Angle="0"/>
                        <TranslateTransform X="0" Y="0"/>
                    </TransformGroup>
                </Grid.RenderTransform>

                <Grid.Background>
                    <ImageBrush Stretch="UniformToFill" ImageSource="Assets/Background.png"/>
                </Grid.Background>
            </Grid>
        </Grid>

        <Grid
            x:Name="Dialog"
            Width="520"
            Height="720"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Opacity="0"
            RenderTransformOrigin="0.5,0.5">

            <Grid.RenderTransform>
                <TransformGroup>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                    <SkewTransform/>
                    <RotateTransform/>
                    <TranslateTransform/>
                </TransformGroup>
            </Grid.RenderTransform>

            <Border
                Margin="20,26,20,12"
                Background="#AA000000"
                CornerRadius="18"
                Opacity="0.55"/>

            <Border
                Margin="0,0,0,18"
                Background="{StaticResource PanelBrush}"
                BorderBrush="#663B4654"
                BorderThickness="1"
                CornerRadius="18">

                <Grid>
                    <Rectangle
                        Height="1"
                        VerticalAlignment="Top"
                        Fill="#55FFFFFF" StrokeLineJoin="Bevel"
                        Margin="22,1,22,0"/>

                    <Rectangle
                        Height="90"
                        VerticalAlignment="Top"
                        Opacity="0.42" StrokeLineJoin="Bevel">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#44FFFFFF" Offset="0"/>
                                <GradientStop Color="#00FFFFFF" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>

                    <Rectangle
                        Width="3"
                        HorizontalAlignment="Left"
                        Margin="0,28,0,28" Fill="#FF127500" StrokeLineJoin="Bevel"/>

                    <StackPanel Margin="54,46,54,42">

                        <TextBlock
                            Text="WAR INC"
                            Foreground="{StaticResource TextMain}"
                            FontFamily="Verdana"
                            FontSize="34"
                            FontWeight="Bold"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,4"/>

                        <TextBlock
                            Foreground="{StaticResource TextMuted}"
                            FontFamily="Verdana"
                            FontSize="13"
                            FontWeight="Bold" Text="By zsv Jesus" HorizontalAlignment="Center"
                            Margin="0,0,0,34"/>

                        <Button
                            x:Name="BtnPlayGame"
                            Style="{StaticResource PlayButton}"
                            Content="PLAY GAME"
                            Margin="0,0,0,22"/>

                        <TextBlock
                            Text="EDITORS"
                            Foreground="#FF6F7A88"
                            FontFamily="Verdana"
                            FontSize="11"
                            FontWeight="Bold"
                            Margin="0,0,0,8" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                        <Button
                            x:Name="BtnLevelEditor"
                            Style="{StaticResource MenuButton}"
                            Content="LEVEL EDITOR"/>

                        <Button
                            x:Name="BtnParticleEditor"
                            Style="{StaticResource MenuButton}"
                            Content="PARTICLE EDITOR"/>

                        <Button
                            x:Name="BtnPhysicsEditor"
                            Style="{StaticResource MenuButton}"
                            Content="PHYSICS EDITOR"/>

                        <Button
                            x:Name="BtnCharacterEditor"
                            Style="{StaticResource MenuButton}"
                            Content="CHARACTER EDITOR"/>

                        <Rectangle Height="1" Fill="#223B4654" Margin="0,22,0,14"/>

                        <Button
                            x:Name="BtnExit"
                            Style="{StaticResource ExitButton}"
                            Content="EXIT"/>

                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <TextBlock
            Text="WarInc / Studio"
            Foreground="#554F5966"
            FontFamily="Verdana"
            FontSize="12"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Margin="0,0,32,26"/>

    </Grid>
</UserControl>