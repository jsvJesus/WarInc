<UserControl
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:noesis="clr-namespace:NoesisGUIExtensions;assembly=Noesis.GUI.Extensions"
    mc:Ignorable="d"
    Background="#FF000000"
    d:DesignWidth="1920"
    d:DesignHeight="1080">

    <UserControl.Resources>

        <SolidColorBrush x:Key="TextWhite" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="TextBlue" Color="#FF2AA6E2"/>
        <SolidColorBrush x:Key="TextBlueDark" Color="#FF488EB5"/>

        <LinearGradientBrush x:Key="StudioBg" StartPoint="0.5,0" EndPoint="0.5,1">
            <GradientStop Offset="0" Color="#FF184C79"/>
            <GradientStop Offset="0.05" Color="#FF1B5688"/>
            <GradientStop Offset="1" Color="#FF071A2A"/>
        </LinearGradientBrush>

        <Storyboard x:Key="Intro">

            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="TitleHost" Storyboard.TargetProperty="Opacity">
                <DiscreteDoubleKeyFrame KeyTime="0" Value="0"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.35" Value="1"/>
            </DoubleAnimationUsingKeyFrames>

            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ButtonsHost" Storyboard.TargetProperty="Opacity">
                <DiscreteDoubleKeyFrame KeyTime="0" Value="0"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.20" Value="0"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.75" Value="1"/>
            </DoubleAnimationUsingKeyFrames>

            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ButtonsHostTransform" Storyboard.TargetProperty="X">
                <DiscreteDoubleKeyFrame KeyTime="0" Value="-90"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.75" Value="0">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <CircleEase EasingMode="EaseOut"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>

            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="VideoMain" Storyboard.TargetProperty="Opacity" RepeatBehavior="Forever">
                <DiscreteDoubleKeyFrame KeyTime="0" Value="0.30"/>
                <EasingDoubleKeyFrame KeyTime="0:0:3" Value="0.42"/>
                <EasingDoubleKeyFrame KeyTime="0:0:6" Value="0.30"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:8" Value="0.30"/>
            </DoubleAnimationUsingKeyFrames>

            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="VideoGhostA" Storyboard.TargetProperty="Opacity" RepeatBehavior="Forever">
                <DiscreteDoubleKeyFrame KeyTime="0" Value="0.06"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.12" Value="0.22"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.24" Value="0.05"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:3.00" Value="0.05"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:3.15" Value="0.18"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:3.30" Value="0.06"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:6.00" Value="0.06"/>
            </DoubleAnimationUsingKeyFrames>

            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="VideoGhostB" Storyboard.TargetProperty="Opacity" RepeatBehavior="Forever">
                <DiscreteDoubleKeyFrame KeyTime="0" Value="0.05"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.18" Value="0.18"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.30" Value="0.04"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:4.10" Value="0.04"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:4.25" Value="0.16"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:4.40" Value="0.05"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:7.00" Value="0.05"/>
            </DoubleAnimationUsingKeyFrames>

            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="VideoGhostATransform" Storyboard.TargetProperty="X" RepeatBehavior="Forever">
                <DiscreteDoubleKeyFrame KeyTime="0" Value="-10"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.12" Value="-34"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.24" Value="-8"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:3.15" Value="-28"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:3.30" Value="-10"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:6.00" Value="-10"/>
            </DoubleAnimationUsingKeyFrames>

            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="VideoGhostBTransform" Storyboard.TargetProperty="X" RepeatBehavior="Forever">
                <DiscreteDoubleKeyFrame KeyTime="0" Value="10"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.18" Value="30"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.30" Value="8"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:4.25" Value="34"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:4.40" Value="10"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:7.00" Value="10"/>
            </DoubleAnimationUsingKeyFrames>

            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="GlitchSweepTransform" Storyboard.TargetProperty="X" RepeatBehavior="Forever">
                <DiscreteDoubleKeyFrame KeyTime="0" Value="-2200"/>
                <EasingDoubleKeyFrame KeyTime="0:0:3.2" Value="2200">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <CubicEase EasingMode="EaseInOut"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <DiscreteDoubleKeyFrame KeyTime="0:0:5.0" Value="-2200"/>
            </DoubleAnimationUsingKeyFrames>

            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="GlitchSweep" Storyboard.TargetProperty="Opacity" RepeatBehavior="Forever">
                <DiscreteDoubleKeyFrame KeyTime="0" Value="0"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.8" Value="0.24"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:1.0" Value="0"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:3.2" Value="0"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:3.35" Value="0.20"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:3.55" Value="0"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:5.0" Value="0"/>
            </DoubleAnimationUsingKeyFrames>

            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="PixelLayer" Storyboard.TargetProperty="Opacity" RepeatBehavior="Forever">
                <DiscreteDoubleKeyFrame KeyTime="0" Value="0"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:2.8" Value="0"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:3.0" Value="0.20"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:3.2" Value="0"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:7.0" Value="0"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:7.15" Value="0.16"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:7.35" Value="0"/>
            </DoubleAnimationUsingKeyFrames>

            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="PixelLayer" Storyboard.TargetProperty="Effect.Size" RepeatBehavior="Forever">
                <DiscreteDoubleKeyFrame KeyTime="0" Value="0.001"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:2.8" Value="0.001"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:3.0" Value="5"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:3.2" Value="0.001"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:7.0" Value="0.001"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:7.15" Value="4"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:7.35" Value="0.001"/>
            </DoubleAnimationUsingKeyFrames>

            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="BlurLayer" Storyboard.TargetProperty="Opacity" RepeatBehavior="Forever">
                <DiscreteDoubleKeyFrame KeyTime="0" Value="0.10"/>
                <EasingDoubleKeyFrame KeyTime="0:0:2.0" Value="0.18"/>
                <EasingDoubleKeyFrame KeyTime="0:0:4.0" Value="0.08"/>
                <EasingDoubleKeyFrame KeyTime="0:0:6.0" Value="0.15"/>
                <EasingDoubleKeyFrame KeyTime="0:0:8.0" Value="0.10"/>
            </DoubleAnimationUsingKeyFrames>

            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="BlurLayer" Storyboard.TargetProperty="Effect.Radius" RepeatBehavior="Forever">
                <DiscreteDoubleKeyFrame KeyTime="0" Value="2"/>
                <EasingDoubleKeyFrame KeyTime="0:0:2.0" Value="9"/>
                <EasingDoubleKeyFrame KeyTime="0:0:4.0" Value="3"/>
                <EasingDoubleKeyFrame KeyTime="0:0:6.0" Value="7"/>
                <EasingDoubleKeyFrame KeyTime="0:0:8.0" Value="2"/>
            </DoubleAnimationUsingKeyFrames>

        </Storyboard>

        <Style x:Key="StudioButton" TargetType="Button">
            <Setter Property="Width" Value="720"/>
            <Setter Property="Height" Value="64"/>
            <Setter Property="Margin" Value="0,9,0,9"/>
            <Setter Property="Foreground" Value="{StaticResource TextBlueDark}"/>
            <Setter Property="FontFamily" Value="Verdana"/>
            <Setter Property="FontSize" Value="31"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Background" Value="#7710334D"/>
            <Setter Property="BorderBrush" Value="#551F4A6F"/>
            <Setter Property="BorderThickness" Value="3"/>
            <Setter Property="Cursor" Value="Hand">

            </Setter>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border
                                x:Name="ButtonBg"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Opacity="0.92"/>

                            <Border
                                Margin="8,7,64,7"
                                BorderBrush="#552AA6E2"
                                BorderThickness="2"
                                Opacity="0.65"/>

                            <Rectangle
                                x:Name="LeftLine"
                                HorizontalAlignment="Left"
                                Width="8"
                                Margin="10,10,0,10"
                                Fill="#442AA6E2"/>

                            <Border
                                x:Name="ArrowBox"
                                Width="62"
                                HorizontalAlignment="Right"
                                BorderBrush="#6639A8E8"
                                BorderThickness="2"
                                Background="#2210334D">

                                <TextBlock
                                    Text=">"
                                    Foreground="#88488EB5"
                                    FontFamily="Verdana"
                                    FontSize="42"
                                    FontWeight="Bold"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Margin="0,-5,0,0"/>
                            </Border>

                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"/>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBg" Property="Background" Value="#DD104B72"/>
                                <Setter TargetName="ButtonBg" Property="BorderBrush" Value="#FF39A8E8"/>
                                <Setter TargetName="LeftLine" Property="Fill" Value="#FF2AA6E2"/>
                                <Setter TargetName="ArrowBox" Property="Background" Value="#55104B72"/>
                                <Setter Property="Foreground" Value="#FFFFFFFF"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBg" Property="Background" Value="#FF082236"/>
                                <Setter TargetName="ButtonBg" Property="BorderBrush" Value="#FFFFFFFF"/>
                                <Setter Property="Foreground" Value="#FFBFEFFF"/>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StudioButtonActive" TargetType="Button" BasedOn="{StaticResource StudioButton}">
            <Setter Property="Foreground" Value="{StaticResource TextWhite}"/>
            <Setter Property="Background" Value="#DD104B72"/>
            <Setter Property="BorderBrush" Value="#FF39A8E8"/>
        </Style>

    </UserControl.Resources>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
            <BeginStoryboard Storyboard="{StaticResource Intro}"/>
        </EventTrigger>
    </UserControl.Triggers>

    <Grid Background="{StaticResource StudioBg}" ClipToBounds="True">

        <Image
            Source="Assets/Background.png"
            Stretch="UniformToFill"
            IsHitTestVisible="False"
            Opacity="0.90"/>

        <MediaElement
            x:Name="VideoMain"
            Source="Assets/Video_Smoke_Splash.mp4"
            Stretch="UniformToFill"
            LoadedBehavior="Play"
            UnloadedBehavior="Close"
            IsMuted="True"
            Volume="0"
            ScrubbingEnabled="True"
            IsHitTestVisible="False"
            Opacity="0.34">

            <b:Interaction.Triggers>
                <b:EventTrigger EventName="Loaded">
                    <noesis:PlayMediaAction/>
                </b:EventTrigger>
            </b:Interaction.Triggers>
        </MediaElement>

        <MediaElement
            x:Name="VideoGhostA"
            Source="Assets/Video_Smoke_Splash.mp4"
            Stretch="UniformToFill"
            LoadedBehavior="Play"
            UnloadedBehavior="Close"
            IsMuted="True"
            Volume="0"
            ScrubbingEnabled="True"
            IsHitTestVisible="False"
            Opacity="0.06">
            <MediaElement.RenderTransform>
                <TranslateTransform x:Name="VideoGhostATransform" X="-10" Y="0"/>
            </MediaElement.RenderTransform>
        </MediaElement>

        <MediaElement
            x:Name="VideoGhostB"
            Source="Assets/Video_Smoke_Splash.mp4"
            Stretch="UniformToFill"
            LoadedBehavior="Play"
            UnloadedBehavior="Close"
            IsMuted="True"
            Volume="0"
            ScrubbingEnabled="True"
            IsHitTestVisible="False"
            Opacity="0.05">
            <MediaElement.RenderTransform>
                <TranslateTransform x:Name="VideoGhostBTransform" X="10" Y="0"/>
            </MediaElement.RenderTransform>
        </MediaElement>

        <Grid
            x:Name="BlurLayer"
            IsHitTestVisible="False"
            Opacity="0.10">
            <Grid.Effect>
                <noesis:DirectionalBlurEffect Radius="2" Angle="0"/>
            </Grid.Effect>

            <Image
                Source="Assets/Background.png"
                Stretch="UniformToFill"
                Opacity="0.50"/>

            <Rectangle Fill="#330B6FA4"/>
        </Grid>

        <Grid
            x:Name="PixelLayer"
            IsHitTestVisible="False"
            Opacity="0">
            <Grid.Effect>
                <noesis:PixelateEffect Size="0.001"/>
            </Grid.Effect>

            <Image
                Source="Assets/Background.png"
                Stretch="UniformToFill"
                Opacity="0.70"/>

            <Rectangle Fill="#3300AEEF"/>
        </Grid>

        <Rectangle Fill="#66020A12"/>

        <Rectangle
            x:Name="GlitchSweep"
            Width="620"
            HorizontalAlignment="Left"
            Opacity="0"
            IsHitTestVisible="False">
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#00104B72" Offset="0"/>
                    <GradientStop Color="#5539A8E8" Offset="0.45"/>
                    <GradientStop Color="#AAFFFFFF" Offset="0.50"/>
                    <GradientStop Color="#5539A8E8" Offset="0.55"/>
                    <GradientStop Color="#00104B72" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
            <Rectangle.RenderTransform>
                <TranslateTransform x:Name="GlitchSweepTransform" X="-2200"/>
            </Rectangle.RenderTransform>
        </Rectangle>

        <Canvas Opacity="0.15" IsHitTestVisible="False">
            <Rectangle Canvas.Top="60" Width="1920" Height="2" Fill="#FF39A8E8"/>
            <Rectangle Canvas.Top="140" Width="1920" Height="1" Fill="#AA39A8E8"/>
            <Rectangle Canvas.Top="230" Width="1920" Height="2" Fill="#8839A8E8"/>
            <Rectangle Canvas.Top="360" Width="1920" Height="1" Fill="#AAFFFFFF"/>
            <Rectangle Canvas.Top="520" Width="1920" Height="2" Fill="#6639A8E8"/>
            <Rectangle Canvas.Top="690" Width="1920" Height="1" Fill="#AA39A8E8"/>
            <Rectangle Canvas.Top="840" Width="1920" Height="2" Fill="#7739A8E8"/>
            <Rectangle Canvas.Top="1010" Width="1920" Height="1" Fill="#AAFFFFFF"/>
        </Canvas>

        <Rectangle Opacity="0.44">
            <Rectangle.Fill>
                <RadialGradientBrush Center="0.5,0.42" GradientOrigin="0.5,0.42" RadiusX="0.85" RadiusY="0.85">
                    <GradientStop Color="#001B5688" Offset="0"/>
                    <GradientStop Color="#55123A5C" Offset="0.55"/>
                    <GradientStop Color="#EE061522" Offset="1"/>
                </RadialGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Grid
            Width="980"
            Height="790"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">

            <Grid.RowDefinitions>
                <RowDefinition Height="210"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel
                x:Name="TitleHost"
                Grid.Row="0"
                Orientation="Horizontal"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Opacity="0">

                <Grid Width="96" Height="96" Margin="0,0,28,0">
                    <Image Source="Assets/WarIncBattleZoneIcon.png" Stretch="Uniform"/>
                </Grid>

                <TextBlock
                    Text="ECLIPSE"
                    Foreground="{StaticResource TextWhite}"
                    FontFamily="Verdana"
                    FontSize="64"
                    FontWeight="Bold"
                    VerticalAlignment="Center"/>

                <TextBlock
                    Text="STUDIO"
                    Foreground="{StaticResource TextBlue}"
                    FontFamily="Verdana"
                    FontSize="64"
                    FontWeight="Bold"
                    VerticalAlignment="Center"
                    Margin="18,0,0,0"/>
            </StackPanel>

            <StackPanel
                x:Name="ButtonsHost"
                Grid.Row="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Opacity="0">

                <StackPanel.RenderTransform>
                    <TranslateTransform x:Name="ButtonsHostTransform" X="-90"/>
                </StackPanel.RenderTransform>

                <Button
                    x:Name="BtnPlayGame"
                    Style="{StaticResource StudioButtonActive}"
                    Content="PLAY GAME"/>

                <Button
                    x:Name="BtnLevelEditor"
                    Style="{StaticResource StudioButton}"
                    Content="LEVEL EDITOR"/>

                <Button
                    x:Name="BtnParticleEditor"
                    Style="{StaticResource StudioButton}"
                    Content="PARTICLE EDITOR"/>

                <Button
                    x:Name="BtnPhysicsEditor"
                    Style="{StaticResource StudioButton}"
                    Content="PHYSICS EDITOR"/>

                <Button
                    x:Name="BtnCharacterEditor"
                    Style="{StaticResource StudioButton}"
                    Content="CHARACTER EDITOR"/>

                <Button
                    x:Name="BtnExit"
                    Style="{StaticResource StudioButton}"
                    Content="EXIT"/>

            </StackPanel>
        </Grid>
    </Grid>
</UserControl>