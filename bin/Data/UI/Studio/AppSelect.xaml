<UserControl
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#FF000000"
    d:DesignWidth="1920"
    d:DesignHeight="1080">

    <UserControl.Resources>

        <SolidColorBrush x:Key="TextWhite" Color="#FFF2F7FC"/>
        <SolidColorBrush x:Key="TextBlue" Color="#FF39A8E8"/>
        <SolidColorBrush x:Key="TextBlueMuted" Color="#FF5B9BC4"/>

        <LinearGradientBrush x:Key="ButtonBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#5510334D" Offset="0"/>
            <GradientStop Color="#DD0B304B" Offset="0.55"/>
            <GradientStop Color="#99143D5A" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="ButtonHoverBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#9916466A" Offset="0"/>
            <GradientStop Color="#FF104B72" Offset="0.55"/>
            <GradientStop Color="#DD1D75A5" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Width" Value="720"/>
            <Setter Property="Height" Value="62"/>
            <Setter Property="Margin" Value="0,9,0,9"/>
            <Setter Property="Foreground" Value="{StaticResource TextBlueMuted}"/>
            <Setter Property="FontFamily" Value="Verdana"/>
            <Setter Property="FontSize" Value="31"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Background" Value="{StaticResource ButtonBrush}"/>
            <Setter Property="BorderBrush" Value="#0039A8E8"/>
            <Setter Property="BorderThickness" Value="3"/>
            <Setter Property="Cursor" Value="Hand"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="#3310334D"
                            BorderThickness="4">

                            <Grid>

                                <Border
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Margin="12,7,62,7"
                                    Background="Transparent"/>

                                <Border
                                    Width="70"
                                    HorizontalAlignment="Right"
                                    Background="#2210334D"
                                    BorderBrush="#6639A8E8"
                                    BorderThickness="3">

                                    <TextBlock
                                        Text=">"
                                        Foreground="#805B9BC4"
                                        FontFamily="Verdana"
                                        FontSize="48"
                                        FontWeight="Bold"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Margin="0,-7,0,0"/>
                                </Border>

                                <ContentPresenter
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>

                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource ButtonHoverBrush}"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#FF39A8E8"/>
                                <Setter Property="Foreground" Value="{StaticResource TextWhite}"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FF082236"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#FFFFFFFF"/>
                                <Setter Property="Foreground" Value="#FFBFEFFF"/>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.35"/>
                                <Setter Property="Foreground" Value="#FF2A526A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PlayButton" TargetType="Button" BasedOn="{StaticResource MenuButton}">
            <Setter Property="Foreground" Value="{StaticResource TextWhite}"/>
            <Setter Property="Background" Value="{StaticResource ButtonHoverBrush}"/>
            <Setter Property="BorderBrush" Value="#FF39A8E8"/>
            <Setter Property="FontSize" Value="34"/>
        </Style>

    </UserControl.Resources>

    <Grid Background="#FF000000" ClipToBounds="True">

        <Image
            Source="Assets/Background.png"
            Stretch="UniformToFill"
            IsHitTestVisible="False"/>

        <MediaElement
            x:Name="SmokeVideo"
            Source="Assets/Video_Smoke_Splash.mp4"
            Stretch="UniformToFill"
            LoadedBehavior="Play"
            UnloadedBehavior="Close"
            IsMuted="True"
            Volume="0"
            ScrubbingEnabled="True"
            IsHitTestVisible="False"
            Opacity="0.35"/>

        <Rectangle Fill="#66030D16"/>

        <Rectangle Opacity="0.35">
            <Rectangle.Fill>
                <RadialGradientBrush Center="0.5,0.38" GradientOrigin="0.5,0.38" RadiusX="0.9" RadiusY="0.9">
                    <GradientStop Color="#111E7AAD" Offset="0"/>
                    <GradientStop Color="#88102F4A" Offset="0.58"/>
                    <GradientStop Color="#DD071A2A" Offset="1"/>
                </RadialGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Grid
            x:Name="Dialog"
            Width="880"
            Height="760"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Opacity="1">

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

                <StackPanel
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,58">

                    <Grid Width="104" Height="104" Margin="0,0,26,0">
                        <Image Source="Assets/WarIncBattleZoneIcon.png" Stretch="Uniform"/>
                    </Grid>

                    <TextBlock
                        Text="ECLIPSE"
                        Foreground="{StaticResource TextWhite}"
                        FontFamily="Verdana"
                        FontSize="62"
                        FontWeight="Bold"
                        VerticalAlignment="Center"/>

                    <TextBlock
                        Text="STUDIO"
                        Foreground="{StaticResource TextBlue}"
                        FontFamily="Verdana"
                        FontSize="62"
                        FontWeight="Bold"
                        VerticalAlignment="Center"
                        Margin="16,0,0,0"/>

                </StackPanel>

                <Button
                    x:Name="BtnPlayGame" BorderBrush="#0039A8E8"
                    Style="{StaticResource PlayButton}"
                    Content="PLAY GAME"/>

                <Button
                    x:Name="BtnLevelEditor"
                    Style="{StaticResource MenuButton}"
                    Content="LEVEL EDITOR"/>

                <Button
                    x:Name="BtnParticleEditor"
                    Style="{StaticResource MenuButton}"
                    Content="PARTICLE EDITOR"/>

                <Button
                    x:Name="BtnPhysicsEditor"
                    Style="{StaticResource MenuButton}"
                    Content="PHYSICS EDITOR"/>

                <Button
                    x:Name="BtnCharacterEditor"
                    Style="{StaticResource MenuButton}"
                    Content="CHARACTER EDITOR"/>

                <Button
                    x:Name="BtnExit"
                    Style="{StaticResource MenuButton}"
                    Content="EXIT"/>

            </StackPanel>
        </Grid>

    </Grid>
</UserControl>