<UserControl
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Width="1280"
    Height="720">

    <Grid Background="#AA05070A">
        <Border
            Width="620"
            Height="360"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="#EE10141B"
            BorderBrush="#FF414C59"
            BorderThickness="1">

            <Grid Margin="30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="60"/>
                    <RowDefinition Height="44"/>
                    <RowDefinition Height="44"/>
                    <RowDefinition Height="44"/>
                    <RowDefinition Height="60"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock
                    Grid.Row="0"
                    Text="WAR INC / NOESIS GUI TEST"
                    Foreground="#FFE8EDF2"
                    FontSize="28"
                    FontWeight="Bold"
                    VerticalAlignment="Center"/>

                <TextBox
                    Grid.Row="1"
                    Height="34"
                    Text="login"
                    FontSize="16"
                    Margin="0,4,0,4"/>

                <TextBox
                    Grid.Row="2"
                    Height="34"
                    Text="password"
                    FontSize="16"
                    Margin="0,4,0,4"/>

                <CheckBox
                    Grid.Row="3"
                    Content="Remember login"
                    Foreground="#FFC8D0D8"
                    FontSize="15"
                    VerticalAlignment="Center"/>

                <StackPanel
                    Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center">

                    <Button
                        Width="130"
                        Height="38"
                        Content="EXIT"
                        Margin="0,0,12,0"/>

                    <Button
                        Width="130"
                        Height="38"
                        Content="LOGIN"/>
                </StackPanel>

                <TextBlock
                    Grid.Row="5"
                    Text="XAML loaded. Renderer step is next."
                    Foreground="#FF77828E"
                    FontSize="13"
                    VerticalAlignment="Bottom"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>