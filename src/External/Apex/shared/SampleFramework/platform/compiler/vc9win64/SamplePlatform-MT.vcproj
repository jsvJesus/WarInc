      <Tool Name="VCXMLDataGeneratorTool" />
      <Tool Name="VCWebDeploymentTool" />
      <Tool Name="VCManagedWrapperGeneratorTool" />
      <Tool Name="VCAuxiliaryManagedWrapperGeneratorTool" />
    </Configuration>
