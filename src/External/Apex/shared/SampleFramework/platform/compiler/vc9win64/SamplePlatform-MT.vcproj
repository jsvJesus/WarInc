  <Configurations>
    <Configuration
        Name="debug|x64"
        OutputDirectory="../../lib/WIN64"
        IntermediateDirectory="x64/SamplePlatform-MT/debug"
        ConfigurationType="4"
        InheritedPropertySheets=""
        CharacterSet="2">
      <Tool
          Name="VCCLCompilerTool"
          AdditionalIncludeDirectories="&quot;..\..\include&quot;;&quot;..\..\..\renderer\include&quot;;&quot;..\..\..\..\..\externals\glew\include&quot;;&quot;..\..\..\..\..\externals\cg\include&quot;;&quot;F:/src/sw/physx/APEXSDK/1.0/RELEASE/shared/pxtask/include&quot;;&quot;..\..\..\..\..\public\foundation&quot;;&quot;..\..\..\framework\include&quot;;&quot;..\..\..\..\shared\include&quot;;&quot;..\..\..\..\reviewed\include&quot;;&quot;..\..\..\..\..\public\foundation\windows&quot;;&quot;..\..\..\..\reviewed\include\windows&quot;;&quot;..\..\..\..\..\..\..\..\..\tools\sdk\DirectX_Jun2010\Include&quot;"
          PreprocessorDefinitions="WIN32;WIN64;PHYSX_PROFILE_SDK;_DEBUG"
          WarningLevel="4"
          Optimization="4"
          AdditionalOptions="/WX /GR-"
          ExceptionHandling="1"
          DebugInformationFormat="3"
          RuntimeLibrary="1"
      />
      <Tool Name="VCCustomBuildTool" />
      <Tool
          Name="VCLibrarianTool"
          OutputFile="$(OutDir)/PlatformDEBUG-MT.lib"
          ProgramDatabaseFile="$(OutDir)/PlatformDEBUG-MT.lib.pdb"
          LinkLibraryDependencies="true"
          AdditionalOptions=""
          AdditionalDependencies=""
          AdditionalLibraryDirectories=""
      />
      <Tool Name="VCMIDLTool" />
      <Tool Name="VCPreBuildEventTool" />
      <Tool Name="VCPostBuildEventTool" />
      <Tool Name="VCPreLinkEventTool" />
      <Tool Name="VCResourceCompilerTool" />
