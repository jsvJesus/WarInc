<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="12.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <PropertyGroup>
    <WarIncLibCurlRoot>$(MSBuildThisFileDirectory)</WarIncLibCurlRoot>
    <WarIncChilkatCompatRoot>$(MSBuildThisFileDirectory)..\ChilKat\include\</WarIncChilkatCompatRoot>
    <WarIncZLibRoot>$(MSBuildThisFileDirectory)..\..\Eternity\Source\ZLib\src\</WarIncZLibRoot>
    <WarIncMinizRoot>$(MSBuildThisFileDirectory)..\miniz\</WarIncMinizRoot>
  </PropertyGroup>

  <ItemDefinitionGroup>
    <ClCompile>
      <AdditionalIncludeDirectories>
        $(WarIncLibCurlRoot)include;
        $(WarIncChilkatCompatRoot);
        $(WarIncZLibRoot);
        $(WarIncMinizRoot);
        %(AdditionalIncludeDirectories)
      </AdditionalIncludeDirectories>

      <PreprocessorDefinitions>
        CURL_STATICLIB;
        WARINC_USE_LIBCURL=1;
        %(PreprocessorDefinitions)
      </PreprocessorDefinitions>
    </ClCompile>

    <Link>
      <AdditionalLibraryDirectories>
        $(WarIncLibCurlRoot)lib\x64;
        %(AdditionalLibraryDirectories)
      </AdditionalLibraryDirectories>

      <AdditionalDependencies>
        libcurl_a.lib;
        ws2_32.lib;
        wldap32.lib;
        crypt32.lib;
        normaliz.lib;
        advapi32.lib;
        secur32.lib;
        bcrypt.lib;
        %(AdditionalDependencies)
      </AdditionalDependencies>
    </Link>
  </ItemDefinitionGroup>

</Project>
